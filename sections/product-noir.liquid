{%- liquid
  assign s = section.settings
  assign col = collections[s.collection]

  assign demo_names = 'Structured Wool Coat,Tailored Trouser,Cashmere Roll Neck,Leather Chelsea Boot,Belted Trench,Pleated Skirt,Silk Shirt,Knit Vest' | split: ','
  assign demo_prices = '$1,290|$420|$540|$680|$1,150|$390|$310|$280' | split: '|'
  assign demo_cats = 'Outerwear,Tailoring,Knitwear,Footwear,Outerwear,Skirts,Shirts,Knitwear' | split: ','
  assign g1 = 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&w=700&q=80'
  assign g2 = 'https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?auto=format&fit=crop&w=700&q=80'
  assign g3 = 'https://images.unsplash.com/photo-1520975954732-35dd22299614?auto=format&fit=crop&w=700&q=80'
  assign g4 = 'https://images.unsplash.com/photo-1543163521-1bf539c55dd2?auto=format&fit=crop&w=700&q=80'
  assign g5 = 'https://images.unsplash.com/photo-1566174053879-31528523f8ae?auto=format&fit=crop&w=700&q=80'
  assign g6 = 'https://images.unsplash.com/photo-1525507119028-ed4c629a60a3?auto=format&fit=crop&w=700&q=80'
  assign g7 = 'https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=700&q=80'
  assign g8 = 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=700&q=80'
  assign demo_imgs_str = g1 | append: '||' | append: g2 | append: '||' | append: g3 | append: '||' | append: g4 | append: '||' | append: g5 | append: '||' | append: g6 | append: '||' | append: g7 | append: '||' | append: g8
  assign demo_imgs = demo_imgs_str | split: '||'
-%}

<section
  id="section-{{ section.id }}"
  class="pno-section pno--{{ s.scheme }}"
  data-section-id="{{ section.id }}"
  data-qv-scheme="{{ s.scheme }}"
>
  <div class="pno-inner">
    <div class="pno-head reveal">
      <div class="pno-head__l">
        {%- if s.eyebrow != blank -%}<span class="pno-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="pno-heading">{{ s.heading }}</h2>{%- endif -%}
      </div>
      <div class="pno-head__r">
        {%- if s.note != blank -%}<p class="pno-note">{{ s.note }}</p>{%- endif -%}
        {%- if s.cta_label != blank -%}<a href="{{ col.url | default: s.cta_url | default: '/collections/all' }}" class="pno-cta">{{ s.cta_label }} <span aria-hidden="true">&#8594;</span></a>{%- endif -%}
      </div>
    </div>

    <div class="pno-grid" style="--pno-cols: {{ s.columns }};">
      {%- if col != blank and col.products.size > 0 -%}
        {%- for product in col.products limit: s.products_to_show -%}
          <div class="pno-item reveal">{%- render 'product-card', product: product, scheme: s.scheme, number: forloop.index -%}</div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          {%- if forloop.index > s.products_to_show -%}{%- break -%}{%- endif -%}
          {%- assign idx = forloop.index0 -%}
          <div class="pno-item reveal">{%- render 'product-card',
            scheme: s.scheme, number: forloop.index,
            demo_index: idx,
            demo_title: demo_names[idx],
            demo_price: demo_prices[idx],
            demo_category: demo_cats[idx],
            demo_image: demo_imgs[idx],
            demo_url: '/collections/all' -%}</div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }}.pno--light { --bg:#ECE9E2; --fg:#18181A; --acc:var(--gold,#9A7B43); --mut:rgba(24,24,26,.55); --bdr:rgba(24,24,26,.16); }
  #section-{{ section.id }}.pno--dark  { --bg:#161618; --fg:#ECE9E2; --acc:var(--gold,#C8A96E); --mut:rgba(236,233,226,.52); --bdr:rgba(236,233,226,.16); }
  #section-{{ section.id }}.pno--warm  { --bg:#E7DCCB; --fg:#241D15; --acc:var(--gold,#8E4F2A); --mut:rgba(36,29,21,.55); --bdr:rgba(36,29,21,.2); }
  #section-{{ section.id }}.pno--theme { --bg:var(--background,#161618); --fg:var(--foreground,#ECE9E2); --acc:var(--gold,#C8A96E); --mut:var(--muted,rgba(236,233,226,.52)); --bdr:var(--border,rgba(236,233,226,.16)); }

  #section-{{ section.id }} { background: var(--bg); color: var(--fg); padding: var(--section-spacing,80px) var(--side-padding,5vw); }
  #section-{{ section.id }} .pno-inner { max-width: var(--container-width,1440px); margin: 0 auto; }

  #section-{{ section.id }} .pno-head { display: grid; grid-template-columns: 1fr auto; align-items: flex-end; gap: 24px; margin-bottom: clamp(40px,5vw,68px); padding-bottom: 22px; border-bottom: 1px solid var(--bdr); }
  #section-{{ section.id }} .pno-eyebrow { display: block; font-family: var(--ff-body,'Outfit',sans-serif); font-size: 11px; font-weight: 500; letter-spacing: .26em; text-transform: uppercase; color: var(--acc); margin-bottom: 14px; }
  #section-{{ section.id }} .pno-heading { font-family: var(--ff-display,'Cormorant Garamond',serif); font-size: calc(clamp(34px,5vw,72px) * var(--heading-scale,1)); font-weight: 300; line-height: .98; text-transform: uppercase; margin: 0; }
  #section-{{ section.id }} .pno-head__r { text-align: right; }
  #section-{{ section.id }} .pno-note { font-family: var(--ff-body,'Outfit',sans-serif); font-size: 13px; line-height: 1.6; color: var(--mut); max-width: 280px; margin: 0 0 12px auto; }
  #section-{{ section.id }} .pno-cta { display: inline-flex; align-items: center; gap: 8px; font-family: var(--ff-body,'Outfit',sans-serif); font-size: 11px; font-weight: 500; letter-spacing: .16em; text-transform: uppercase; color: var(--fg); text-decoration: none; border-bottom: 1px solid var(--acc); padding-bottom: 4px; transition: color .2s; }
  #section-{{ section.id }} .pno-cta:hover { color: var(--acc); }

  #section-{{ section.id }} .pno-grid { display: grid; grid-template-columns: repeat(var(--pno-cols,4), 1fr); gap: clamp(16px,2vw,34px); }
  /* Editorial stagger — lift every 2nd & 3rd column on desktop */
  #section-{{ section.id }} .pno-item:nth-child(4n+2) { transform: translateY(clamp(20px,3vw,52px)); }
  #section-{{ section.id }} .pno-item:nth-child(4n+3) { transform: translateY(clamp(10px,1.6vw,28px)); }

  #section-{{ section.id }} .reveal.reveal-armed { opacity: 0; transform: translateY(28px); transition: opacity .7s ease, transform .7s ease; }
  #section-{{ section.id }} .reveal.is-visible { opacity: 1; }
  #section-{{ section.id }} .pno-item.reveal-armed { opacity: 0; }
  #section-{{ section.id }} .pno-item.is-visible { opacity: 1; }
  #section-{{ section.id }} .pno-grid .pno-item:nth-child(2){transition-delay:.05s;}
  #section-{{ section.id }} .pno-grid .pno-item:nth-child(3){transition-delay:.1s;}
  #section-{{ section.id }} .pno-grid .pno-item:nth-child(4){transition-delay:.15s;}

  @media (max-width: 1100px) { #section-{{ section.id }} .pno-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) {
    #section-{{ section.id }} .pno-grid { grid-template-columns: repeat(2, 1fr); }
    #section-{{ section.id }} .pno-item:nth-child(4n+2),
    #section-{{ section.id }} .pno-item:nth-child(4n+3) { transform: none; }
    #section-{{ section.id }} .pno-head { grid-template-columns: 1fr; }
    #section-{{ section.id }} .pno-head__r { text-align: left; }
    #section-{{ section.id }} .pno-note { margin-left: 0; }
  }
</style>

<script>
(function(){
  var SEC='{{ section.id }}';
  function arm(root){
    var els=root.querySelectorAll('.reveal');
    els.forEach(function(el){el.classList.add('reveal-armed');});
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:.1});
    els.forEach(function(el){io.observe(el);});
    setTimeout(function(){els.forEach(function(el){el.classList.add('is-visible');});},800);
  }
  function root(){return document.getElementById('section-'+SEC);}
  document.addEventListener('DOMContentLoaded',function(){var r=root();if(r)arm(r);});
  document.addEventListener('shopify:section:load',function(e){if(e.detail.sectionId!==SEC)return;var r=root();if(r){arm(r);r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});}});
})();
</script>

{% schema %}
{
  "name": "Product Noir",
  "tag": "section",
  "class": "section-product-noir",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (bone)" },
        { "value": "dark",  "label": "Dark (graphite)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "dark"
    },
    { "type": "paragraph", "content": "Card design, image ratio, hover behaviour, wishlist and quick view all follow Theme settings → Product Cards. Demo items show until a collection is connected." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Defining Pieces" },
    { "type": "textarea", "id": "note", "label": "Note (top-right)", "default": "Investment essentials, cut from the season's finest materials." },
    { "type": "collection", "id": "collection", "label": "Collection (demo items if empty)" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 8 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 3, "max": 4, "step": 1, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop All" },
    { "type": "url",  "id": "cta_url",   "label": "CTA link" }
  ],
  "presets": [ { "name": "Product Noir" } ]
}
{% endschema %}
