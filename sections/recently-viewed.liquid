<section class="section recently-viewed" id="section-{{ section.id }}">
  <div class="container recently-viewed__inner" style="display:none;">
    <div class="section-head">
      <h2 class="section-head__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="product-grid product-grid--{{ section.settings.columns }}" id="recently-viewed-grid"></div>
  </div>
</section>

<style>
  .recently-viewed { padding: var(--section-spacing) 0; border-top: 1px solid var(--border); }
</style>

<script>
  (function() {
    const STORAGE_KEY = 'mn_recently_viewed';
    const currentProductId = {{ product.id | json }};
    const limit = {{ section.settings.products_to_show }};

    let viewed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    viewed = viewed.filter(id => id !== currentProductId);
    if (currentProductId) {
      viewed.unshift(currentProductId);
      viewed = viewed.slice(0, 12);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(viewed));
    }

    const displayIds = viewed.filter(id => id !== currentProductId).slice(0, limit);
    if (displayIds.length === 0) return;

    const container = document.querySelector('.recently-viewed__inner');
    const grid = document.getElementById('recently-viewed-grid');
    if (!container || !grid) return;

    Promise.all(displayIds.map(id =>
      fetch('/products.json?product_id=' + id + '&view=json').then(r => r.json()).catch(() => null)
    )).then(results => {
      results.forEach(data => {
        if (data && data.product) {
          const p = data.product;
          const card = document.createElement('div');
          card.className = 'product-card product-card--style-1';
          card.innerHTML = `
            <div class="product-card__media product-card__media--portrait">
              <a href="/products/${p.handle}" aria-label="${p.title}">
                ${p.images[0] ? `<img class="product-card__img product-card__img--primary" src="${p.images[0].src}" alt="${p.title}" loading="lazy">` : ''}
              </a>
            </div>
            <div class="product-card__info">
              <a href="/products/${p.handle}" class="product-card__title">${p.title}</a>
              <div class="product-card__price"><span class="price-current">${window.MaisonNoir ? window.MaisonNoir.formatMoney(p.variants[0].price) : '$' + (p.variants[0].price / 100).toFixed(2)}</span></div>
            </div>`;
          grid.appendChild(card);
        }
      });
      if (grid.children.length > 0) container.style.display = '';
    }).catch(() => {});
  })();
</script>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "settings": [
    { "type": "text",  "id": "heading",          "label": "Heading",          "default": "Recently Viewed" },
    { "type": "range", "id": "products_to_show", "label": "Products to Show", "min": 2, "max": 6, "step": 1, "default": 4 },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "presets": [{ "name": "Recently Viewed" }]
}
{% endschema %}
