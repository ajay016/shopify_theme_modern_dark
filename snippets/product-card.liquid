{%- comment -%}
  Product Card Snippet — unified "Atelier" card used site-wide.

  Renders one consistent, scheme-aware product card on collection, search,
  cart, recommendations AND the bespoke homepage sections (product-rail,
  product-showcase, featured-products). All visual options are driven by
  Theme Settings → Product Cards, with per-render overrides.

  Accepts:
    - product {Object}            a real product. If blank, demo_* params are used.
    - scheme {String}             'theme' (default) | 'light' | 'dark' | 'warm'
    - card_style {String}         'atelier' (default) | 'minimal' | 'overlay' | 'bordered'
    - image_ratio {String}        'portrait' | 'square' | 'landscape'
    - media_hover {String}        'zoom' | 'second_image' | 'carousel' | 'none'
    - quickadd_style {String}     'slide_up' | 'popup' | 'always'
    - show_vendor / show_category / show_number {Boolean}
    - show_wishlist / show_quickview {Boolean}
    - show_price_compare {Boolean}
    - text_align {String}         'left' | 'center'
    - radius {String}             'none' | 'subtle' | 'rounded'
    - number {Number}             index used for the 01–08 corner badge (optional)
    - rail {Boolean}              true when placed in a horizontal scroll rail
    - lazy {Boolean}              lazy-load images (default true)

  Demo fallback (when product is blank):
    - demo_title, demo_price, demo_category, demo_image, demo_url, demo_index
{%- endcomment -%}

{%- liquid
  assign card_style    = card_style    | default: settings.product_card_style    | default: 'atelier'
  assign image_ratio   = image_ratio   | default: settings.product_card_image_ratio | default: 'portrait'
  assign media_hover   = media_hover   | default: settings.product_card_media_hover | default: 'zoom'
  assign quickadd_style = quickadd_style | default: settings.product_card_quickadd_style | default: 'slide_up'
  assign text_align    = text_align    | default: settings.product_card_text_align | default: 'left'
  assign radius        = radius        | default: settings.product_card_radius   | default: 'subtle'
  assign scheme        = scheme        | default: 'theme'

  assign show_vendor   = show_vendor   | default: settings.product_card_show_vendor
  assign show_category = show_category | default: settings.product_card_show_category
  assign show_number   = show_number   | default: settings.product_card_show_number
  assign show_wishlist = show_wishlist | default: settings.product_card_show_wishlist
  assign show_quickview = show_quickview | default: settings.product_card_show_quickview
  assign show_price_compare = show_price_compare | default: settings.product_card_show_price_compare

  assign img_loading = 'lazy'
  if lazy == false
    assign img_loading = 'eager'
  endif

  assign is_demo = false
  if product == blank
    assign is_demo = true
  endif

  assign wl_on = false
  if settings.wishlist_enabled and show_wishlist
    assign wl_on = true
  endif
  assign qv_on = false
  if settings.quickview_enabled and show_quickview
    assign qv_on = true
  endif
-%}

{%- if is_demo -%}
  {%- comment -%}— Demo card (no collection connected) —{%- endcomment -%}
  {%- liquid
    assign d_title = demo_title | default: 'Atelier Piece'
    assign d_url   = demo_url   | default: '/collections/all'
    assign d_cat   = demo_category | default: 'Atelier'
    assign d_price = demo_price | default: '$0'
    assign d_img   = demo_image
  -%}
  <div
    class="product-card pcard pcard--{{ scheme }} pcard--{{ card_style }} pcard--align-{{ text_align }} pcard--rad-{{ radius }}{% if rail %} pcard--rail{% endif %}"
    data-pcard
    data-quickadd="{{ quickadd_style }}"
  >
    <script type="application/json" class="product-card__json">{"id":0,"title":{{ d_title | json }},"vendor":{{ shop.name | json }},"url":{{ d_url | json }},"price":0,"compare_at_price":0,"body_html":"Demo product — connect a collection in the theme editor to show your own pieces.","images":[{{ d_img | json }}],"options":["Title"],"variants":[{"id":0,"price":0,"compare_at_price":0,"available":true,"options":["Default Title"]}]}</script>

    <div class="pcard__media pcard__media--{{ image_ratio }} pcard__media--hov-{{ media_hover }}">
      <a href="{{ d_url }}" class="pcard__imglink" aria-label="{{ d_title | escape }}">
        <img class="pcard__img pcard__img--a" src="{{ d_img }}" alt="{{ d_title | escape }}" loading="{{ img_loading }}" />
      </a>
      {%- if show_number and demo_index -%}
        <span class="pcard__num">{{ demo_index | plus: 1 | prepend: '0' | slice: -2, 2 }}</span>
      {%- endif -%}

      <div class="pcard__icons">
        {%- if wl_on -%}
          <button class="pcard-icon-btn" data-wishlist-id="demo-{{ demo_index | default: 0 }}" aria-label="Add to wishlist" aria-pressed="false">{%- render 'icon-wishlist' -%}</button>
        {%- endif -%}
        {%- if qv_on -%}
          <button class="pcard-icon-btn" data-open-quickview data-product-url="{{ d_url }}" aria-label="Quick view {{ d_title | escape }}">{%- render 'icon-eye' -%}</button>
        {%- endif -%}
      </div>

      {%- unless quickadd_style == 'none' -%}
        <a href="{{ d_url }}" class="pcard-atc pcard-btn--atc">
          {%- render 'icon-bag' -%}
          <span class="pcard-atc__label">View Product</span>
        </a>
      {%- endunless -%}
    </div>

    <div class="pcard__info">
      {%- if show_category -%}<span class="pcard__cat">{{ d_cat }}</span>{%- endif -%}
      <span class="pcard__name"><a href="{{ d_url }}">{{ d_title }}</a></span>
      <span class="pcard__price">{{ d_price }}</span>
    </div>
  </div>

{%- else -%}
  {%- comment -%}— Real product card —{%- endcomment -%}
  {%- liquid
    assign p_alt = product.title | escape
    assign first_variant = product.first_available_variant | default: product.variants.first

    assign imgs_j = '['
    for img in product.images limit: 8
      assign img_src = img | image_url: width: 800
      if forloop.first
        assign imgs_j = imgs_j | append: '"' | append: img_src | append: '"'
      else
        assign imgs_j = imgs_j | append: ',"' | append: img_src | append: '"'
      endif
    endfor
    assign imgs_j = imgs_j | append: ']'

    assign vars_j = '['
    for v in product.variants
      assign opt1_j = v.option1 | json
      assign opts_j = '[' | append: opt1_j
      if v.option2 != blank
        assign opt2_j = v.option2 | json
        assign opts_j = opts_j | append: ',' | append: opt2_j
      endif
      if v.option3 != blank
        assign opt3_j = v.option3 | json
        assign opts_j = opts_j | append: ',' | append: opt3_j
      endif
      assign opts_j = opts_j | append: ']'
      assign v_cmp = v.compare_at_price | default: 0
      assign v_avail = 'false'
      if v.available
        assign v_avail = 'true'
      endif
      assign v_obj = '{"id":' | append: v.id | append: ',"price":' | append: v.price | append: ',"compare_at_price":' | append: v_cmp | append: ',"available":' | append: v_avail | append: ',"options":' | append: opts_j | append: '}'
      if forloop.first
        assign vars_j = vars_j | append: v_obj
      else
        assign vars_j = vars_j | append: ',' | append: v_obj
      endif
    endfor
    assign vars_j = vars_j | append: ']'
  -%}
  <div
    class="product-card pcard pcard--{{ scheme }} pcard--{{ card_style }} pcard--align-{{ text_align }} pcard--rad-{{ radius }}{% if rail %} pcard--rail{% endif %}"
    data-pcard
    data-product-id="{{ product.id }}"
    data-quickadd="{{ quickadd_style }}"
  >
    <script type="application/json" class="product-card__json">{"id":{{ product.id }},"title":{{ product.title | json }},"vendor":{{ product.vendor | json }},"url":{{ product.url | json }},"price":{{ product.price }},"compare_at_price":{{ product.compare_at_price | default: 0 }},"body_html":{{ product.description | json }},"images":{{ imgs_j }},"options":{{ product.options | json }},"variants":{{ vars_j }}}</script>

    <div class="pcard__media pcard__media--{{ image_ratio }} pcard__media--hov-{{ media_hover }}">
      <a href="{{ product.url }}" class="pcard__imglink" aria-label="{{ p_alt }}">
        {%- if product.featured_image != blank -%}
          {{ product.featured_image | image_url: width: 700 | image_tag:
            loading: img_loading, class: 'pcard__img pcard__img--a',
            sizes: '(max-width:700px) 64vw, (max-width:1100px) 33vw, 24vw',
            widths: '350,500,700,900', alt: p_alt }}
          {%- if media_hover == 'second_image' and product.images.size > 1 -%}
            {{ product.images[1] | image_url: width: 700 | image_tag:
              loading: 'lazy', class: 'pcard__img pcard__img--b', alt: p_alt }}
          {%- endif -%}
          {%- if media_hover == 'carousel' and product.images.size > 1 -%}
            {%- for img in product.images offset: 1 limit: 3 -%}
              {{ img | image_url: width: 700 | image_tag:
                loading: 'lazy', class: 'pcard__img pcard__img--cycle', alt: p_alt }}
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          <span class="pcard__img pcard__img--a pcard__img--placeholder">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </span>
        {%- endif -%}
      </a>

      {%- if show_number and number -%}
        <span class="pcard__num">{{ number | prepend: '0' | slice: -2, 2 }}</span>
      {%- endif -%}

      {%- if product.available == false -%}
        <span class="pcard__badge">{{ 'products.product.sold_out_badge' | t }}</span>
      {%- elsif product.compare_at_price > product.price -%}
        {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="pcard__badge pcard__badge--sale">−{{ discount_pct }}%</span>
      {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
        <span class="pcard__badge">{{ 'products.product.new_badge' | t }}</span>
      {%- endif -%}

      <div class="pcard__icons">
        {%- if wl_on -%}
          <button class="pcard-icon-btn" data-wishlist-id="{{ product.id }}" aria-label="{{ 'accessibility.wishlist_add' | t }}" aria-pressed="false">{%- render 'icon-wishlist' -%}</button>
        {%- endif -%}
        {%- if qv_on -%}
          <button class="pcard-icon-btn" data-open-quickview data-product-url="{{ product.url }}" aria-label="{{ 'accessibility.quick_view' | t: product_title: product.title }}">{%- render 'icon-eye' -%}</button>
        {%- endif -%}
      </div>

      {%- comment -%}Add to bag — popup opens quick view; single variant adds directly; else select options{%- endcomment -%}
      {%- unless quickadd_style == 'none' -%}
        {%- if quickadd_style == 'popup' and settings.quickview_enabled -%}
          <button class="pcard-atc pcard-btn--atc" data-open-quickview data-product-url="{{ product.url }}" aria-label="{{ 'accessibility.add_to_cart' | t: product_title: product.title }}">
            {%- render 'icon-bag' -%}
            <span class="pcard-atc__label">Add to Bag</span>
          </button>
        {%- elsif product.variants.size == 1 and first_variant -%}
          <button class="pcard-atc pcard-btn--atc" data-variant-id="{{ first_variant.id }}" aria-label="{{ 'accessibility.add_to_cart' | t: product_title: product.title }}" {% unless first_variant.available %}disabled{% endunless %}>
            {%- render 'icon-bag' -%}
            <span class="pcard-atc__label">{% if first_variant.available %}Add to Bag{% else %}{{ 'products.product.sold_out' | t }}{% endif %}</span>
          </button>
        {%- elsif qv_on -%}
          <button class="pcard-atc pcard-btn--atc" data-open-quickview data-product-url="{{ product.url }}">
            {%- render 'icon-bag' -%}
            <span class="pcard-atc__label">Add to Bag</span>
          </button>
        {%- else -%}
          <a href="{{ product.url }}" class="pcard-atc">
            {%- render 'icon-bag' -%}
            <span class="pcard-atc__label">Select Options</span>
          </a>
        {%- endif -%}
      {%- endunless -%}
    </div>

    <div class="pcard__info">
      {%- if show_category and product.type != blank -%}
        <span class="pcard__cat">{{ product.type }}</span>
      {%- elsif show_vendor and product.vendor != blank -%}
        <span class="pcard__cat">{{ product.vendor }}</span>
      {%- endif -%}
      <span class="pcard__name"><a href="{{ product.url }}">{{ product.title }}</a></span>
      <span class="pcard__price">
        {%- if show_price_compare and product.compare_at_price > product.price -%}
          <span class="pcard__price-now">{{ product.price | money }}</span>
          <s class="pcard__price-was">{{ product.compare_at_price | money }}</s>
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </span>
    </div>
  </div>
{%- endif -%}
