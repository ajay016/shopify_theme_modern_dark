<!doctype html>
<html
  class="no-js"
  lang="{{ request.locale.iso_code }}"
  dir="ltr"
>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height">
  <meta name="theme-color" content="{{ settings.color_black }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {%- liquid
    case settings.font_pairing
      when 'playfair_inter'
        assign gf_url = 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500&display=swap'
      when 'libre_raleway'
        assign gf_url = 'https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;600&display=swap'
      when 'dm_serif_dm_sans'
        assign gf_url = 'https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap'
      else
        assign gf_url = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Outfit:wght@200;300;400;500&display=swap'
    endcase
  -%}
  <link href="{{ gf_url }}" rel="stylesheet">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%}OG / Social meta{%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}

  {{ content_for_header }}

  {%- comment -%}Dynamic CSS custom properties (colors, fonts, layout){%- endcomment -%}
  {%- render 'css-variables' -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body
  class="template-{{ request.page_type }}"
  data-cursor-style="{{ settings.custom_cursor_style }}"
  data-free-shipping-threshold="{{ settings.cart_free_shipping_threshold }}"
>

  {%- comment -%}Custom cursor (conditionally rendered){%- endcomment -%}
  {%- if settings.custom_cursor -%}
    <div class="cursor" id="cursor" aria-hidden="true"></div>
    <div class="cursor-ring" id="cursorRing" aria-hidden="true"></div>
  {%- endif -%}

  {%- comment -%}Skip link{%- endcomment -%}
  <a class="skip-to-content-link button visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_text' | t }}
  </a>

  {%- comment -%}Announcement Bar{%- endcomment -%}
  {%- if settings.announcement_enabled -%}
    {%- section 'announcement-bar' -%}
  {%- endif -%}

  {%- comment -%}Header{%- endcomment -%}
  {%- section 'header' -%}

  {%- comment -%}Cart Drawer (when drawer mode enabled){%- endcomment -%}
  {%- if settings.cart_type == 'drawer' -%}
    {%- section 'cart-drawer' -%}
  {%- endif -%}

  {%- comment -%}Quick View Modal (global, filled via JS){%- endcomment -%}
  {%- if settings.quickview_enabled -%}
    <div id="quick-view-overlay" class="modal-overlay" role="dialog" aria-modal="true" aria-label="{{ 'quick_view.title' | t }}">
      <div class="quick-view-modal" id="quick-view-modal"></div>
    </div>
  {%- endif -%}

  {%- comment -%}Main content{%- endcomment -%}
  <main
    id="MainContent"
    class="content-for-layout"
    role="main"
    tabindex="-1"
  >
    {{ content_for_layout }}
  </main>

  {%- comment -%}Footer{%- endcomment -%}
  {%- section 'footer' -%}

  {%- comment -%}Toast notification (JS appended){%- endcomment -%}

  {%- comment -%}Accessibility: page refresh message{%- endcomment -%}
  <ul hidden id="a11y-refresh-page-message">
    <li>{{ 'accessibility.refresh_page' | t }}</li>
  </ul>

  {%- comment -%}Scripts{%- endcomment -%}
  <script>
    window.routes = {
      root_url:        "{{ routes.root_url }}",
      cart_url:        "{{ routes.cart_url }}",
      cart_add_url:    "{{ routes.cart_add_url }}",
      cart_change_url: "{{ routes.cart_change_url }}",
      search_url:      "{{ routes.search_url }}"
    };
    window.theme_strings = {
      added_to_cart:           {{ 'cart.added' | t | json }},
      free_shipping_message:   {{ 'cart.free_shipping_message' | t | json }},
      free_shipping_achieved:  {{ 'cart.free_shipping_achieved' | t | json }},
      wishlist_added:          {{ 'wishlist.added' | t | json }},
      wishlist_removed:        {{ 'wishlist.removed' | t | json }}
    };
    window.theme_settings = {
      custom_cursor:    {{ settings.custom_cursor | json }},
      wishlist_enabled: {{ settings.wishlist_enabled | json }},
      quickview_enabled:{{ settings.quickview_enabled | json }},
      animations:       {{ settings.animations_scroll_reveal | json }}
    };
  </script>

  {{ 'theme.js' | asset_url | script_tag }}

  {%- if settings.custom_cursor -%}
    {{ 'custom-cursor.js' | asset_url | script_tag }}
  {%- endif -%}

</body>
</html>
