{%- liquid
  assign blog_handle    = section.settings.blog
  assign posts_to_show  = section.settings.posts_to_show
  assign blog_obj       = blogs[blog_handle]
  assign layout         = section.settings.layout
-%}

<section class="section blog-posts" id="section-{{ section.id }}">
  <div class="container">
    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-head__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if blog_obj != blank -%}
        <a href="{{ blog_obj.url }}" class="section-link">{{ section.settings.view_all_label | default: 'View All' }}</a>
      {%- endif -%}
    </div>

    {%- if blog_obj != blank and blog_obj.articles_count > 0 -%}
      <div class="blog-posts__grid blog-posts__grid--{{ layout }}">
        {%- for article in blog_obj.articles limit: posts_to_show -%}
          {%- assign article_img_alt = article.title | escape -%}
          <article class="blog-card reveal reveal-delay-{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <a href="{{ article.url }}" class="blog-card__media-link" tabindex="-1" aria-hidden="true">
              <div class="blog-card__media">
                {%- if article.image != blank -%}
                  {{
                    article.image
                    | image_url: width: 800
                    | image_tag: class: 'blog-card__img', loading: 'lazy', alt: article_img_alt
                  }}
                {%- else -%}
                  <div class="blog-card__placeholder bp-bg-{{ forloop.index | modulo: 3 | plus: 1 }}">
                    {%- assign ic = forloop.index | modulo: 3 | plus: 1 -%}
                    {%- if ic == 1 -%}
                      <svg width="120" height="90" viewBox="0 0 120 90" fill="none" aria-hidden="true">
                        <rect x="8" y="8" width="104" height="74" rx="2" stroke="rgba(200,169,110,0.3)" stroke-width="1"/>
                        <path d="M8 55 L35 32 L60 48 L82 28 L112 55" stroke="rgba(200,169,110,0.5)" stroke-width="1.2" fill="none"/>
                        <circle cx="35" cy="32" r="4" fill="rgba(200,169,110,0.2)" stroke="rgba(200,169,110,0.4)" stroke-width="0.8"/>
                      </svg>
                    {%- elsif ic == 2 -%}
                      <svg width="80" height="100" viewBox="0 0 80 100" fill="none" aria-hidden="true">
                        <path d="M15 10 Q40 5 65 10 L68 90 L12 90 Z" stroke="rgba(200,169,110,0.3)" stroke-width="1" fill="rgba(200,169,110,0.04)"/>
                        <line x1="20" y1="35" x2="60" y2="35" stroke="rgba(200,169,110,0.25)" stroke-width="0.8"/>
                        <line x1="20" y1="50" x2="60" y2="50" stroke="rgba(200,169,110,0.2)" stroke-width="0.8"/>
                        <line x1="20" y1="65" x2="45" y2="65" stroke="rgba(200,169,110,0.15)" stroke-width="0.8"/>
                      </svg>
                    {%- else -%}
                      <svg width="100" height="80" viewBox="0 0 100 80" fill="none" aria-hidden="true">
                        <circle cx="50" cy="36" r="24" stroke="rgba(200,169,110,0.3)" stroke-width="1" fill="none"/>
                        <path d="M26 36 Q50 10 74 36 Q50 62 26 36 Z" stroke="rgba(200,169,110,0.2)" stroke-width="0.8" fill="rgba(200,169,110,0.04)"/>
                        <circle cx="50" cy="36" r="8" stroke="rgba(200,169,110,0.4)" stroke-width="0.8" fill="none"/>
                        <line x1="50" y1="65" x2="50" y2="75" stroke="rgba(200,169,110,0.25)" stroke-width="1"/>
                      </svg>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- if section.settings.show_category and article.tags.size > 0 -%}
                  <span class="blog-card__tag">{{ article.tags | first }}</span>
                {%- endif -%}
              </div>
            </a>

            <div class="blog-card__body">
              {%- if section.settings.show_date -%}
                <time class="blog-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: '%B %d, %Y' }}
                </time>
              {%- endif -%}

              <h3 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {%- if section.settings.show_excerpt and article.excerpt != blank -%}
                <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
              {%- endif -%}

              <a href="{{ article.url }}" class="blog-card__cta">
                Read More
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                  <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%}Placeholder posts — show even with no blog assigned so preview looks complete{%- endcomment -%}
      {%- liquid
        assign placeholder_titles   = 'The Art of Understated Luxury|How to Build a Considered Wardrobe|Inside Our Milan Atelier' | split: '|'
        assign placeholder_excerpts = 'A deep dive into what quiet luxury means for the modern wardrobe — and why restraint is the ultimate statement.|The capsule wardrobe is not about minimalism for its own sake. It is about choosing with intention, piece by lasting piece.|We open the doors of our workshop to share the craft behind every seam, every decision, every detail.'  | split: '|'
        assign placeholder_dates    = 'May 12, 2025|April 28, 2025|April 10, 2025' | split: ','
      -%}
      <div class="blog-posts__grid blog-posts__grid--{{ layout }}">
        {%- for i in (1..posts_to_show) -%}
          {%- assign pi = i | minus: 1 -%}
          {%- assign bg_mod = i | modulo: 3 | plus: 1 -%}
          <article class="blog-card reveal reveal-delay-{{ forloop.index0 }}">
            <a href="#" class="blog-card__media-link" tabindex="-1" aria-hidden="true">
              <div class="blog-card__media">
                <div class="blog-card__placeholder bp-bg-{{ bg_mod }}">
                  {%- if bg_mod == 1 -%}
                    <svg width="120" height="90" viewBox="0 0 120 90" fill="none" aria-hidden="true">
                      <rect x="8" y="8" width="104" height="74" rx="2" stroke="rgba(200,169,110,0.3)" stroke-width="1"/>
                      <path d="M8 55 L35 32 L60 48 L82 28 L112 55" stroke="rgba(200,169,110,0.5)" stroke-width="1.2" fill="none"/>
                      <circle cx="35" cy="32" r="4" fill="rgba(200,169,110,0.2)" stroke="rgba(200,169,110,0.4)" stroke-width="0.8"/>
                    </svg>
                  {%- elsif bg_mod == 2 -%}
                    <svg width="80" height="100" viewBox="0 0 80 100" fill="none" aria-hidden="true">
                      <path d="M15 10 Q40 5 65 10 L68 90 L12 90 Z" stroke="rgba(200,169,110,0.3)" stroke-width="1" fill="rgba(200,169,110,0.04)"/>
                      <line x1="20" y1="35" x2="60" y2="35" stroke="rgba(200,169,110,0.25)" stroke-width="0.8"/>
                      <line x1="20" y1="50" x2="60" y2="50" stroke="rgba(200,169,110,0.2)" stroke-width="0.8"/>
                      <line x1="20" y1="65" x2="45" y2="65" stroke="rgba(200,169,110,0.15)" stroke-width="0.8"/>
                    </svg>
                  {%- else -%}
                    <svg width="100" height="80" viewBox="0 0 100 80" fill="none" aria-hidden="true">
                      <circle cx="50" cy="36" r="24" stroke="rgba(200,169,110,0.3)" stroke-width="1" fill="none"/>
                      <path d="M26 36 Q50 10 74 36 Q50 62 26 36 Z" stroke="rgba(200,169,110,0.2)" stroke-width="0.8" fill="rgba(200,169,110,0.04)"/>
                      <circle cx="50" cy="36" r="8" stroke="rgba(200,169,110,0.4)" stroke-width="0.8" fill="none"/>
                    </svg>
                  {%- endif -%}
                </div>
                <span class="blog-card__tag">Journal</span>
              </div>
            </a>

            <div class="blog-card__body">
              <time class="blog-card__date">{{ placeholder_dates[pi] | default: 'May 2025' }}</time>
              <h3 class="blog-card__title">
                <a href="#">{{ placeholder_titles[pi] | default: 'From the Atelier' }}</a>
              </h3>
              <p class="blog-card__excerpt">{{ placeholder_excerpts[pi] | default: 'Stories from the world of Maison Noir — craft, culture, and considered design.' }}</p>
              <a href="#" class="blog-card__cta">
                Read More
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                  <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .blog-posts { padding: var(--section-spacing) 0; }

  .blog-posts__grid { display: grid; gap: 40px; }
  .blog-posts__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .blog-posts__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .blog-posts__grid--list { grid-template-columns: 1fr; }

  .blog-card { display: flex; flex-direction: column; }
  .blog-posts__grid--list .blog-card {
    flex-direction: row;
    gap: 48px;
    align-items: flex-start;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  .blog-posts__grid--list .blog-card__media-link { flex: 0 0 360px; }

  .blog-card__media-link { display: block; overflow: hidden; margin-bottom: 24px; }
  .blog-posts__grid--list .blog-card__media-link { margin-bottom: 0; }

  .blog-card__media {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .blog-posts__grid--list .blog-card__media { aspect-ratio: 4/3; }

  .blog-card__img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .blog-card:hover .blog-card__img { transform: scale(1.04); }

  .blog-card__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.6s var(--ease-out);
  }
  .blog-card:hover .blog-card__placeholder { transform: scale(1.04); }

  .bp-bg-1 { background: linear-gradient(135deg, #181410, #24201a, #181410); }
  .bp-bg-2 { background: linear-gradient(135deg, #141820, #1c2030, #141820); }
  .bp-bg-3 { background: linear-gradient(135deg, #1a1420, #221830, #1a1420); }

  .blog-card__tag {
    position: absolute; top: 20px; left: 20px;
    font-size: 8px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--black); background: var(--gold);
    padding: 5px 12px; font-weight: 500;
  }

  .blog-card__body { flex: 1; display: flex; flex-direction: column; }

  .blog-card__date {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); display: block; margin-bottom: 12px;
  }

  .blog-card__title {
    font-family: var(--ff-display);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 300;
    line-height: 1.25;
    margin-bottom: 14px;
  }
  .blog-card__title a { transition: color 0.3s; }
  .blog-card__title a:hover { color: var(--gold); }

  .blog-card__excerpt {
    font-size: 13px; line-height: 1.8; color: var(--cream); opacity: 0.75;
    margin-bottom: 20px; flex: 1;
  }

  .blog-card__cta {
    font-size: 11px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); display: flex; align-items: center; gap: 10px;
    transition: gap 0.3s;
  }
  .blog-card__cta:hover { gap: 16px; }

  @media (max-width: 1024px) {
    .blog-posts__grid--3 { grid-template-columns: repeat(2, 1fr); }
    .blog-posts__grid--list .blog-card__media-link { flex-basis: 280px; }
  }
  @media (max-width: 768px) {
    .blog-posts__grid--3,
    .blog-posts__grid--2 { grid-template-columns: 1fr; }
    .blog-posts__grid--list .blog-card { flex-direction: column; }
    .blog-posts__grid--list .blog-card__media-link { flex-basis: auto; margin-bottom: 24px; }
  }
</style>

{% schema %}
{
  "name": "Blog Posts",
  "tag": "section",
  "settings": [
    { "type": "text",    "id": "eyebrow",        "label": "Eyebrow",              "default": "From the Journal" },
    { "type": "text",    "id": "heading",         "label": "Heading",              "default": "Latest Stories" },
    { "type": "text",    "id": "view_all_label",  "label": "View All label",       "default": "View All Stories" },
    { "type": "blog",    "id": "blog",            "label": "Blog" },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 2, "max": 6, "step": 1, "default": 3
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "3",    "label": "3 columns" },
        { "value": "2",    "label": "2 columns" },
        { "value": "list", "label": "List" }
      ],
      "default": "3"
    },
    { "type": "checkbox", "id": "show_date",     "label": "Show date",            "default": true },
    { "type": "checkbox", "id": "show_excerpt",  "label": "Show excerpt",         "default": true },
    { "type": "checkbox", "id": "show_category", "label": "Show first tag as category badge", "default": true }
  ],
  "presets": [{ "name": "Blog Posts" }]
}
{% endschema %}
