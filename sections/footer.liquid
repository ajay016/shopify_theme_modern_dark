<footer class="site-footer" role="contentinfo">
  <div class="site-footer__top">

    {%- comment -%}Brand column{%- endcomment -%}
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="site-header__logo">
        {%- if settings.footer_logo != blank -%}
          {{
            settings.footer_logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- elsif settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- else -%}
          {{ settings.logo_text | default: shop.name }}
        {%- endif -%}
      </a>
      {%- if settings.footer_description != blank -%}
        <div class="footer-brand__desc">{{ settings.footer_description }}</div>
      {%- endif -%}
    </div>

    {%- comment -%}Nav columns — with hardcoded fallbacks when menus are not configured{%- endcomment -%}
    {%- liquid
      assign col1_handle = settings.footer_menu_1
      assign col1_title  = settings.footer_menu_1_title | default: 'Shop'
      assign col2_handle = settings.footer_menu_2
      assign col2_title  = settings.footer_menu_2_title | default: 'Brand'
      assign col3_handle = settings.footer_menu_3
      assign col3_title  = settings.footer_menu_3_title | default: 'Help'
    -%}

    <div class="footer-col">
      <h4>{{ col1_title }}</h4>
      <ul>
        {%- if col1_handle != blank and linklists[col1_handle].links.size > 0 -%}
          {%- for link in linklists[col1_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">New Arrivals</a></li>
          <li><a href="#">Clothing</a></li>
          <li><a href="#">Accessories</a></li>
          <li><a href="#">Sale</a></li>
          <li><a href="#">Gift Cards</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{{ col2_title }}</h4>
      <ul>
        {%- if col2_handle != blank and linklists[col2_handle].links.size > 0 -%}
          {%- for link in linklists[col2_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">Our Story</a></li>
          <li><a href="#">Sustainability</a></li>
          <li><a href="#">Craftsmanship</a></li>
          <li><a href="#">Press</a></li>
          <li><a href="#">Careers</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{{ col3_title }}</h4>
      <ul>
        {%- if col3_handle != blank and linklists[col3_handle].links.size > 0 -%}
          {%- for link in linklists[col3_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Shipping & Returns</a></li>
          <li><a href="#">Size Guide</a></li>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Privacy Policy</a></li>
        {%- endif -%}
      </ul>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p class="footer-copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      {{ 'general.continue_shopping' | t | prepend: ' ' }}
    </p>

    <div class="footer-social">
      {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>{%- endif -%}
      {%- if settings.social_pinterest != blank -%}<a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">Pinterest</a>{%- endif -%}
      {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>{%- endif -%}
      {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>{%- endif -%}
      {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X (Twitter)">X</a>{%- endif -%}
    </div>

    {%- if settings.footer_show_payment_icons -%}
      <div class="footer-payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'icon payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure the footer logo, brand description, navigation columns, social links, and payment icons in Theme Settings → Footer."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
