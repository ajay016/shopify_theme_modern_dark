<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {%- render 'css-variables' -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <style>
    body {
      background: var(--black);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 40px;
      text-align: center;
    }
    .password-logo {
      font-family: var(--ff-display);
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 500;
      letter-spacing: 0.35em;
      color: var(--cream);
      margin-bottom: 64px;
    }
    .password-logo span { color: var(--gold); }
    .password-eyebrow {
      font-size: 10px;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }
    .password-eyebrow::before,
    .password-eyebrow::after {
      content: '';
      width: 32px; height: 1px;
      background: var(--gold);
    }
    .password-title {
      font-family: var(--ff-display);
      font-size: clamp(48px, 8vw, 96px);
      font-weight: 300;
      line-height: 1;
      margin-bottom: 24px;
    }
    .password-title em { font-style: italic; color: var(--gold-light); }
    .password-desc {
      font-size: 14px;
      opacity: 0.6;
      max-width: 400px;
      margin: 0 auto 48px;
      line-height: 1.8;
      letter-spacing: 0.03em;
    }
    .password-form { display: flex; gap: 0; max-width: 420px; width: 100%; margin: 0 auto; }
    .password-form input[type="password"] {
      flex: 1;
      background: transparent;
      border: 1px solid var(--border);
      border-right: none;
      color: var(--cream);
      font-family: var(--ff-body);
      font-size: 13px;
      padding: 16px 20px;
      outline: none;
      transition: border-color 0.3s;
    }
    .password-form input[type="password"]::placeholder { color: var(--muted); }
    .password-form input[type="password"]:focus { border-color: var(--gold); }
    .password-form button {
      background: var(--gold);
      border: 1px solid var(--gold);
      color: var(--black);
      font-family: var(--ff-body);
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      padding: 16px 28px;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.3s;
      white-space: nowrap;
    }
    .password-form button:hover { background: var(--gold-light); }
    .password-footer {
      position: fixed;
      bottom: 32px;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .password-footer a { color: var(--gold); transition: opacity 0.3s; }
    .password-footer a:hover { opacity: 0.7; }
  </style>
</head>
<body>
  <div>
    <div class="password-logo">MAISON<span>·</span>NOIR</div>
    <p class="password-eyebrow">Coming Soon</p>
    <h1 class="password-title">
      Something<br><em>Beautiful</em><br>Is Coming
    </h1>
    <p class="password-desc">
      We're crafting an experience worthy of your time.
      Enter the password for early access.
    </p>

    {{ content_for_layout }}
  </div>

  <p class="password-footer">
    Powered by <a href="https://www.shopify.com" target="_blank" rel="noopener">Shopify</a>
    &nbsp;·&nbsp;
    <a href="/admin" target="_blank">Admin login</a>
  </p>
</body>
</html>
