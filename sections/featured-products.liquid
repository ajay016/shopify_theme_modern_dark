{% liquid
  assign heading      = section.settings.heading
  assign subheading   = section.settings.subheading
  assign collection   = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
  assign columns      = section.settings.columns
  assign show_view_all = section.settings.show_view_all
%}

<section class="section featured-products" id="section-{{ section.id }}">
  <div class="container">
    {%- if heading != blank or subheading != blank -%}
      <div class="section-head">
        <div>
          {%- if subheading != blank -%}
            <p class="eyebrow">{{ subheading }}</p>
          {%- endif -%}
          {%- if heading != blank -%}
            <h2 class="section-head__title">{{ heading }}</h2>
          {%- endif -%}
        </div>
        {%- if show_view_all and collection != blank -%}
          <a href="{{ collection.url }}" class="section-link">{{ 'collections.general.view_all' | t }}</a>
        {%- elsif show_view_all -%}
          <a href="/collections/all" class="section-link">View All New In</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="product-grid product-grid--{{ columns }}">
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%}Placeholder cards — visible even without products so theme preview looks complete{%- endcomment -%}
      {%- liquid
        assign placeholder_products = 'Oversized Wool Coat — Ivory,Structured Tote in Calfskin,Column Gown in Silk Crêpe,Tailored Blazer — Charcoal' | split: ','
        assign placeholder_prices   = '$1,240,$890,$2,150,$960' | split: ','
        assign placeholder_orig     = '|$1,100||' | split: '|'
        assign placeholder_badges   = 'New In,,Limited,' | split: ','
      -%}
      <div class="product-grid product-grid--{{ columns }} fp-placeholder-grid">
        {%- for i in (1..products_to_show) -%}
          {%- liquid
            assign pi = i | minus: 1
            assign p_name   = placeholder_products[pi] | default: 'Sample Piece'
            assign p_price  = placeholder_prices[pi]   | default: '$500'
            assign p_orig   = placeholder_orig[pi]
            assign p_badge  = placeholder_badges[pi]
            assign bg_mod   = i | modulo: 3 | plus: 1
          -%}
          <div class="product-card fp-card product-card--{{ settings.product_card_style }}">
            <div class="fp-card__media product-card__media product-card__media--{{ settings.product_card_image_ratio }} fp-bg-{{ bg_mod }}">
              {%- if i == 1 -%}
                <svg width="160" height="260" viewBox="0 0 160 260" fill="none" aria-hidden="true">
                  <path d="M55 30 Q55 15 80 12 Q105 15 105 30 L110 65 L90 70 L90 240 L70 240 L70 70 L50 65 Z" stroke="rgba(200,169,110,0.35)" stroke-width="1.2" fill="rgba(200,169,110,0.05)"/>
                  <path d="M50 65 L28 78 L36 200 L70 195" stroke="rgba(200,169,110,0.25)" stroke-width="1" fill="none"/>
                  <path d="M110 65 L132 78 L124 200 L90 195" stroke="rgba(200,169,110,0.25)" stroke-width="1" fill="none"/>
                  <line x1="70" y1="120" x2="90" y2="120" stroke="rgba(200,169,110,0.2)" stroke-width="0.8"/>
                  <line x1="68" y1="150" x2="92" y2="150" stroke="rgba(200,169,110,0.15)" stroke-width="0.8"/>
                </svg>
              {%- elsif i == 2 -%}
                <svg width="140" height="200" viewBox="0 0 140 200" fill="none" aria-hidden="true">
                  <path d="M20 60 Q20 20 70 18 Q120 20 120 60 L118 80 L105 85 L105 195 L35 195 L35 85 L22 80 Z" stroke="rgba(200,169,110,0.35)" stroke-width="1.2" fill="rgba(200,169,110,0.05)"/>
                  <path d="M40 105 L100 105" stroke="rgba(200,169,110,0.2)" stroke-width="0.8"/>
                  <circle cx="70" cy="70" r="22" stroke="rgba(200,169,110,0.25)" stroke-width="1" fill="none"/>
                  <line x1="70" y1="85" x2="70" y2="195" stroke="rgba(200,169,110,0.1)" stroke-width="0.5"/>
                </svg>
              {%- elsif i == 3 -%}
                <svg width="100" height="260" viewBox="0 0 100 260" fill="none" aria-hidden="true">
                  <path d="M10 30 L50 20 L90 30 L90 260 L50 255 L10 260 Z" stroke="rgba(200,169,110,0.3)" stroke-width="1.2" fill="rgba(200,169,110,0.05)"/>
                  <line x1="10" y1="90" x2="90" y2="90" stroke="rgba(200,169,110,0.2)" stroke-width="0.8"/>
                  <line x1="10" y1="160" x2="90" y2="160" stroke="rgba(200,169,110,0.15)" stroke-width="0.8"/>
                  <ellipse cx="50" cy="55" rx="12" ry="16" stroke="rgba(200,169,110,0.25)" stroke-width="1" fill="none"/>
                </svg>
              {%- else -%}
                <svg width="130" height="220" viewBox="0 0 130 220" fill="none" aria-hidden="true">
                  <path d="M30 20 Q30 8 65 8 Q100 8 100 20 L104 55 L85 60 L85 210 L45 210 L45 60 L26 55 Z" stroke="rgba(200,169,110,0.35)" stroke-width="1.2" fill="rgba(200,169,110,0.05)"/>
                  <path d="M26 55 L8 68 L16 190 L45 185" stroke="rgba(200,169,110,0.2)" stroke-width="1" fill="none"/>
                  <path d="M104 55 L122 68 L114 190 L85 185" stroke="rgba(200,169,110,0.2)" stroke-width="1" fill="none"/>
                  <line x1="45" y1="120" x2="85" y2="120" stroke="rgba(200,169,110,0.15)" stroke-width="0.8"/>
                </svg>
              {%- endif -%}

              {%- if p_badge != blank -%}
                <span class="fp-badge
                  {%- if p_badge == 'Limited' %} fp-badge--outline{%- endif -%}
                ">{{ p_badge }}</span>
              {%- endif -%}

              <div class="fp-card__actions">
                <button class="fp-action-btn" aria-label="Wishlist">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
                <button class="fp-action-btn" aria-label="Quick view">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>

              <div class="fp-quick-add">+ Add to Cart</div>
            </div>

            <div class="fp-card__info product-card__info">
              <p class="fp-card__brand">{{ shop.name }}</p>
              <h3 class="fp-card__name product-card__title">{{ p_name }}</h3>
              <div class="fp-card__price">
                <span class="price-current">{{ p_price }}</span>
                {%- if p_orig != blank -%}
                  <span class="price-original">{{ p_orig }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .featured-products { padding: var(--section-spacing) 0; }
  .featured-products__cta { text-align: center; margin-top: 48px; }
  .product-grid { display: grid; gap: 2px; }
  .product-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .product-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .product-grid--4 { grid-template-columns: repeat(4, 1fr); }
  .product-grid--5 { grid-template-columns: repeat(5, 1fr); }

  /* Placeholder product cards */
  .fp-card { position: relative; cursor: pointer; }
  .fp-card__media {
    /* aspect-ratio is driven by the global Product Card "Image Aspect Ratio"
       setting via the .product-card__media--{ratio} class (see theme.css) */
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .fp-card:hover .fp-card__media { transform: scale(1.02); }
  .fp-bg-1 { background: linear-gradient(145deg, #1c1814, #2a241c); }
  .fp-bg-2 { background: linear-gradient(145deg, #141c1c, #1c2828); }
  .fp-bg-3 { background: linear-gradient(145deg, #1c1420, #28182c); }

  .fp-badge {
    position: absolute; top: 20px; left: 20px;
    background: var(--gold); color: var(--black);
    font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
    padding: 6px 12px; font-weight: 500; z-index: 2;
  }
  .fp-badge--outline {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
  }

  .fp-card__actions {
    position: absolute; right: 20px; top: 20px;
    display: flex; flex-direction: column; gap: 8px;
    opacity: 0; transform: translateX(10px);
    transition: opacity 0.3s, transform 0.3s;
    z-index: 2;
  }
  .fp-card:hover .fp-card__actions { opacity: 1; transform: translateX(0); }

  .fp-action-btn {
    width: 40px; height: 40px;
    background: rgba(10,10,10,0.8);
    border: 1px solid rgba(200,169,110,0.3);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.2s, border-color 0.2s;
    backdrop-filter: blur(4px);
    color: var(--cream);
  }
  .fp-action-btn:hover { background: var(--gold); border-color: var(--gold); color: var(--black); }

  .fp-quick-add {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: var(--black); border-top: 1px solid var(--border);
    padding: 14px 20px; font-size: 11px; letter-spacing: 0.3em;
    text-transform: uppercase; text-align: center; color: var(--gold);
    opacity: 0; transform: translateY(100%);
    transition: opacity 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .fp-card:hover .fp-quick-add { opacity: 1; transform: translateY(0); }
  .fp-quick-add:hover { background: var(--gold); color: var(--black); }

  .fp-card__info { padding: 0 4px; }
  .fp-card__brand {
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 6px;
  }
  .fp-card__name {
    font-family: var(--ff-display); font-size: 20px; font-weight: 400;
    line-height: 1.3; margin-bottom: 8px; color: var(--cream);
  }
  .fp-card__price { display: flex; align-items: center; gap: 12px; }
  .price-current { font-size: 15px; font-weight: 400; color: var(--cream); letter-spacing: 0.05em; }
  .price-original { font-size: 13px; color: var(--cream); opacity: 0.6; text-decoration: line-through; }

  /* Section header with view-all link */
  .featured-products .section-head { display: flex; align-items: flex-end; justify-content: space-between; }

  @media (max-width: 1200px) {
    .product-grid--5 { grid-template-columns: repeat(4, 1fr); }
    .product-grid--4 { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 900px) {
    .product-grid--3, .product-grid--4, .product-grid--5 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .product-grid--2, .product-grid--3, .product-grid--4, .product-grid--5 { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "settings": [
    { "type": "text",       "id": "heading",         "label": "Heading",            "default": "New Arrivals" },
    { "type": "text",       "id": "subheading",      "label": "Eyebrow Text",       "default": "Collection" },
    { "type": "collection", "id": "collection",      "label": "Collection" },
    { "type": "range",      "id": "products_to_show","label": "Products to Show",   "min": 2, "max": 12, "step": 1, "default": 4 },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View All' button", "default": true }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
