<section class="section brand-logos" id="section-{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <p class="brand-logos__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    <div class="brand-logos__track-wrap">
      <div class="brand-logos__track {% if section.settings.marquee %}brand-logos__track--marquee{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.settings.logo -%}
            <a
              href="{{ block.settings.url | default: '#' }}"
              class="brand-logos__item"
              aria-label="{{ block.settings.name }}"
              {{ block.shopify_attributes }}
            >
              {{
                block.settings.logo
                | image_url: width: 300
                | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: block.settings.name
              }}
            </a>
          {%- elsif block.settings.name != blank -%}
            <a href="{{ block.settings.url | default: '#' }}" class="brand-logos__item brand-logos__item--text" {{ block.shopify_attributes }}>
              {{ block.settings.name }}
            </a>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.marquee -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.logo -%}
              <a href="{{ block.settings.url | default: '#' }}" class="brand-logos__item" aria-hidden="true">
                {{ block.settings.logo | image_url: width: 300 | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: '' }}
              </a>
            {%- elsif block.settings.name != blank -%}
              <a href="{{ block.settings.url | default: '#' }}" class="brand-logos__item brand-logos__item--text" aria-hidden="true">{{ block.settings.name }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .brand-logos { padding: var(--section-spacing) 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .brand-logos__heading { text-align: center; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--muted); margin-bottom: 40px; }
  .brand-logos__track-wrap { overflow: hidden; }
  .brand-logos__track { display: flex; align-items: center; justify-content: center; gap: 56px; flex-wrap: wrap; }
  .brand-logos__track--marquee { flex-wrap: nowrap; justify-content: flex-start; animation: marquee 24s linear infinite; }
  .brand-logos__track--marquee:hover { animation-play-state: paused; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .brand-logos__item { display: flex; align-items: center; flex-shrink: 0; }
  .brand-logos__img { height: 32px; width: auto; object-fit: contain; opacity: 0.45; filter: brightness(0) invert(1); transition: opacity 0.3s; }
  .brand-logos__item:hover .brand-logos__img { opacity: 0.9; }
  .brand-logos__item--text { font-family: var(--ff-display); font-size: 18px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); transition: color 0.3s; white-space: nowrap; }
  .brand-logos__item--text:hover { color: var(--cream); }
</style>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text",     "id": "heading", "label": "Section Label",     "default": "As Seen In" },
    { "type": "checkbox", "id": "marquee", "label": "Scrolling Marquee", "default": false }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo Image" },
        { "type": "text",         "id": "name", "label": "Brand Name (text fallback)" },
        { "type": "url",          "id": "url",  "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
