<section class="section product-recommendations" id="section-{{ section.id }}" data-product-id="{{ product.id }}" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">
  {%- if recommendations.performed? and recommendations.products_count > 0 -%}
    <div class="container">
      <div class="section-head">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-head__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <div class="product-grid product-grid--{{ section.settings.columns }}">
        {%- for product in recommendations.products -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  .product-recommendations { padding: var(--section-spacing) 0; border-top: 1px solid var(--border); }
</style>

<script>
  (function() {
    const section = document.getElementById('section-{{ section.id }}');
    if (!section || section.querySelector('.product-card')) return;
    const url = section.dataset.url;
    if (!url) return;
    fetch(url)
      .then(r => r.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const inner = doc.querySelector('.product-recommendations');
        if (inner) section.innerHTML = inner.innerHTML;
      })
      .catch(() => {});
  })();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "settings": [
    { "type": "text",  "id": "heading",          "label": "Heading",           "default": "You May Also Like" },
    { "type": "range", "id": "products_to_show", "label": "Products to Show",  "min": 2, "max": 8, "step": 1, "default": 4 },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "presets": [{ "name": "Product Recommendations" }]
}
{% endschema %}
