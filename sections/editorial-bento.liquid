{%- liquid
  assign s = section.settings
-%}

<section
  class="ebento"
  id="section-{{ section.id }}"
  style="background:{% if s.section_bg == 'charcoal' %}var(--charcoal){% else %}var(--black){% endif %}; padding-block:{{ s.vertical_spacing }}px;"
>
  {%- if s.heading != blank or s.eyebrow != blank -%}
    <div class="ebento__header container">
      {%- if s.eyebrow != blank -%}<p class="eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="section-head__title">{{ s.heading }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="ebento__grid ebento__grid--{{ s.layout }}" id="ebento-grid-{{ section.id }}">

    {%- comment -%}——— Featured block (left / top — always first) ———{%- endcomment -%}
    <div class="ebento__featured">
      {%- if s.featured_image != blank -%}
        {{
          s.featured_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(max-width:900px) 100vw, 58vw',
            class: 'ebento__featured-img',
            alt: s.featured_heading | escape
        }}
      {%- else -%}
        <div class="ebento__ph ebento__ph--feat"></div>
      {%- endif -%}
      <div class="ebento__featured-overlay ebento__featured-overlay--{{ s.overlay_pos }}">
        {%- if s.featured_eyebrow != blank -%}
          <p class="ebento__feat-eyebrow">{{ s.featured_eyebrow }}</p>
        {%- endif -%}
        {%- if s.featured_heading != blank -%}
          <h2 class="ebento__feat-title">{{ s.featured_heading }}</h2>
        {%- endif -%}
        {%- if s.featured_text != blank -%}
          <p class="ebento__feat-text">{{ s.featured_text }}</p>
        {%- endif -%}
        {%- if s.featured_cta != blank -%}
          <a href="{{ s.featured_cta_url | default: '#' }}" class="ebento__feat-cta">
            {{ s.featured_cta }}
            <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true"><path d="M1 5h16M13 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}——— Configurable blocks (right column or remainder) ———{%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'stat' -%}
          <div
            class="ebento__block ebento__block--stat ebento__block--{{ block.settings.bg }}"
            {{ block.shopify_attributes }}
          >
            <div class="ebento__stat-inner">
              {%- if block.settings.eyebrow != blank -%}
                <p class="ebento__block-eye">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              <span class="ebento__stat-val">{{ block.settings.value }}</span>
              <span class="ebento__stat-lbl">{{ block.settings.label }}</span>
              {%- if block.settings.description != blank -%}
                <p class="ebento__stat-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>

        {%- when 'collection' -%}
          {%- liquid
            assign bc = collections[block.settings.collection]
            assign bc_url = block.settings.custom_url
            if bc != blank and bc_url == blank
              assign bc_url = bc.url
            endif
            assign bc_label = block.settings.label
            if bc_label == blank and bc != blank
              assign bc_label = bc.title
            endif
            assign bc_count = block.settings.count
            if bc_count == blank and bc != blank and bc.products_count > 0
              assign bc_count = bc.products_count | append: ' pieces'
            endif
          -%}
          <a
            href="{{ bc_url | default: '#' }}"
            class="ebento__block ebento__block--coll"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 700
                | image_tag: loading: 'lazy', sizes: '28vw', class: 'ebento__coll-img', alt: bc_label | escape
              }}
            {%- elsif bc != blank and bc.featured_image != blank -%}
              {{
                bc.featured_image
                | image_url: width: 700
                | image_tag: loading: 'lazy', sizes: '28vw', class: 'ebento__coll-img', alt: bc_label | escape
              }}
            {%- else -%}
              <div class="ebento__ph ebento__ph--coll ebento__ph--{{ forloop.index | modulo: 3 | plus: 1 }}"></div>
            {%- endif -%}
            <div class="ebento__coll-label">
              {%- if bc_count != blank -%}
                <span class="ebento__coll-count">{{ bc_count }}</span>
              {%- endif -%}
              <span class="ebento__coll-name">{{ bc_label | default: 'Collection' }}</span>
              <span class="ebento__coll-arrow" aria-hidden="true">→</span>
            </div>
          </a>

        {%- when 'text_cta' -%}
          <div
            class="ebento__block ebento__block--text ebento__block--{{ block.settings.bg }}"
            {{ block.shopify_attributes }}
          >
            <div class="ebento__text-inner">
              {%- if block.settings.eyebrow != blank -%}
                <p class="ebento__block-eye">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="ebento__text-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="ebento__text-body rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.btn_label != blank -%}
                <a href="{{ block.settings.btn_url | default: '#' }}" class="{{ block.settings.btn_style | default: 'btn btn-primary' }} btn-sm">{{ block.settings.btn_label }}</a>
              {%- endif -%}
            </div>
          </div>

        {%- when 'image' -%}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="ebento__block ebento__block--img"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 700
                | image_tag: loading: 'lazy', sizes: '28vw', class: 'ebento__img-img', alt: block.settings.caption | escape
              }}
            {%- else -%}
              <div class="ebento__ph ebento__ph--img ebento__ph--{{ forloop.index | modulo: 3 | plus: 1 }}"></div>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <div class="ebento__img-label">
                <span>{{ block.settings.caption }}</span>
                <span aria-hidden="true">→</span>
              </div>
            {%- endif -%}
          </a>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  #section-{{ section.id }}.ebento { overflow: hidden; }
  #section-{{ section.id }} .ebento__header { margin-bottom: 48px; }

  /* ══ Grid layouts ══════════════════════════════════════════════════ */
  /* Layout: "left-featured" — featured takes left 58%, blocks stack right */
  #section-{{ section.id }} .ebento__grid--left-featured {
    display: grid;
    grid-template-columns: 58% 1fr;
    grid-template-rows: repeat({{ section.blocks.size | at_least: 3 }}, minmax(220px, 1fr));
    gap: 2px;
    max-width: var(--container-width, 1440px);
    margin-inline: auto;
  }
  #section-{{ section.id }} .ebento__grid--left-featured .ebento__featured {
    grid-column: 1;
    grid-row: 1 / -1;
  }
  #section-{{ section.id }} .ebento__grid--left-featured .ebento__block {
    grid-column: 2;
  }

  /* Layout: "mosaic" — 12-column bento, featured spans 8 cols / 2 rows */
  #section-{{ section.id }} .ebento__grid--mosaic {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 280px;
    gap: 2px;
    max-width: var(--container-width, 1440px);
    margin-inline: auto;
  }
  #section-{{ section.id }} .ebento__grid--mosaic .ebento__featured { grid-column: span 7; grid-row: span 2; }
  #section-{{ section.id }} .ebento__grid--mosaic .ebento__block:nth-child(2) { grid-column: span 5; }
  #section-{{ section.id }} .ebento__grid--mosaic .ebento__block:nth-child(3) { grid-column: span 5; }
  #section-{{ section.id }} .ebento__grid--mosaic .ebento__block:nth-child(4) { grid-column: span 7; }
  #section-{{ section.id }} .ebento__grid--mosaic .ebento__block:nth-child(n+5) { grid-column: span 4; }

  /* ── Featured block ── */
  #section-{{ section.id }} .ebento__featured { position: relative; overflow: hidden; }
  #section-{{ section.id }} .ebento__featured-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.9s var(--ease-out); }
  #section-{{ section.id }} .ebento__featured:hover .ebento__featured-img { transform: scale(1.04); }

  #section-{{ section.id }} .ebento__ph--feat {
    width: 100%; height: 100%;
    background: radial-gradient(110% 110% at 60% 20%, #2a2014 0%, #0a0a0a 100%);
  }

  /* Featured overlay */
  #section-{{ section.id }} .ebento__featured-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 52%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: clamp(24px, 3vw, 48px);
    transition: background 0.4s;
  }
  #section-{{ section.id }} .ebento__featured:hover .ebento__featured-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.94) 0%, rgba(0,0,0,0.15) 52%);
  }
  #section-{{ section.id }} .ebento__featured-overlay--top-left { justify-content: flex-start; }
  #section-{{ section.id }} .ebento__featured-overlay--center { justify-content: center; align-items: center; text-align: center; }

  #section-{{ section.id }} .ebento__feat-eyebrow { font-size: 10px; letter-spacing: 0.32em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  #section-{{ section.id }} .ebento__feat-title { font-family: var(--ff-display); font-size: clamp(26px, 3vw, 44px); font-weight: 300; color: var(--cream); margin-bottom: 12px; line-height: 1.15; }
  #section-{{ section.id }} .ebento__feat-text { font-size: 13px; line-height: 1.7; color: var(--cream); opacity: 0.72; max-width: 340px; margin-bottom: 20px; }
  #section-{{ section.id }} .ebento__feat-cta {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 11px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); transition: gap var(--transition);
  }
  #section-{{ section.id }} .ebento__feat-cta:hover { gap: 18px; }

  /* ── Shared block base ── */
  #section-{{ section.id }} .ebento__block { position: relative; overflow: hidden; display: flex; }

  /* Stat block */
  #section-{{ section.id }} .ebento__block--stat { align-items: center; justify-content: center; }
  #section-{{ section.id }} .ebento__block--charcoal { background: var(--charcoal); }
  #section-{{ section.id }} .ebento__block--black    { background: var(--black); }
  #section-{{ section.id }} .ebento__block--gold     { background: var(--gold); }
  #section-{{ section.id }} .ebento__block--ivory    { background: var(--ivory); }

  #section-{{ section.id }} .ebento__stat-inner { text-align: center; padding: 32px 24px; }
  #section-{{ section.id }} .ebento__block-eye { font-size: 10px; letter-spacing: 0.32em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
  #section-{{ section.id }} .ebento__block--gold  .ebento__block-eye { color: var(--black); opacity: 0.65; }
  #section-{{ section.id }} .ebento__block--ivory .ebento__block-eye { color: var(--black); opacity: 0.55; }
  #section-{{ section.id }} .ebento__stat-val { display: block; font-family: var(--ff-display); font-size: clamp(40px, 5vw, 72px); font-weight: 300; color: var(--gold); line-height: 1; margin-bottom: 8px; }
  #section-{{ section.id }} .ebento__block--gold  .ebento__stat-val { color: var(--black); }
  #section-{{ section.id }} .ebento__block--ivory .ebento__stat-val { color: var(--black); }
  #section-{{ section.id }} .ebento__stat-lbl { display: block; font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--cream); opacity: 0.55; margin-bottom: 14px; }
  #section-{{ section.id }} .ebento__block--gold  .ebento__stat-lbl { color: var(--black); opacity: 0.6; }
  #section-{{ section.id }} .ebento__block--ivory .ebento__stat-lbl { color: var(--black); opacity: 0.6; }
  #section-{{ section.id }} .ebento__stat-desc { font-size: 12px; line-height: 1.7; color: var(--cream); opacity: 0.55; max-width: 200px; margin-inline: auto; }

  /* Collection block */
  #section-{{ section.id }} .ebento__block--coll { display: block; }
  #section-{{ section.id }} .ebento__coll-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.7s var(--ease-out); }
  #section-{{ section.id }} .ebento__block--coll:hover .ebento__coll-img { transform: scale(1.06); }
  #section-{{ section.id }} .ebento__coll-label {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 50%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 20px 18px;
    opacity: 0; transition: opacity 0.38s;
  }
  #section-{{ section.id }} .ebento__block--coll:hover .ebento__coll-label { opacity: 1; }
  #section-{{ section.id }} .ebento__coll-count { font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 4px; }
  #section-{{ section.id }} .ebento__coll-name { font-family: var(--ff-display); font-size: clamp(16px, 1.8vw, 22px); color: var(--cream); margin-bottom: 10px; }
  #section-{{ section.id }} .ebento__coll-arrow { color: var(--gold); font-size: 16px; display: block; transform: translateX(-6px); transition: transform 0.28s; }
  #section-{{ section.id }} .ebento__block--coll:hover .ebento__coll-arrow { transform: translateX(0); }

  /* Text CTA block */
  #section-{{ section.id }} .ebento__block--text { align-items: center; justify-content: center; }
  #section-{{ section.id }} .ebento__text-inner { padding: clamp(24px, 3vw, 44px); }
  #section-{{ section.id }} .ebento__text-title { font-family: var(--ff-display); font-size: clamp(22px, 2.4vw, 34px); font-weight: 300; color: var(--cream); line-height: 1.2; margin: 12px 0; }
  #section-{{ section.id }} .ebento__block--gold  .ebento__text-title { color: var(--black); }
  #section-{{ section.id }} .ebento__block--ivory .ebento__text-title { color: var(--black); }
  #section-{{ section.id }} .ebento__text-body { font-size: 13px; line-height: 1.75; color: var(--cream); opacity: 0.68; margin-bottom: 22px; }
  #section-{{ section.id }} .ebento__block--gold  .ebento__text-body { color: var(--black); }
  #section-{{ section.id }} .ebento__block--ivory .ebento__text-body { color: var(--black); }

  /* Image block */
  #section-{{ section.id }} .ebento__block--img { display: block; }
  #section-{{ section.id }} .ebento__img-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.7s var(--ease-out); }
  #section-{{ section.id }} .ebento__block--img:hover .ebento__img-img { transform: scale(1.06); }
  #section-{{ section.id }} .ebento__img-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 18px;
    background: rgba(0,0,0,0.72); backdrop-filter: blur(4px);
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cream);
    opacity: 0; transition: opacity 0.38s; transform: translateY(100%); transition: opacity 0.38s, transform 0.38s;
  }
  #section-{{ section.id }} .ebento__block--img:hover .ebento__img-label { opacity: 1; transform: translateY(0); }

  /* Placeholder fills */
  #section-{{ section.id }} .ebento__ph--coll,
  #section-{{ section.id }} .ebento__ph--img { width: 100%; height: 100%; }
  #section-{{ section.id }} .ebento__ph--1 { background: linear-gradient(145deg, #1c1814, #282214); }
  #section-{{ section.id }} .ebento__ph--2 { background: linear-gradient(145deg, #141822, #1a2232); }
  #section-{{ section.id }} .ebento__ph--3 { background: linear-gradient(145deg, #1a1420, #261830); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    #section-{{ section.id }} .ebento__grid--left-featured {
      grid-template-columns: 1fr;
      grid-template-rows: 65vw auto;
    }
    #section-{{ section.id }} .ebento__grid--left-featured .ebento__featured { grid-column: 1; grid-row: 1; }
    #section-{{ section.id }} .ebento__grid--left-featured .ebento__block { grid-column: 1; min-height: 200px; }
    #section-{{ section.id }} .ebento__grid--mosaic { grid-template-columns: repeat(6, 1fr); }
    #section-{{ section.id }} .ebento__grid--mosaic .ebento__featured { grid-column: span 6; grid-row: span 1; height: 65vw; }
    #section-{{ section.id }} .ebento__grid--mosaic .ebento__block { grid-column: span 3 !important; }
  }
  @media (max-width: 640px) {
    #section-{{ section.id }} .ebento__grid--mosaic .ebento__block { grid-column: span 6 !important; min-height: 220px; }
  }
</style>

{% schema %}
{
  "name": "Editorial Bento",
  "tag": "section",
  "class": "editorial-bento-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "left-featured", "label": "Featured left — blocks stack right" },
        { "value": "mosaic",        "label": "Mosaic — asymmetric bento grid" }
      ],
      "default": "left-featured"
    },
    {
      "type": "select", "id": "section_bg", "label": "Section background",
      "options": [
        { "value": "black",    "label": "Black" },
        { "value": "charcoal", "label": "Charcoal" }
      ],
      "default": "black"
    },
    { "type": "range", "id": "vertical_spacing", "label": "Vertical spacing", "min": 0, "max": 120, "step": 8, "unit": "px", "default": 0 },

    { "type": "header", "content": "Section heading (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },

    { "type": "header", "content": "Featured block" },
    { "type": "image_picker", "id": "featured_image",   "label": "Featured image" },
    { "type": "text",         "id": "featured_eyebrow", "label": "Eyebrow",          "default": "The Season's Edit" },
    { "type": "text",         "id": "featured_heading", "label": "Heading",          "default": "Wear the Collection" },
    { "type": "textarea",     "id": "featured_text",    "label": "Description",      "default": "Eight months in our Milan atelier. Every seam deliberate. Every fabric considered." },
    { "type": "text",         "id": "featured_cta",     "label": "CTA label",        "default": "Discover Now" },
    { "type": "url",          "id": "featured_cta_url", "label": "CTA link" },
    {
      "type": "select", "id": "overlay_pos", "label": "Text position",
      "options": [
        { "value": "bottom-left",  "label": "Bottom left" },
        { "value": "top-left",     "label": "Top left" },
        { "value": "center",       "label": "Centered" }
      ],
      "default": "bottom-left"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "eyebrow",     "label": "Eyebrow",     "default": "Since" },
        { "type": "text", "id": "value",       "label": "Value",       "default": "2009" },
        { "type": "text", "id": "label",       "label": "Label",       "default": "Founded" },
        { "type": "text", "id": "description", "label": "Description", "default": "Atelier craftsmanship for the modern wardrobe." },
        {
          "type": "select", "id": "bg", "label": "Background",
          "options": [
            { "value": "charcoal", "label": "Charcoal" },
            { "value": "gold",     "label": "Gold" },
            { "value": "black",    "label": "Black" },
            { "value": "ivory",    "label": "Ivory / Light" }
          ],
          "default": "charcoal"
        }
      ]
    },
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection",   "id": "collection",  "label": "Collection" },
        { "type": "image_picker", "id": "image",       "label": "Override image" },
        { "type": "text",         "id": "label",       "label": "Name",         "default": "Women's RTW" },
        { "type": "text",         "id": "count",       "label": "Count label",  "default": "142 pieces" },
        { "type": "url",          "id": "custom_url",  "label": "Custom URL (overrides collection)" }
      ]
    },
    {
      "type": "text_cta",
      "name": "Text + CTA",
      "settings": [
        { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "About Us" },
        { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Craft Without Compromise" },
        { "type": "richtext", "id": "text",       "label": "Body text",  "default": "<p>Each piece begins as a question of proportion.</p>" },
        { "type": "text",     "id": "btn_label",  "label": "Button label", "default": "Our Story" },
        { "type": "url",      "id": "btn_url",    "label": "Button link" },
        {
          "type": "select", "id": "btn_style", "label": "Button style",
          "options": [
            { "value": "btn btn-primary", "label": "Primary (gold)" },
            { "value": "btn btn-ghost",   "label": "Ghost (outlined)" },
            { "value": "btn btn-dark",    "label": "Dark" }
          ],
          "default": "btn btn-primary"
        },
        {
          "type": "select", "id": "bg", "label": "Background",
          "options": [
            { "value": "charcoal", "label": "Charcoal" },
            { "value": "black",    "label": "Black" },
            { "value": "gold",     "label": "Gold" },
            { "value": "ivory",    "label": "Ivory / Light" }
          ],
          "default": "charcoal"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image",   "label": "Image" },
        { "type": "text",         "id": "caption", "label": "Caption / hover label" },
        { "type": "url",          "id": "url",     "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Bento",
      "blocks": [
