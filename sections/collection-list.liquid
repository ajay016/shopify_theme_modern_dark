<section class="section collection-list" id="section-{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-head">
        {%- if section.settings.subheading != blank -%}
          <p class="eyebrow">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="section-head__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="collection-list__grid collection-list__grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        <a
          href="{{ col.url | default: block.settings.custom_url | default: '#' }}"
          class="collection-list__item"
          {{ block.shopify_attributes }}
        >
          <div class="collection-list__media">
            {%- if block.settings.image -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag: class: 'collection-list__img', loading: 'lazy', alt: block.settings.label | default: col.title
              }}
            {%- elsif col.featured_image -%}
              {{
                col.featured_image
                | image_url: width: 800
                | image_tag: class: 'collection-list__img', loading: 'lazy', alt: col.title
              }}
            {%- else -%}
              <div class="collection-list__placeholder">
                {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-list__img' }}
              </div>
            {%- endif -%}
            <div class="collection-list__overlay">
              <span class="collection-list__label">{{ block.settings.label | default: col.title }}</span>
              {%- if block.settings.sublabel != blank -%}
                <span class="collection-list__sublabel">{{ block.settings.sublabel }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collection-list { padding: var(--section-spacing) 0; }
  .collection-list__grid { display: grid; gap: 16px; }
  .collection-list__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .collection-list__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .collection-list__grid--4 { grid-template-columns: repeat(4, 1fr); }
  .collection-list__item { display: block; overflow: hidden; border-radius: 2px; }
  .collection-list__media { position: relative; aspect-ratio: 3/4; overflow: hidden; }
  .collection-list__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease-out); }
  .collection-list__item:hover .collection-list__img { transform: scale(1.05); }
  .collection-list__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.7) 0%, transparent 50%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 28px 24px;
  }
  .collection-list__label { font-family: var(--ff-display); font-size: clamp(18px, 2vw, 26px); font-weight: 300; color: var(--cream); letter-spacing: 0.05em; }
  .collection-list__sublabel { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-top: 6px; }
  @media (max-width: 900px) {
    .collection-list__grid--4 { grid-template-columns: repeat(2, 1fr); }
    .collection-list__grid--3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .collection-list__grid--2, .collection-list__grid--3, .collection-list__grid--4 { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading",     "default": "Shop by Category" },
    { "type": "text", "id": "subheading", "label": "Eyebrow",     "default": "Explore" },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        { "type": "collection",   "id": "collection",  "label": "Collection" },
        { "type": "image_picker", "id": "image",       "label": "Override Image" },
        { "type": "text",         "id": "label",       "label": "Label" },
        { "type": "text",         "id": "sublabel",    "label": "Sub-label (e.g. count)" },
        { "type": "url",          "id": "custom_url",  "label": "Custom URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}
