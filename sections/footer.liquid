<footer class="site-footer" role="contentinfo">
  <div class="site-footer__top">

    {%- comment -%}Brand column{%- endcomment -%}
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="site-header__logo">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- elsif settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- else -%}
          {{ settings.logo_text | default: shop.name }}
        {%- endif -%}
      </a>
      {%- if section.settings.description != blank -%}
        <div class="footer-brand__desc">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    {%- comment -%}Nav columns — with hardcoded fallbacks when menus are not configured{%- endcomment -%}
    {%- liquid
      assign col1_handle = section.settings.menu_1
      assign col1_title  = section.settings.menu_1_title | default: 'Shop'
      assign col2_handle = section.settings.menu_2
      assign col2_title  = section.settings.menu_2_title | default: 'Brand'
      assign col3_handle = section.settings.menu_3
      assign col3_title  = section.settings.menu_3_title | default: 'Help'
    -%}

    <div class="footer-col">
      <h4>{{ col1_title }}</h4>
      <ul>
        {%- if col1_handle != blank and linklists[col1_handle].links.size > 0 -%}
          {%- for link in linklists[col1_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">New Arrivals</a></li>
          <li><a href="#">Clothing</a></li>
          <li><a href="#">Accessories</a></li>
          <li><a href="#">Sale</a></li>
          <li><a href="#">Gift Cards</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{{ col2_title }}</h4>
      <ul>
        {%- if col2_handle != blank and linklists[col2_handle].links.size > 0 -%}
          {%- for link in linklists[col2_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">Our Story</a></li>
          <li><a href="#">Sustainability</a></li>
          <li><a href="#">Craftsmanship</a></li>
          <li><a href="#">Press</a></li>
          <li><a href="#">Careers</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{{ col3_title }}</h4>
      <ul>
        {%- if col3_handle != blank and linklists[col3_handle].links.size > 0 -%}
          {%- for link in linklists[col3_handle].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Shipping & Returns</a></li>
          <li><a href="#">Size Guide</a></li>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Privacy Policy</a></li>
        {%- endif -%}
      </ul>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p class="footer-copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      {{ 'general.continue_shopping' | t | prepend: ' ' }}
    </p>

    <div class="footer-social">
      <a href="{{ section.settings.instagram | default: '#' }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
      <a href="{{ section.settings.pinterest | default: '#' }}" target="_blank" rel="noopener" aria-label="Pinterest">Pinterest</a>
      <a href="{{ section.settings.tiktok | default: '#' }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>
      <a href="{{ section.settings.facebook | default: '#' }}" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
    </div>

    {%- if section.settings.show_payment_icons -%}
      <div class="footer-payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'icon payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional, overrides global logo)"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Brand description",
      "default": "<p>Luxury fashion with a considered approach to design, craft, and the world we inhabit.</p>"
    },
    {
      "type": "header",
      "content": "Navigation Columns"
    },
    { "type": "link_list", "id": "menu_1", "label": "Column 1 menu", "default": "footer" },
    { "type": "text",      "id": "menu_1_title", "label": "Column 1 heading", "default": "Shop" },
    { "type": "link_list", "id": "menu_2", "label": "Column 2 menu" },
    { "type": "text",      "id": "menu_2_title", "label": "Column 2 heading", "default": "Brand" },
    { "type": "link_list", "id": "menu_3", "label": "Column 3 menu" },
    { "type": "text",      "id": "menu_3_title", "label": "Column 3 heading", "default": "Help" },
    {
      "type": "header",
      "content": "Social Links"
    },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "pinterest", "label": "Pinterest" },
    { "type": "url", "id": "tiktok",    "label": "TikTok" },
    { "type": "url", "id": "facebook",  "label": "Facebook" },
    { "type": "url", "id": "twitter",   "label": "X (Twitter)" },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
