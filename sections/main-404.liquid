<div class="error-page" id="section-{{ section.id }}">
  <div class="container">
    <div class="error-page__inner">
      <p class="error-page__code">404</p>
      <h1 class="error-page__title">{{ '404.title' | t }}</h1>
      <p class="error-page__text">{{ '404.subtext' | t }}</p>
      <div class="error-page__actions">
        <a href="{{ routes.root_url }}" class="btn-primary">{{ '404.homepage_link' | t }}</a>
        <a href="{{ routes.all_products_collection_url }}" class="btn-ghost">{{ '404.shop_link' | t }}</a>
      </div>
      {%- if section.settings.show_search -%}
        <div class="error-page__search">
          <p class="error-page__search-label">{{ '404.search_label' | t }}</p>
          <form action="{{ routes.search_url }}" method="get" class="error-search-form">
            <input type="hidden" name="type" value="product">
            <div class="error-search-form__row">
              <input type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.placeholder' | t }}">
              <button type="submit" class="btn-primary">{{ 'general.search.submit' | t }}</button>
            </div>
          </form>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .error-page { padding: var(--section-spacing) 0; text-align: center; min-height: 60vh; display: flex; align-items: center; }
  .error-page__inner { max-width: 560px; margin: 0 auto; }
  .error-page__code { font-family: var(--ff-display); font-size: clamp(80px, 12vw, 160px); font-weight: 300; color: var(--gold); opacity: 0.25; line-height: 1; margin-bottom: 8px; }
  .error-page__title { font-family: var(--ff-display); font-size: clamp(24px, 3vw, 40px); font-weight: 300; margin-bottom: 16px; }
  .error-page__text { font-size: 14px; opacity: 0.6; line-height: 1.7; margin-bottom: 40px; }
  .error-page__actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .error-page__search { margin-top: 56px; padding-top: 40px; border-top: 1px solid var(--border); }
  .error-page__search-label { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--cream); opacity: 0.6; margin-bottom: 20px; }
  .error-search-form__row { display: flex; max-width: 400px; margin: 0 auto; }
  .error-search-form__row input { flex: 1; background: transparent; border: 1px solid var(--border); border-right: none; color: var(--cream); font-family: var(--ff-body); font-size: 14px; padding: 14px 18px; outline: none; }
  .error-search-form__row input:focus { border-color: var(--gold); }
  .error-search-form__row .btn-primary { font-size: 11px; letter-spacing: 0.2em; white-space: nowrap; }
</style>

{% schema %}
{
  "name": "404 Page",
  "tag": "div",
  "settings": [
    { "type": "checkbox", "id": "show_search", "label": "Show Search Bar", "default": true }
  ],
  "presets": [{ "name": "404 Page" }]
}
{% endschema %}
