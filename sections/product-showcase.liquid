{%- liquid
  assign s = section.settings
  assign scheme_class = 'psc--' | append: s.scheme
  assign collection = collections[s.collection]
  assign fb = 'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1496217590455-aa63a8350eea?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1525507119028-ed4c629a60a3?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&w=800&q=85|https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=800&q=85' | split: '|'
  assign demo_names = 'The Atelier Coat,Sculptural Blazer,Cashmere Turtleneck,Wide-Leg Trousers,Silk Midi Dress,Tailored Waistcoat,Wool Overcoat,Pleated Skirt' | split: ','
  assign demo_prices = '$1,290|$890|$640|$580|$740|$420|$1,150|$390' | split: '|'
  assign demo_cats = 'Outerwear,Tailoring,Knitwear,Trousers,Dresses,Tailoring,Outerwear,Skirts' | split: ','
-%}

<section
  id="section-{{ section.id }}"
  class="psc-section {{ scheme_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="psc-inner">

    <div class="psc-head reveal">
      <div>
        {%- if s.eyebrow != blank -%}<span class="psc-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="psc-head__heading">{{ s.heading }}</h2>{%- endif -%}
      </div>
      {%- if s.cta_label != blank -%}
        <a href="{{ collection.url | default: s.cta_url | default: '/collections/all' }}" class="psc-head__cta">
          {{ s.cta_label }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="psc-grid" style="--psc-cols: {{ s.columns }};">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: s.products_to_show -%}
          <a href="{{ product.url }}" class="psc-card reveal">
            <div class="psc-card__media">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag:
                  loading: 'lazy', class: 'psc-card__img', sizes: '(max-width:900px) 50vw, 25vw',
                  widths: '300,500,800', alt: product.title | escape }}
              {%- else -%}
                <img class="psc-card__img" src="{{ fb[forloop.index0] | default: fb[0] }}" alt="{{ product.title | escape }}" loading="lazy" />
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="psc-card__badge">Sale</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="psc-card__badge">New</span>
              {%- endif -%}
              <span class="psc-card__quick">View Product</span>
            </div>
            <div class="psc-card__info">
              <span class="psc-card__cat">{{ product.type | default: product.vendor }}</span>
              <h3 class="psc-card__name">{{ product.title }}</h3>
              <div class="psc-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                <span>{{ product.price | money }}</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (0..7) -%}
          {%- if forloop.index > s.products_to_show -%}{%- break -%}{%- endif -%}
          <a href="/collections/all" class="psc-card reveal">
            <div class="psc-card__media">
              <img class="psc-card__img" src="{{ fb[i] }}" alt="{{ demo_names[i] }}" loading="lazy" />
              {%- if i == 0 or i == 4 -%}<span class="psc-card__badge">New</span>{%- endif -%}
              <span class="psc-card__quick">View Product</span>
            </div>
            <div class="psc-card__info">
              <span class="psc-card__cat">{{ demo_cats[i] }}</span>
              <h3 class="psc-card__name">{{ demo_names[i] }}</h3>
              <div class="psc-card__price"><span>{{ demo_prices[i] }}</span></div>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  #section-{{ section.id }}.psc--light { --sbg:#FAF8F3; --sfg:#0A0A0A; --sacc:#9B7B3F; --smut:rgba(10,10,10,.5); --sbdr:rgba(10,10,10,.12); --ssale:#8B1A1A; }
  #section-{{ section.id }}.psc--dark  { --sbg:#0A0A0A; --sfg:#F5F0E8; --sacc:#C8A96E; --smut:rgba(245,240,232,.55); --sbdr:rgba(245,240,232,.1); --ssale:#E8A0A0; }
  #section-{{ section.id }}.psc--warm  { --sbg:#F0EBE0; --sfg:#2C1F14; --sacc:#8B5E3C; --smut:rgba(44,31,20,.5); --sbdr:rgba(44,31,20,.13); --ssale:#8B1A1A; }
  #section-{{ section.id }}.psc--theme { --sbg:var(--background,#0A0A0A); --sfg:var(--foreground,#F5F0E8); --sacc:var(--gold,#C8A96E); --smut:var(--muted,rgba(245,240,232,.55)); --sbdr:var(--border,rgba(245,240,232,.1)); --ssale:#E8A0A0; }

  #section-{{ section.id }} { background: var(--sbg); color: var(--sfg); padding: clamp(64px,8vw,120px) var(--side-padding,5vw); }
  .psc-inner { max-width: var(--container-width,1400px); margin: 0 auto; }

  .psc-head { display:flex; align-items:flex-end; justify-content:space-between; gap:24px; margin-bottom: clamp(36px,4vw,56px); }
  .psc-head__eyebrow { display:block; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.22em; text-transform:uppercase; color:var(--sacc); margin-bottom:12px; }
  .psc-head__heading { font-family:var(--ff-display,'Cormorant Garamond',serif); font-size:clamp(32px,4vw,56px); font-weight:300; line-height:1.08; margin:0; }
  .psc-head__cta { display:inline-flex; align-items:center; gap:8px; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.14em; text-transform:uppercase; color:var(--smut); text-decoration:none; white-space:nowrap; transition:color .2s; }
  .psc-head__cta:hover { color:var(--sfg); }

  .psc-grid { display:grid; grid-template-columns: repeat(var(--psc-cols,4), 1fr); gap: clamp(16px,2vw,30px); }

  .psc-card { text-decoration:none; color:inherit; display:block; }
  .psc-card__media { position:relative; overflow:hidden; border-radius:3px; aspect-ratio:3/4; margin-bottom:16px; background:#e7e0d4; }
  .psc-card__img { width:100%; height:100%; object-fit:cover; display:block; transition: transform .8s cubic-bezier(.4,0,.2,1); }
  .psc-card:hover .psc-card__img { transform: scale(1.05); }
  .psc-card__badge { position:absolute; top:14px; left:14px; font-family:var(--ff-body,'Outfit',sans-serif); font-size:9px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; background:rgba(255,255,255,.94); color:#0A0A0A; padding:6px 11px; border-radius:2px; }
  .psc-card__quick {
    position:absolute; left:14px; right:14px; bottom:14px;
    text-align:center; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.14em; text-transform:uppercase;
    background:rgba(255,255,255,.95); color:#0A0A0A; padding:13px; border-radius:2px;
    opacity:0; transform: translateY(12px); transition: opacity .3s, transform .3s;
  }
  .psc-card:hover .psc-card__quick { opacity:1; transform:none; }

  .psc-card__cat { display:block; font-family:var(--ff-body,'Outfit',sans-serif); font-size:10px; letter-spacing:.14em; text-transform:uppercase; color:var(--smut); margin-bottom:7px; }
  .psc-card__name { font-family:var(--ff-display,'Cormorant Garamond',serif); font-size:clamp(17px,1.5vw,22px); font-weight:400; line-height:1.2; margin:0 0 8px; }
  .psc-card__price { font-family:var(--ff-body,'Outfit',sans-serif); font-size:14px; display:flex; gap:10px; align-items:baseline; }
  .psc-card__price s { color:var(--smut); font-size:12px; }
  .psc-card__price span { color:var(--sfg); }

  .psc-section .reveal { opacity:0; transform:translateY(24px); transition: opacity .6s ease, transform .6s ease; }
  .psc-section .reveal.is-visible { opacity:1; transform:none; }
  .psc-grid .reveal:nth-child(2){transition-delay:.05s;}
  .psc-grid .reveal:nth-child(3){transition-delay:.1s;}
  .psc-grid .reveal:nth-child(4){transition-delay:.15s;}
  .psc-grid .reveal:nth-child(5){transition-delay:.2s;}
  .psc-grid .reveal:nth-child(6){transition-delay:.25s;}

  @media (max-width: 900px) { .psc-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<script>
(function(){
  var SEC='{{ section.id }}';
  function init(root){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:.1});
    root.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
  }
  function getRoot(){return document.getElementById('section-'+SEC);}
  document.addEventListener('DOMContentLoaded',function(){var r=getRoot();if(r)init(r);});
  document.addEventListener('shopify:section:load',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r){init(r);r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});}});
  document.addEventListener('shopify:section:select',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r)r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});});
})();
</script>

{% schema %}
{
  "name": "Product Showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated Edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This Season's Icons" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View all products" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [ { "name": "Product Showcase" } ]
}
{% endschema %}
