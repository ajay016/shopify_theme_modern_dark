      "block_order": ["btn1"],
      "settings": {
        "eyebrow": "The Craft",
        "heading": "Made to Last\nNot Just a Season",
        "text": "<p>Every piece is constructed with the same deliberate care as the first. We work with artisans whose families have practiced their craft for generations.</p>",
        "layout": "left",
        "image_width": "60"
      }
    },
    "stats": {
      "type": "stats-row",
      "blocks": {
