<div class="site-header__actions">
  {%- comment -%}Search{%- endcomment -%}
  <button
    class="header-icon-btn"
    data-open-search
    aria-label="{{ 'accessibility.open_search' | t }}"
    aria-expanded="false"
    aria-controls="search-overlay"
  >
    {%- render 'icon-search' -%}
  </button>

  {%- comment -%}Account{%- endcomment -%}
  {%- if shop.customer_accounts_enabled -%}
    <a
      href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
      class="header-icon-btn"
      aria-label="{{ 'header.account' | t }}"
    >
      {%- render 'icon-account' -%}
    </a>
  {%- endif -%}

  {%- comment -%}Wishlist{%- endcomment -%}
  {%- if show_wishlist -%}
    <button
      class="header-icon-btn"
      data-open-wishlist
      aria-label="{{ 'accessibility.open_wishlist' | t }}"
    >
      {%- render 'icon-wishlist' -%}
      <span class="header-wishlist-count" aria-hidden="true"></span>
    </button>
  {%- endif -%}

  {%- comment -%}Cart{%- endcomment -%}
  {%- if cart_type == 'drawer' -%}
    <button
      class="header-icon-btn"
      data-open-cart
      aria-label="{{ 'header.cart' | t: count: cart.item_count }}"
      aria-expanded="false"
      aria-controls="cart-drawer"
    >
      {%- render 'icon-cart' -%}
      <span class="header-cart-count" aria-hidden="true">
        {%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}
      </span>
    </button>
  {%- else -%}
    <a
      href="{{ routes.cart_url }}"
      class="header-icon-btn"
      aria-label="{{ 'header.cart' | t: count: cart.item_count }}"
    >
      {%- render 'icon-cart' -%}
      <span class="header-cart-count" aria-hidden="true">
        {%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}
      </span>
    </a>
  {%- endif -%}
</div>
