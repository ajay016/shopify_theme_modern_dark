{% liquid
  assign heading      = section.settings.heading
  assign subheading   = section.settings.subheading
  assign collection   = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
  assign columns      = section.settings.columns
  assign show_view_all = section.settings.show_view_all

  assign demo_names  = 'Oversized Wool Coat,Structured Calfskin Tote,Column Gown in Silk,Tailored Blazer,Cashmere Roll Neck,Pleated Midi Skirt,Leather Ankle Boot,Wide-Leg Trouser' | split: ','
  assign demo_prices = '$1,240|$890|$2,150|$960|$540|$420|$780|$610' | split: '|'
  assign demo_cats   = 'Outerwear,Leather Goods,Eveningwear,Tailoring,Knitwear,Skirts,Footwear,Trousers' | split: ','
  assign f1 = 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&w=700&q=80'
  assign f2 = 'https://images.unsplash.com/photo-1566174053879-31528523f8ae?auto=format&fit=crop&w=700&q=80'
  assign f3 = 'https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=700&q=80'
  assign f4 = 'https://images.unsplash.com/photo-1520975954732-35dd22299614?auto=format&fit=crop&w=700&q=80'
  assign f5 = 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=700&q=80'
  assign f6 = 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=700&q=80'
  assign f7 = 'https://images.unsplash.com/photo-1543163521-1bf539c55dd2?auto=format&fit=crop&w=700&q=80'
  assign f8 = 'https://images.unsplash.com/photo-1525507119028-ed4c629a60a3?auto=format&fit=crop&w=700&q=80'
  assign demo_imgs_str = f1 | append: '||' | append: f2 | append: '||' | append: f3 | append: '||' | append: f4 | append: '||' | append: f5 | append: '||' | append: f6 | append: '||' | append: f7 | append: '||' | append: f8
  assign demo_imgs = demo_imgs_str | split: '||'
%}

<section class="section featured-products" id="section-{{ section.id }}">
  <div class="container">
    {%- if heading != blank or subheading != blank -%}
      <div class="section-head">
        <div>
          {%- if subheading != blank -%}
            <p class="eyebrow">{{ subheading }}</p>
          {%- endif -%}
          {%- if heading != blank -%}
            <h2 class="section-head__title">{{ heading }}</h2>
          {%- endif -%}
        </div>
        {%- if show_view_all and collection != blank -%}
          <a href="{{ collection.url }}" class="section-link">{{ 'collections.general.view_all' | t }}</a>
        {%- elsif show_view_all -%}
          <a href="/collections/all" class="section-link">View All New In</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="product-grid product-grid--{{ columns }}">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product, number: forloop.index -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%}Demo cards — same unified product card, shown until a collection is connected{%- endcomment -%}
        {%- for i in (1..8) -%}
          {%- if forloop.index > products_to_show -%}{%- break -%}{%- endif -%}
          {%- assign idx = forloop.index0 -%}
          {%- render 'product-card',
              demo_index: idx,
              demo_title: demo_names[idx],
              demo_price: demo_prices[idx],
              demo_category: demo_cats[idx],
              demo_image: demo_imgs[idx],
              demo_url: '/collections/all' -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .featured-products { padding: var(--section-spacing) 0; }
  .product-grid { display: grid; gap: clamp(16px, 2vw, 30px); }
  .product-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .product-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .product-grid--4 { grid-template-columns: repeat(4, 1fr); }
  .product-grid--5 { grid-template-columns: repeat(5, 1fr); }

  /* Section header with view-all link */
  .featured-products .section-head { display: flex; align-items: flex-end; justify-content: space-between; }

  @media (max-width: 1200px) {
    .product-grid--5 { grid-template-columns: repeat(4, 1fr); }
    .product-grid--4 { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 900px) {
    .product-grid--3, .product-grid--4, .product-grid--5 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .product-grid--2, .product-grid--3, .product-grid--4, .product-grid--5 { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "settings": [
    { "type": "text",       "id": "heading",         "label": "Heading",            "default": "New Arrivals" },
    { "type": "text",       "id": "subheading",      "label": "Eyebrow Text",       "default": "Collection" },
    { "type": "collection", "id": "collection",      "label": "Collection" },
    { "type": "range",      "id": "products_to_show","label": "Products to Show",   "min": 2, "max": 12, "step": 1, "default": 4 },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View All' button", "default": true }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
