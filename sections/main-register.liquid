<div class="auth-page" id="section-{{ section.id }}">
  <div class="container">
    <div class="auth-card">
      <h1 class="auth-card__title">{{ 'customer.register.title' | t }}</h1>
      {%- form 'create_customer', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-error">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="form-field">
          <label for="reg-first">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" id="reg-first" name="customer[first_name]" autocomplete="given-name" value="{{ form.first_name }}">
        </div>
        <div class="form-field">
          <label for="reg-last">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" id="reg-last" name="customer[last_name]" autocomplete="family-name" value="{{ form.last_name }}">
        </div>
        <div class="form-field">
          <label for="reg-email">{{ 'customer.register.email' | t }}</label>
          <input type="email" id="reg-email" name="customer[email]" autocomplete="email" value="{{ form.email }}" required>
        </div>
        <div class="form-field">
          <label for="reg-password">{{ 'customer.register.password' | t }}</label>
          <input type="password" id="reg-password" name="customer[password]" autocomplete="new-password" required>
        </div>
        <button type="submit" class="btn-primary auth-form__submit">{{ 'customer.register.submit' | t }}</button>
      {%- endform -%}
      <div class="auth-card__alt">
        <a href="{{ routes.account_login_url }}" class="auth-form__link">{{ 'customer.register.login_link' | t }}</a>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Register",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Register" }]
}
{% endschema %}
