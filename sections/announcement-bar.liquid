{%- if settings.announcement_enabled -%}
  {%- liquid
    assign bar_style = settings.announcement_style
    assign text_1 = settings.announcement_text_1
    assign text_2 = settings.announcement_text_2
    assign bar_link = settings.announcement_link
  -%}

  <div class="announcement-bar" role="banner" aria-label="Announcement">
    {%- if bar_link != blank -%}<a href="{{ bar_link }}">{%- endif -%}

    {%- if bar_style == 'ticker' -%}
      <div class="announcement-bar__ticker-wrap" aria-live="off">
        <div class="announcement-bar__ticker">
          {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
          <span>{{ text_1 }}</span>
          {%- if text_2 != blank -%}<span>{{ text_2 }}</span>{%- endif -%}
          <span>{{ text_1 }}</span>
          {%- if text_2 != blank -%}<span>{{ text_2 }}</span>{%- endif -%}
        </div>
      </div>

    {%- elsif bar_style == 'rotating' -%}
      {%- liquid
        assign messages = text_1
        if text_2 != blank
          assign messages = text_1 | append: '|' | append: text_2
        endif
        assign messages_arr = messages | split: '|'
        assign messages_json = messages_arr | json
      -%}
      <div
        class="announcement-bar__rotating"
        data-messages="{{ messages_json | escape }}"
      >{{ messages_arr[0] }}</div>

    {%- else -%}
      <div class="announcement-bar__static">
        <span>{{ text_1 }}</span>
        {%- if text_2 != blank -%}
          <span aria-hidden="true">✦</span>
          <span>{{ text_2 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if bar_link != blank -%}</a>{%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "announcement-bar-section",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure the announcement bar (on/off, style, text) in Theme Settings → Announcement Bar."
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
