{% liquid
  assign layout   = section.settings.layout
  assign columns  = section.settings.columns
  assign show_sidebar = section.settings.show_sidebar
  assign posts_per_page = section.settings.posts_per_page
%}

{%- paginate blog.articles by posts_per_page -%}
<div class="blog-page blog-page--{{ layout }}" id="section-{{ section.id }}">
  <div class="container">
    <div class="blog-page__header">
      <p class="eyebrow">{{ 'blogs.article.blog' | t }}</p>
      <h1 class="blog-page__title">{{ blog.title }}</h1>
    </div>

    <div class="blog-layout {% if show_sidebar %}blog-layout--has-sidebar{% endif %}">
      <div class="blog-posts blog-posts--{{ layout }}">
        {%- for article in blog.articles -%}
          <article class="blog-card blog-card--{{ layout }}" itemscope itemtype="http://schema.org/BlogPosting">
            {%- if article.image -%}
              {%- assign blog_card_alt = article.image.alt | default: article.title | escape -%}
              <a href="{{ article.url }}" class="blog-card__media" tabindex="-1" aria-hidden="true">
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'blog-card__img',
                    loading: 'lazy',
                    alt: blog_card_alt,
                    widths: '400, 600, 800'
                }}
              </a>
            {%- endif -%}
            <div class="blog-card__info">
              <div class="blog-card__meta">
                {%- if section.settings.show_date -%}
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
                    {{ article.published_at | date: '%B %-d, %Y' }}
                  </time>
                {%- endif -%}
                {%- if section.settings.show_author -%}
                  <span class="blog-card__author" itemprop="author">{{ article.author }}</span>
                {%- endif -%}
                {%- if section.settings.show_tags and article.tags.size > 0 -%}
                  {%- for tag in article.tags limit: 2 -%}
                    <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-tag">{{ tag }}</a>
                  {%- endfor -%}
                {%- endif -%}
              </div>
              <h2 class="blog-card__title" itemprop="headline">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>
              {%- if section.settings.show_excerpt and article.excerpt != blank -%}
                <p class="blog-card__excerpt" itemprop="description">{{ article.excerpt | strip_html | truncate: 130 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="blog-card__read-more">
                {{ 'blogs.article.read_more' | t }}
                {%- render 'icon-arrow-right' -%}
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if show_sidebar -%}
        <aside class="blog-sidebar">
          {%- if section.settings.show_search -%}
            <div class="blog-sidebar__widget">
              <h3 class="blog-sidebar__title">{{ 'blogs.sidebar.search' | t | default: 'Search' }}</h3>
              <form action="{{ routes.search_url }}" method="get" class="blog-search">
                <input type="hidden" name="type" value="article">
                <div class="blog-search__row">
                  <input type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}">
                  <button type="submit" aria-label="Search">{%- render 'icon-search' -%}</button>
                </div>
              </form>
            </div>
          {%- endif -%}
          <div class="blog-sidebar__widget">
            <h3 class="blog-sidebar__title">{{ 'blogs.sidebar.recent' | t | default: 'Recent Posts' }}</h3>
            <ul class="blog-sidebar__recent">
              {%- for article in blog.articles limit: 5 -%}
                <li>
                  <a href="{{ article.url }}" class="blog-sidebar__recent-item">
                    {%- if article.image -%}
                      {{ article.image | image_url: width: 80 | image_tag: class: 'blog-sidebar__recent-img', loading: 'lazy', alt: article.title }}
                    {%- endif -%}
                    <div>
                      <p class="blog-sidebar__recent-title">{{ article.title }}</p>
                      <time>{{ article.published_at | date: '%b %-d, %Y' }}</time>
                    </div>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </aside>
      {%- endif -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="{{ 'accessibility.pagination' | t }}">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="pagination__item pagination__item--prev">← {{ 'general.pagination.previous' | t }}</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}
            <span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span>
          {%- else -%}
            <span class="pagination__item pagination__item--gap">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="pagination__item pagination__item--next">{{ 'general.pagination.next' | t }} →</a>{%- endif -%}
      </nav>
    {%- endif -%}
  </div>
</div>
{%- endpaginate -%}

<style>
  .blog-page { padding: var(--section-spacing) 0; }
  .blog-page__header { text-align: center; margin-bottom: 56px; }
  .blog-page__title { font-family: var(--ff-display); font-size: clamp(32px, 4vw, 60px); font-weight: 300; margin-top: 12px; }
  .blog-layout { display: grid; gap: 48px; }
  .blog-layout--has-sidebar { grid-template-columns: 1fr 280px; }
  .blog-posts--grid { display: grid; gap: 32px; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  .blog-posts--masonry { columns: 2; column-gap: 32px; }
  .blog-posts--list .blog-card { display: grid; grid-template-columns: 340px 1fr; gap: 40px; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 40px; }
  .blog-card { }
  .blog-card__media { display: block; overflow: hidden; aspect-ratio: 16/9; }
  .blog-posts--list .blog-card__media { aspect-ratio: 4/3; }
  .blog-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease-out); }
  .blog-card__media:hover .blog-card__img { transform: scale(1.04); }
  .blog-card__info { padding: 20px 0 0; }
  .blog-posts--list .blog-card__info { padding: 0; display: flex; flex-direction: column; justify-content: center; }
  .blog-card__meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
  .blog-card__meta time { color: var(--gold); }
  .blog-tag { background: var(--gold-dim); color: var(--gold); padding: 2px 8px; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; }
  .blog-card__title { font-family: var(--ff-display); font-size: clamp(18px, 2vw, 24px); font-weight: 300; line-height: 1.2; margin-bottom: 12px; }
  .blog-card__title a { color: var(--cream); transition: color 0.2s; }
  .blog-card__title a:hover { color: var(--gold); }
  .blog-card__excerpt { font-size: 13px; line-height: 1.7; opacity: 0.6; margin-bottom: 16px; }
  .blog-card__read-more { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); transition: gap 0.2s; }
  .blog-card__read-more:hover { gap: 10px; }
  .blog-sidebar__widget { margin-bottom: 40px; }
  .blog-sidebar__title { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .blog-search__row { display: flex; border: 1px solid var(--border); }
  .blog-search__row input { flex: 1; background: transparent; border: none; color: var(--cream); font-family: var(--ff-body); font-size: 13px; padding: 10px 14px; outline: none; }
  .blog-search__row button { background: transparent; border: none; border-left: 1px solid var(--border); color: var(--muted); padding: 0 14px; cursor: pointer; }
  .blog-search__row button:hover { color: var(--gold); }
  .blog-sidebar__recent { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .blog-sidebar__recent-item { display: flex; gap: 12px; align-items: center; color: var(--cream); }
  .blog-sidebar__recent-img { width: 56px; height: 56px; object-fit: cover; flex-shrink: 0; }
  .blog-sidebar__recent-title { font-size: 13px; line-height: 1.4; margin-bottom: 4px; }
  .blog-sidebar__recent-item time { font-size: 10px; color: var(--muted); }
  @media (max-width: 900px) {
    .blog-layout--has-sidebar { grid-template-columns: 1fr; }
    .blog-posts--list .blog-card { grid-template-columns: 1fr; }
    .blog-posts--masonry { columns: 1; }
  }
</style>

{% schema %}
{
  "name": "Blog Posts",
  "tag": "div",
  "settings": [
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "grid",    "label": "Grid" },
        { "value": "list",    "label": "List" },
        { "value": "masonry", "label": "Masonry" }
      ],
      "default": "grid"
    },
    { "type": "checkbox", "id": "show_sidebar", "label": "Show Sidebar",       "default": false },
    { "type": "checkbox", "id": "show_date",    "label": "Show Publish Date",  "default": true },
    { "type": "checkbox", "id": "show_author",  "label": "Show Author",        "default": true },
    { "type": "checkbox", "id": "show_tags",    "label": "Show Tags",          "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show Excerpt",       "default": true },
    { "type": "checkbox", "id": "show_search",  "label": "Show Search (sidebar)", "default": true },
    { "type": "range",    "id": "posts_per_page","label": "Posts Per Page",    "min": 4, "max": 24, "step": 2, "default": 9 }
  ],
  "presets": [{ "name": "Blog Posts" }]
}
{% endschema %}
