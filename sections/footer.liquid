<footer class="site-footer" role="contentinfo">
  <div class="site-footer__top">

    {%- comment -%}Brand column{%- endcomment -%}
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="site-header__logo">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- elsif settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: 160
            | image_tag: loading: 'lazy', alt: shop.name
          }}
        {%- else -%}
          {{ settings.logo_text | default: shop.name }}
        {%- endif -%}
      </a>
      {%- if section.settings.description != blank -%}
        <div class="footer-brand__desc">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    {%- comment -%}Nav columns{%- endcomment -%}
    {%- for i in (1..3) -%}
      {%- liquid
        case i
          when 1
            assign menu_handle = section.settings.menu_1
            assign menu_title  = section.settings.menu_1_title
          when 2
            assign menu_handle = section.settings.menu_2
            assign menu_title  = section.settings.menu_2_title
          when 3
            assign menu_handle = section.settings.menu_3
            assign menu_title  = section.settings.menu_3_title
        endcase
      -%}
      {%- if menu_handle != blank -%}
        <div class="footer-col">
          {%- if menu_title != blank -%}
            <h4>{{ menu_title }}</h4>
          {%- endif -%}
          <ul>
            {%- for link in linklists[menu_handle].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <div class="site-footer__bottom">
    <p class="footer-copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      {{ 'general.continue_shopping' | t | prepend: ' ' }}
    </p>

    <div class="footer-social">
      {%- if section.settings.instagram != blank -%}
        <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
      {%- endif -%}
      {%- if section.settings.pinterest != blank -%}
        <a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">Pinterest</a>
      {%- endif -%}
      {%- if section.settings.tiktok != blank -%}
        <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>
      {%- endif -%}
      {%- if section.settings.facebook != blank -%}
        <a href="{{ section.settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
      {%- endif -%}
      {%- if section.settings.twitter != blank -%}
        <a href="{{ section.settings.twitter }}" target="_blank" rel="noopener" aria-label="X (Twitter)">X</a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_payment_icons -%}
      <div class="footer-payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'icon payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional, overrides global logo)"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Brand description",
      "default": "<p>Luxury fashion with a considered approach to design, craft, and the world we inhabit.</p>"
    },
    {
      "type": "header",
      "content": "Navigation Columns"
    },
    { "type": "link_list", "id": "menu_1", "label": "Column 1 menu", "default": "footer" },
    { "type": "text",      "id": "menu_1_title", "label": "Column 1 heading", "default": "Shop" },
    { "type": "link_list", "id": "menu_2", "label": "Column 2 menu" },
    { "type": "text",      "id": "menu_2_title", "label": "Column 2 heading", "default": "Brand" },
    { "type": "link_list", "id": "menu_3", "label": "Column 3 menu" },
    { "type": "text",      "id": "menu_3_title", "label": "Column 3 heading", "default": "Help" },
    {
      "type": "header",
      "content": "Social Links"
    },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "pinterest", "label": "Pinterest" },
    { "type": "url", "id": "tiktok",    "label": "TikTok" },
    { "type": "url", "id": "facebook",  "label": "Facebook" },
    { "type": "url", "id": "twitter",   "label": "X (Twitter)" },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
