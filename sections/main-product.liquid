{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign layout          = section.settings.layout
  assign thumb_position  = section.settings.thumbnail_position
  assign enable_zoom     = section.settings.enable_zoom
  assign enable_lightbox = section.settings.enable_lightbox
  assign sticky_atc      = section.settings.sticky_atc
%}

<div class="product-page product-page--{{ layout }}" id="section-{{ section.id }}" data-product-id="{{ product.id }}">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/">{{ 'general.home' | t }}</a>
      <span>{{ 'general.breadcrumb_separator' | t }}</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span>{{ 'general.breadcrumb_separator' | t }}</span>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </nav>

    <div class="product-layout product-layout--{{ layout }}">

      {%- comment -%} Media Column {%- endcomment -%}
      <div class="product-media-col product-media-col--thumb-{{ thumb_position }}">

        {%- if thumb_position == 'left' or thumb_position == 'right' -%}
          <div class="product-thumbs product-thumbs--{{ thumb_position }}">
            {%- for image in product.images limit: 8 -%}
              <button
                class="product-thumb {% if forloop.first %}is-active{% endif %}"
                data-thumbnail="{{ forloop.index0 }}"
                aria-label="{{ image.alt | default: product.title | escape }}"
              >
                {{ image | image_url: width: 120 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="product-gallery" id="product-gallery">
          {%- for image in product.images limit: 8 -%}
            <div class="product-gallery__slide {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}">
              {%- if enable_lightbox -%}
                <a href="{{ image | image_url: width: 2000 }}" class="product-gallery__lightbox-trigger" data-lightbox>
              {%- endif -%}
              {{
                image
                | image_url: width: 1200
                | image_tag:
                  class: 'product-gallery__img',
                  loading: forloop.first | if: 'eager', 'lazy',
                  alt: image.alt | default: product.title | escape,
                  widths: '600, 800, 1200',
                  data-zoom: enable_zoom
              }}
              {%- if enable_zoom -%}
                <div class="zoom-hint">{{ 'products.product.zoom_hint' | t }}</div>
              {%- endif -%}
              {%- if enable_lightbox -%}
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
          {%- if product.images.size == 0 -%}
            <div class="product-gallery__slide is-active">
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__img' }}
            </div>
          {%- endif -%}

          {%- if product.images.size > 1 -%}
            <button class="gallery-nav gallery-nav--prev" data-gallery-prev aria-label="Previous image">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="gallery-nav gallery-nav--next" data-gallery-next aria-label="Next image">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if thumb_position == 'bottom' -%}
          <div class="product-thumbs product-thumbs--bottom">
            {%- for image in product.images limit: 8 -%}
              <button class="product-thumb {% if forloop.first %}is-active{% endif %}" data-thumbnail="{{ forloop.index0 }}"
                aria-label="{{ image.alt | default: product.title | escape }}">
                {{ image | image_url: width: 120 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Info Column {%- endcomment -%}
      <div class="product-info-col">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'vendor' -%}
              {%- if product.vendor != blank -%}
                <p class="product-vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</p>
              {%- endif -%}

            {%- when 'title' -%}
              <h1 class="product-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

            {%- when 'price' -%}
              <div class="product-price" id="product-price" {{ block.shopify_attributes }}>
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <span class="product-price__current">{{ current_variant.price | money }}</span>
                  <span class="product-price__compare">{{ current_variant.compare_at_price | money }}</span>
                  {%- assign save = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
                  <span class="product-price__save">{{ 'products.product.save' | t }} {{ save }}%</span>
                {%- else -%}
                  <span class="product-price__current">{{ current_variant.price | money }}</span>
                {%- endif -%}
              </div>

            {%- when 'rating' -%}
              {%- if product.metafields.reviews.rating.value != blank -%}
                <div class="product-rating" {{ block.shopify_attributes }}>
                  {%- assign rating = product.metafields.reviews.rating.value -%}
                  {%- assign count  = product.metafields.reviews.rating_count.value | default: 0 -%}
                  <div class="rating-stars" aria-label="{{ rating }} out of 5 stars">
                    {%- for i in (1..5) -%}
                      <span class="star {% if i <= rating %}star--full{% elsif i <= rating | ceil %}star--half{% endif %}">★</span>
                    {%- endfor -%}
                  </div>
                  <span class="rating-count">({{ count }})</span>
                </div>
              {%- endif -%}

            {%- when 'variants' -%}
              {%- if product.has_only_default_variant == false -%}
                <div class="product-variants" {{ block.shopify_attributes }}>
                  {%- for option in product.options_with_values -%}
                    <div class="variant-group" data-option-index="{{ forloop.index0 }}">
                      <div class="variant-group__label">
                        <span>{{ option.name }}</span>
                        {%- if option.name == 'Size' or option.name == 'size' -%}
                          {%- if section.settings.show_size_guide -%}
                            <button class="size-guide-trigger" data-open-size-guide>{{ 'products.product.size_guide' | t }}</button>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                      {%- if option.name == 'Color' or option.name == 'Colour' -%}
                        <div class="variant-swatches">
                          {%- for value in option.values -%}
                            {%- assign swatch_color = value | downcase | replace: ' ', '-' -%}
                            <button
                              class="variant-swatch {% if option.selected_value == value %}is-selected{% endif %}"
                              data-option-value="{{ value }}"
                              style="background-color: {{ swatch_color }};"
                              title="{{ value }}"
                              aria-label="{{ value }}"
                              aria-pressed="{{ option.selected_value == value }}"
                            ></button>
                          {%- endfor -%}
                        </div>
                      {%- else -%}
                        <div class="variant-pills">
                          {%- for value in option.values -%}
                            {%- assign is_available = false -%}
                            {%- for variant in product.variants -%}
                              {%- if variant.option1 == value or variant.option2 == value or variant.option3 == value -%}
                                {%- if variant.available -%}{%- assign is_available = true -%}{%- endif -%}
                              {%- endif -%}
                            {%- endfor -%}
                            <button
                              class="variant-pill {% if option.selected_value == value %}is-selected{% endif %} {% unless is_available %}is-sold-out{% endunless %}"
                              data-option-value="{{ value }}"
                              aria-pressed="{{ option.selected_value == value }}"
                              {%- unless is_available -%}title="{{ 'products.product.sold_out' | t }}"{%- endunless -%}
                            >{{ value }}</button>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}

                  <select name="id" id="variant-select" class="sr-only" aria-label="{{ 'products.product.variant' | t }}">
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        {% if variant == current_variant %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                        data-price="{{ variant.price }}"
                        data-compare-price="{{ variant.compare_at_price }}"
                        data-sku="{{ variant.sku }}"
                      >{{ variant.title }}</option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endif -%}

            {%- when 'quantity' -%}
              <div class="product-quantity" {{ block.shopify_attributes }}>
                <label class="product-quantity__label" for="quantity-input">{{ 'products.product.quantity' | t }}</label>
                <div class="qty-stepper">
                  <button class="qty-btn" data-qty-minus aria-label="{{ 'accessibility.decrease_quantity' | t }}">−</button>
                  <input type="number" id="quantity-input" name="quantity" value="1" min="1" max="99" class="qty-input">
                  <button class="qty-btn" data-qty-plus aria-label="{{ 'accessibility.increase_quantity' | t }}">+</button>
                </div>
              </div>

            {%- when 'atc' -%}
              <div class="product-atc-group" {{ block.shopify_attributes }}>
                <button
                  class="btn-primary product-atc"
                  id="add-to-cart"
                  data-variant-id="{{ current_variant.id }}"
                  {%- unless current_variant.available -%}disabled{%- endunless -%}
                >
                  {%- if current_variant.available -%}
                    {{ 'cart.add' | t }}
                  {%- else -%}
                    {{ 'products.product.sold_out' | t }}
                  {%- endif -%}
                </button>
                {%- if section.settings.show_wishlist -%}
                  <button
                    class="act-btn act-btn--large"
                    data-wishlist-id="{{ product.id }}"
                    aria-label="{{ 'accessibility.wishlist_add' | t }}"
                    aria-pressed="false"
                  >
                    {%- render 'icon-wishlist' -%}
                  </button>
                {%- endif -%}
              </div>

            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="product-description rte" {{ block.shopify_attributes }}>
                  {{ product.description }}
                </div>
              {%- endif -%}

            {%- when 'trust_badges' -%}
              <div class="trust-badges" {{ block.shopify_attributes }}>
                {%- if block.settings.badge_1 != blank -%}
                  <div class="trust-badge">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span>{{ block.settings.badge_1 }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.badge_2 != blank -%}
                  <div class="trust-badge">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    <span>{{ block.settings.badge_2 }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.badge_3 != blank -%}
                  <div class="trust-badge">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{{ block.settings.badge_3 }}</span>
                  </div>
                {%- endif -%}
              </div>

            {%- when 'countdown' -%}
              {%- if block.settings.end_date != blank -%}
                <div class="product-countdown" {{ block.shopify_attributes }}
                  data-countdown="{{ block.settings.end_date }}" data-countdown-label="{{ block.settings.label }}">
                  <p class="countdown-label">{{ block.settings.label }}</p>
                  <div class="countdown-timer">
                    <div class="countdown-unit"><span class="countdown-value" data-days>00</span><span class="countdown-key">D</span></div>
                    <div class="countdown-sep">:</div>
                    <div class="countdown-unit"><span class="countdown-value" data-hours>00</span><span class="countdown-key">H</span></div>
                    <div class="countdown-sep">:</div>
                    <div class="countdown-unit"><span class="countdown-value" data-minutes>00</span><span class="countdown-key">M</span></div>
                    <div class="countdown-sep">:</div>
                    <div class="countdown-unit"><span class="countdown-value" data-seconds>00</span><span class="countdown-key">S</span></div>
                  </div>
                </div>
              {%- endif -%}

            {%- when 'stock_counter' -%}
              {%- if current_variant.inventory_management == 'shopify' -%}
                <div class="stock-counter" {{ block.shopify_attributes }}>
                  {%- if current_variant.inventory_quantity <= block.settings.threshold and current_variant.inventory_quantity > 0 -%}
                    <div class="stock-bar">
                      <div class="stock-bar__fill" style="width: {{ current_variant.inventory_quantity | times: 100 | divided_by: block.settings.threshold }}%"></div>
                    </div>
                    <p class="stock-text">{{ 'products.product.stock_remaining' | t: count: current_variant.inventory_quantity }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'visitors' -%}
              {%- if block.settings.show_visitors -%}
                <p class="product-visitors" {{ block.shopify_attributes }}>
                  <span class="visitors-dot"></span>
                  <span data-visitor-count>{{ block.settings.min_visitors | plus: product.id | modulo: block.settings.max_visitors | plus: block.settings.min_visitors }}</span>
                  {{ 'products.product.visitors' | t }}
                </p>
              {%- endif -%}

            {%- when 'share' -%}
              <div class="product-share" {{ block.shopify_attributes }}>
                <span class="product-share__label">{{ 'products.product.share' | t }}:</span>
                <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="share-btn" aria-label="Share on Facebook">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
                <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="share-btn" aria-label="Share on X">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
                </a>
                <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 800 }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" class="share-btn" aria-label="Pin on Pinterest">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                </a>
              </div>

            {%- when 'sku' -%}
              <p class="product-sku" {{ block.shopify_attributes }}>
                {{ 'products.product.sku' | t }}: <span id="product-sku">{{ current_variant.sku | default: 'N/A' }}</span>
              </p>

            {%- when 'tabs' -%}
              <div class="product-tabs" {{ block.shopify_attributes }}>
                <div class="tabs-nav">
                  {%- if block.settings.tab_1_title != blank -%}
                    <button class="tab-btn is-active" data-tab="0">{{ block.settings.tab_1_title }}</button>
                  {%- endif -%}
                  {%- if block.settings.tab_2_title != blank -%}
                    <button class="tab-btn" data-tab="1">{{ block.settings.tab_2_title }}</button>
                  {%- endif -%}
                  {%- if block.settings.tab_3_title != blank -%}
                    <button class="tab-btn" data-tab="2">{{ block.settings.tab_3_title }}</button>
                  {%- endif -%}
                </div>
                {%- if block.settings.tab_1_title != blank -%}
                  <div class="tab-panel is-active rte" data-tab-panel="0">{{ block.settings.tab_1_content }}</div>
                {%- endif -%}
                {%- if block.settings.tab_2_title != blank -%}
                  <div class="tab-panel rte" data-tab-panel="1">{{ block.settings.tab_2_content }}</div>
                {%- endif -%}
                {%- if block.settings.tab_3_title != blank -%}
                  <div class="tab-panel rte" data-tab-panel="2">{{ block.settings.tab_3_content }}</div>
                {%- endif -%}
              </div>

            {%- when 'divider' -%}
              <hr class="product-divider" {{ block.shopify_attributes }}>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- if sticky_atc -%}
    <div class="sticky-atc" id="sticky-atc" aria-hidden="true">
      <div class="container">
        <div class="sticky-atc__inner">
          <div class="sticky-atc__product">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 80 | image_tag: class: 'sticky-atc__img', loading: 'lazy', alt: product.title }}
            {%- endif -%}
            <div>
              <p class="sticky-atc__title">{{ product.title }}</p>
              <p class="sticky-atc__variant" id="sticky-atc-variant">{{ current_variant.title }}</p>
            </div>
          </div>
          <div class="sticky-atc__price" id="sticky-atc-price">{{ current_variant.price | money }}</div>
          <button class="btn-primary sticky-atc__btn" data-sticky-atc-btn data-variant-id="{{ current_variant.id }}"
            {%- unless current_variant.available -%}disabled{%- endunless -%}>
            {%- if current_variant.available -%}{{ 'cart.add' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
          </button>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Size Guide Modal {%- endcomment -%}
  {%- if section.settings.show_size_guide -%}
    <div class="size-guide-modal modal" id="size-guide-modal" role="dialog" aria-modal="true" aria-label="{{ 'products.product.size_guide' | t }}">
      <div class="modal__inner">
        <button class="modal__close" data-close-size-guide aria-label="{{ 'accessibility.close' | t }}">{%- render 'icon-close' -%}</button>
        <h2 class="modal__title">{{ 'products.product.size_guide' | t }}</h2>
        <div class="rte">{{ section.settings.size_guide_content }}</div>
      </div>
      <div class="modal__overlay" data-close-size-guide></div>
    </div>
  {%- endif -%}
</div>

<script type="application/json" id="product-json">
  {{ product | json }}
</script>

<style>
  .product-page { padding: 32px 0 var(--section-spacing); }
  .product-layout { display: grid; gap: 64px; }
  .product-layout--standard  { grid-template-columns: 1fr 1fr; }
  .product-layout--wide      { grid-template-columns: 3fr 2fr; }
  .product-layout--centered  { grid-template-columns: 1fr 1fr; }
  .product-layout--fullwidth { grid-template-columns: 1fr; }

  .product-media-col { position: relative; }
  .product-media-col--thumb-left,
  .product-media-col--thumb-right { display: flex; gap: 12px; }
  .product-media-col--thumb-right { flex-direction: row-reverse; }
  .product-media-col--thumb-left .product-thumbs,
  .product-media-col--thumb-right .product-thumbs { width: 80px; }

  .product-gallery { position: relative; overflow: hidden; background: var(--charcoal); aspect-ratio: 4/5; flex: 1; }
  .product-gallery__slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.4s; }
  .product-gallery__slide.is-active { opacity: 1; position: relative; }
  .product-gallery__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gallery-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(10,10,10,0.6); border: 1px solid var(--border); color: var(--cream); width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; transition: background 0.2s; }
  .gallery-nav:hover { background: var(--gold); border-color: var(--gold); color: var(--black); }
  .gallery-nav--prev { left: 12px; }
  .gallery-nav--next { right: 12px; }
  .zoom-hint { position: absolute; bottom: 12px; right: 12px; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); background: rgba(10,10,10,0.7); padding: 4px 8px; }

  .product-thumbs { display: flex; flex-direction: column; gap: 8px; }
  .product-thumbs--bottom { flex-direction: row; margin-top: 12px; }
  .product-thumb { width: 80px; height: 96px; border: 1px solid transparent; overflow: hidden; cursor: pointer; transition: border-color 0.2s; flex-shrink: 0; }
  .product-thumb.is-active { border-color: var(--gold); }
  .product-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .product-info-col { display: flex; flex-direction: column; gap: 24px; }
  .product-vendor { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); }
  .product-title { font-family: var(--ff-display); font-size: clamp(24px, 3vw, 40px); font-weight: 300; line-height: 1.1; }
  .product-price { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .product-price__current { font-size: 22px; font-weight: 400; color: var(--cream); }
  .product-price__compare { font-size: 16px; color: var(--muted); text-decoration: line-through; }
  .product-price__save { font-size: 12px; background: var(--sale-bg); color: var(--sale-text); padding: 2px 8px; }
  .product-rating { display: flex; align-items: center; gap: 8px; }
  .rating-stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }
  .star--half { opacity: 0.5; }
  .rating-count { font-size: 12px; color: var(--muted); }

  .variant-group { display: flex; flex-direction: column; gap: 12px; }
  .variant-group__label { display: flex; justify-content: space-between; align-items: center; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--cream); }
  .size-guide-trigger { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--muted); background: transparent; border-top: none; border-left: none; border-right: none; cursor: pointer; padding: 0; }
  .size-guide-trigger:hover { color: var(--gold); border-bottom-color: var(--gold); }
  .variant-pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .variant-pill { background: transparent; border: 1px solid var(--border); color: var(--cream); font-family: var(--ff-body); font-size: 12px; letter-spacing: 0.05em; padding: 8px 16px; cursor: pointer; transition: all 0.2s; }
  .variant-pill.is-selected { border-color: var(--gold); color: var(--gold); }
  .variant-pill.is-sold-out { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }
  .variant-pill:hover:not(.is-sold-out):not(.is-selected) { border-color: var(--cream); }
  .variant-swatches { display: flex; flex-wrap: wrap; gap: 8px; }
  .variant-swatch { width: 28px; height: 28px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: border-color 0.2s; outline: 2px solid transparent; outline-offset: 2px; }
  .variant-swatch.is-selected { outline-color: var(--gold); }

  .product-quantity { display: flex; align-items: center; gap: 16px; }
  .product-quantity__label { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }
  .qty-stepper { display: flex; align-items: center; border: 1px solid var(--border); }
  .qty-btn { background: transparent; border: none; border-right: 1px solid var(--border); color: var(--cream); width: 40px; height: 40px; font-size: 18px; cursor: pointer; transition: background 0.2s; }
  .qty-btn:last-child { border-right: none; border-left: 1px solid var(--border); }
  .qty-btn:hover { background: var(--gold-dim); }
  .qty-input { background: transparent; border: none; color: var(--cream); font-family: var(--ff-body); font-size: 14px; width: 48px; text-align: center; -moz-appearance: textfield; }
  .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .product-atc-group { display: flex; gap: 12px; align-items: stretch; }
  .product-atc { flex: 1; font-size: 12px; letter-spacing: 0.25em; text-transform: uppercase; padding: 18px; }
  .act-btn--large { width: 54px; height: auto; border: 1px solid var(--border); }

  .trust-badges { display: flex; flex-wrap: wrap; gap: 16px; }
  .trust-badge { display: flex; align-items: center; gap: 8px; font-size: 11px; letter-spacing: 0.1em; color: var(--muted); }

  .product-description { font-size: 14px; line-height: 1.8; opacity: 0.7; }
  .product-divider { border: none; border-top: 1px solid var(--border); }
  .product-sku { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; }
  .product-share { display: flex; align-items: center; gap: 12px; }
  .product-share__label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .share-btn { color: var(--muted); transition: color 0.2s; }
  .share-btn:hover { color: var(--gold); }

  .product-countdown { background: var(--charcoal); border: 1px solid var(--border); padding: 20px 24px; }
  .countdown-label { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .countdown-timer { display: flex; align-items: center; gap: 4px; }
  .countdown-unit { text-align: center; }
  .countdown-value { font-family: var(--ff-display); font-size: 28px; font-weight: 300; }
  .countdown-key { display: block; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-top: 2px; }
  .countdown-sep { font-size: 24px; color: var(--muted); padding: 0 4px; margin-bottom: 16px; }

  .stock-counter { }
  .stock-bar { height: 2px; background: var(--border); border-radius: 2px; margin-bottom: 8px; }
  .stock-bar__fill { height: 100%; background: var(--gold); border-radius: 2px; }
  .stock-text { font-size: 11px; letter-spacing: 0.1em; color: var(--muted); }

  .product-visitors { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--muted); }
  .visitors-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .product-tabs { }
  .tabs-nav { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 20px; }
  .tab-btn { background: transparent; border: none; border-bottom: 2px solid transparent; color: var(--muted); font-family: var(--ff-body); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; padding: 12px 20px; cursor: pointer; margin-bottom: -1px; transition: all 0.2s; }
  .tab-btn.is-active { color: var(--gold); border-bottom-color: var(--gold); }
  .tab-panel { display: none; font-size: 13px; line-height: 1.8; opacity: 0.7; }
  .tab-panel.is-active { display: block; }

  .sticky-atc {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: var(--z-overlay);
    background: var(--charcoal); border-top: 1px solid var(--border);
    transform: translateY(100%); transition: transform 0.4s var(--ease-out);
    padding: 16px 0;
  }
  .sticky-atc.is-visible { transform: translateY(0); }
  .sticky-atc__inner { display: flex; align-items: center; gap: 24px; justify-content: space-between; }
  .sticky-atc__product { display: flex; align-items: center; gap: 16px; }
  .sticky-atc__img { width: 48px; height: 60px; object-fit: cover; }
  .sticky-atc__title { font-size: 13px; font-weight: 500; }
  .sticky-atc__variant { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .sticky-atc__price { font-size: 16px; }
  .sticky-atc__btn { font-size: 11px; letter-spacing: 0.2em; padding: 14px 28px; white-space: nowrap; }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  .modal { position: fixed; inset: 0; z-index: var(--z-modal); display: none; align-items: center; justify-content: center; }
  .modal.is-open { display: flex; }
  .modal__inner { position: relative; background: var(--charcoal); border: 1px solid var(--border); padding: 48px; max-width: 720px; width: 90%; max-height: 80vh; overflow-y: auto; z-index: 1; }
  .modal__close { position: absolute; top: 20px; right: 20px; background: transparent; border: none; color: var(--cream); cursor: pointer; padding: 4px; }
  .modal__title { font-family: var(--ff-display); font-size: 24px; font-weight: 300; margin-bottom: 24px; }
  .modal__overlay { position: fixed; inset: 0; background: var(--black-overlay); }

  @media (max-width: 900px) {
    .product-layout--standard, .product-layout--wide, .product-layout--centered { grid-template-columns: 1fr; gap: 32px; }
    .product-media-col--thumb-left, .product-media-col--thumb-right { flex-direction: column; }
    .product-thumbs--left, .product-thumbs--right { width: 100%; flex-direction: row; overflow-x: auto; }
    .product-thumb { width: 64px; height: 80px; }
    .sticky-atc__product { display: none; }
  }
</style>

{% schema %}
{
  "name": "Product",
  "tag": "div",
  "blocks": [
    { "type": "vendor",      "name": "Vendor",          "limit": 1, "settings": [] },
    { "type": "title",       "name": "Title",           "limit": 1, "settings": [] },
    { "type": "price",       "name": "Price",           "limit": 1, "settings": [] },
    { "type": "rating",      "name": "Rating",          "limit": 1, "settings": [] },
    { "type": "variants",    "name": "Variants",        "limit": 1, "settings": [] },
    { "type": "quantity",    "name": "Quantity",        "limit": 1, "settings": [] },
    { "type": "atc",         "name": "Add to Cart",     "limit": 1, "settings": [] },
    { "type": "description", "name": "Description",     "limit": 1, "settings": [] },
    {
      "type": "trust_badges", "name": "Trust Badges", "limit": 1,
      "settings": [
        { "type": "text", "id": "badge_1", "label": "Badge 1", "default": "Secure Payment" },
        { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "Free Shipping $500+" },
        { "type": "text", "id": "badge_3", "label": "Badge 3", "default": "Easy Returns" }
      ]
    },
    {
      "type": "countdown", "name": "Countdown Timer", "limit": 1,
      "settings": [
        { "type": "text",     "id": "label",    "label": "Label",    "default": "Offer Ends In" },
        { "type": "text",     "id": "end_date", "label": "End Date (YYYY-MM-DD HH:MM:SS)", "info": "Use UTC timezone format" }
      ]
    },
    {
      "type": "stock_counter", "name": "Stock Counter", "limit": 1,
      "settings": [
        { "type": "range", "id": "threshold", "label": "Show when stock below", "min": 1, "max": 20, "default": 10 }
      ]
    },
    {
      "type": "visitors", "name": "Live Visitors", "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_visitors",  "label": "Show visitor count", "default": true },
        { "type": "range",    "id": "min_visitors",   "label": "Min visitors",       "min": 1, "max": 50, "default": 5 },
        { "type": "range",    "id": "max_visitors",   "label": "Max visitors",       "min": 10, "max": 200, "default": 40 }
      ]
    },
    { "type": "share", "name": "Share", "limit": 1, "settings": [] },
    { "type": "sku",   "name": "SKU",   "limit": 1, "settings": [] },
    {
      "type": "tabs", "name": "Info Tabs", "limit": 1,
      "settings": [
        { "type": "text",     "id": "tab_1_title",   "label": "Tab 1 Title",   "default": "Details" },
        { "type": "richtext", "id": "tab_1_content", "label": "Tab 1 Content", "default": "<p>Product details and care instructions.</p>" },
        { "type": "text",     "id": "tab_2_title",   "label": "Tab 2 Title",   "default": "Shipping" },
        { "type": "richtext", "id": "tab_2_content", "label": "Tab 2 Content", "default": "<p>Complimentary shipping on orders over $500.</p>" },
        { "type": "text",     "id": "tab_3_title",   "label": "Tab 3 Title",   "default": "Returns" },
        { "type": "richtext", "id": "tab_3_content", "label": "Tab 3 Content", "default": "<p>Returns accepted within 14 days of receipt.</p>" }
      ]
    },
    { "type": "divider", "name": "Divider", "settings": [] }
  ],
  "settings": [
    {
      "type": "select", "id": "layout", "label": "Product Layout",
      "options": [
        { "value": "standard",  "label": "Standard (50/50)" },
        { "value": "wide",      "label": "Wide Media (60/40)" },
        { "value": "centered",  "label": "Centered" },
        { "value": "fullwidth", "label": "Full Width Media" }
      ],
      "default": "standard"
    },
    {
      "type": "select", "id": "thumbnail_position", "label": "Thumbnail Position",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "right",  "label": "Right" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "none",   "label": "None" }
      ],
      "default": "left"
    },
    { "type": "checkbox", "id": "enable_zoom",     "label": "Enable Image Zoom",       "default": true },
    { "type": "checkbox", "id": "enable_lightbox", "label": "Enable Lightbox",         "default": true },
    { "type": "checkbox", "id": "sticky_atc",      "label": "Sticky Add to Cart Bar",  "default": true },
    { "type": "checkbox", "id": "show_wishlist",   "label": "Show Wishlist Button",    "default": true },
    { "type": "checkbox", "id": "show_size_guide", "label": "Enable Size Guide",       "default": true },
    { "type": "richtext", "id": "size_guide_content", "label": "Size Guide Content" }
  ],
  "presets": [
    {
      "name": "Product",
      "blocks": [
        { "type": "vendor" },
        { "type": "title" },
        { "type": "price" },
        { "type": "rating" },
        { "type": "variants" },
        { "type": "quantity" },
        { "type": "atc" },
        { "type": "trust_badges" },
        { "type": "tabs" }
      ]
    }
  ]
}
