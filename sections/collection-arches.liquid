{%- liquid
  assign s = section.settings
  assign fb1 = 'https://images.unsplash.com/photo-1445205170230-053b83016050?auto=format&fit=crop&w=800&q=80'
  assign fb2 = 'https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?auto=format&fit=crop&w=800&q=80'
  assign fb3 = 'https://images.unsplash.com/photo-1520975954732-35dd22299614?auto=format&fit=crop&w=800&q=80'
  assign fb4 = 'https://images.unsplash.com/photo-1542295669297-4d352b042bca?auto=format&fit=crop&w=800&q=80'
  assign fb5 = 'https://images.unsplash.com/photo-1462804993656-fac4ff489837?auto=format&fit=crop&w=800&q=80'
  assign fb6 = 'https://images.unsplash.com/photo-1543163521-1bf539c55dd2?auto=format&fit=crop&w=800&q=80'
-%}

<section
  id="section-{{ section.id }}"
  class="arc-section arc--{{ s.scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="arc-head reveal">
    <div>
      {%- if s.eyebrow != blank -%}<span class="arc-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="arc-heading">{{ s.heading }}</h2>{%- endif -%}
    </div>
    <div class="arc-nav">
      <button type="button" class="arc-nav__btn" data-arc-prev aria-label="Previous">
        <svg width="20" height="10" viewBox="0 0 22 10" fill="none"><path d="M21 5H2M6 1L2 5l4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="arc-nav__btn" data-arc-next aria-label="Next">
        <svg width="20" height="10" viewBox="0 0 22 10" fill="none"><path d="M1 5h19M16 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div class="arc-track" data-arc-track>
    {%- for block in section.blocks -%}
      {%- liquid
        case forloop.index
          when 1
            assign fb = fb1
          when 2
            assign fb = fb2
          when 3
            assign fb = fb3
          when 4
            assign fb = fb4
          when 5
            assign fb = fb5
          else
            assign fb = fb6
        endcase
        assign card_alt = block.settings.label | escape
      -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="arc-card reveal"
        {{ block.shopify_attributes }}
      >
        <span class="arc-card__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
        <div class="arc-card__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              loading: 'lazy', class: 'arc-card__img', sizes: '(max-width:900px) 70vw, 24vw',
              widths: '400,600,800', alt: card_alt }}
          {%- else -%}
            <img class="arc-card__img" src="{{ fb }}" alt="{{ card_alt }}" loading="lazy" />
          {%- endif -%}
        </div>
        <span class="arc-card__label">{{ block.settings.label }}</span>
        {%- if block.settings.sub != blank -%}
          <span class="arc-card__sub">{{ block.settings.sub }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  #section-{{ section.id }}.arc--light { --abg:#F4EFE6; --afg:#1C1814; --aacc:var(--gold,#A4552F); --amut:rgba(28,24,20,.55); --abdr:rgba(28,24,20,.16); }
  #section-{{ section.id }}.arc--dark  { --abg:#14100C; --afg:#F2EDE4; --aacc:var(--gold,#D9986B); --amut:rgba(242,237,228,.6); --abdr:rgba(242,237,228,.2); }
  #section-{{ section.id }}.arc--warm  { --abg:#E7DCCB; --afg:#2A2118; --aacc:var(--gold,#8E4F2A); --amut:rgba(42,33,24,.55); --abdr:rgba(42,33,24,.2); }
  #section-{{ section.id }}.arc--theme {
    --abg:var(--background,#14100C); --afg:var(--foreground,#F2EDE4);
    --aacc:var(--gold,#C8A96E); --amut:var(--muted,rgba(242,237,228,.6));
    --abdr:var(--border-strong,rgba(242,237,228,.2));
  }

  #section-{{ section.id }} {
    background: var(--abg);
    padding: var(--section-spacing, 80px) 0;
  }
  .arc-head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
    padding: 0 var(--side-padding, 5vw);
    margin-bottom: clamp(32px, 5vw, 56px);
  }
  .arc-eyebrow {
    display: block;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 11px; font-weight: 500; letter-spacing: .26em; text-transform: uppercase;
    color: var(--aacc); margin-bottom: 14px;
  }
  .arc-heading {
    font-family: var(--ff-display,'Cormorant Garamond',serif);
    font-size: calc(clamp(32px, 4.4vw, 60px) * var(--heading-scale, 1)); font-weight: 300; line-height: 1.05;
    color: var(--afg); margin: 0;
  }
  .arc-nav { display: flex; gap: 10px; }
  .arc-nav__btn {
    width: 52px; height: 52px; border-radius: 50%;
    border: 1px solid var(--abdr); background: transparent; color: var(--afg);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .25s, color .25s, border-color .25s;
  }
  .arc-nav__btn:hover { background: var(--afg); color: var(--abg); border-color: var(--afg); }

  .arc-track {
    display: flex; gap: clamp(18px, 2.4vw, 32px);
    overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;
    padding: 0 var(--side-padding, 5vw) 8px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .arc-track::-webkit-scrollbar { display: none; }

  .arc-card {
    flex: 0 0 auto; width: clamp(220px, 23vw, 300px);
    scroll-snap-align: start;
    text-decoration: none; text-align: center; position: relative;
  }
  .arc-card__num {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%); z-index: 2;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 10px; font-weight: 500; letter-spacing: .22em;
    color: rgba(255,255,255,.85);
  }
  .arc-card__media {
    aspect-ratio: 3 / 4;
    border-radius: 999px 999px 4px 4px; /* arch */
    overflow: hidden; background: #cbbfa9;
  }
  .arc-card__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .6s ease;
  }
  .arc-card:hover .arc-card__img { transform: scale(1.06); }
  .arc-card__label {
    display: block; margin-top: 18px;
    font-family: var(--ff-display,'Cormorant Garamond',serif);
    font-size: clamp(20px, 1.7vw, 26px); font-weight: 400; font-style: italic;
    color: var(--afg);
  }
  .arc-card__sub {
    display: block; margin-top: 6px;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 10px; font-weight: 500; letter-spacing: .2em; text-transform: uppercase;
    color: var(--amut);
  }

  @media (max-width: 700px) {
    .arc-nav { display: none; }
    .arc-card { width: 68vw; }
  }
</style>

<script>
(function(){
  var SEC = '{{ section.id }}';
  function init(root){
    var track = root.querySelector('[data-arc-track]');
    if (!track) return;
    var step = 340;
    var prev = root.querySelector('[data-arc-prev]');
    var next = root.querySelector('[data-arc-next]');
    if (prev) prev.addEventListener('click', function(){ track.scrollBy({ left: -step, behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function(){ track.scrollBy({ left: step, behavior: 'smooth' }); });
  }
  function getRoot(){ return document.getElementById('section-' + SEC); }
  document.addEventListener('DOMContentLoaded', function(){ var r = getRoot(); if (r) init(r); });
  document.addEventListener('shopify:section:load', function(e){ if (e.detail.sectionId !== SEC) return; var r = getRoot(); if (r) init(r); });
})();
</script>

{% schema %}
{
  "name": "Collection Arches",
  "tag": "section",
  "class": "section-collection-arches",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (sand)" },
        { "value": "dark",  "label": "Dark (espresso)" },
        { "value": "warm",  "label": "Warm (deep sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "warm"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Wardrobe Edit" }
  ],
  "blocks": [
    {
      "type": "card", "name": "Category card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Ready-to-Wear" },
        { "type": "text", "id": "sub", "label": "Sub label", "default": "42 pieces" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection Arches",
      "blocks": [
        { "type": "card", "settings": { "label": "Ready-to-Wear", "sub": "42 pieces" } },
        { "type": "card", "settings": { "label": "Dresses", "sub": "36 pieces" } },
        { "type": "card", "settings": { "label": "Knitwear", "sub": "28 pieces" } },
        { "type": "card", "settings": { "label": "Leather Goods", "sub": "19 pieces" } },
        { "type": "card", "settings": { "label": "Eyewear", "sub": "14 pieces" } }
      ]
    }
  ]
}
{% endschema %}
