{%- liquid
  assign s = section.settings
  assign collection = collections[s.collection]
  assign count = s.products_to_show
-%}

<section class="fcs section" id="section-{{ section.id }}" style="background:{% if s.bg == 'charcoal' %}var(--charcoal){% else %}var(--black){% endif %};">
  <div class="container">
    <div class="fcs__head">
      <div class="fcs__head-text">
        {%- if s.eyebrow != blank -%}
          <p class="eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="section-head__title">{{ s.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="fcs__controls">
        {%- if s.show_view_all -%}
          <a href="{% if collection != blank %}{{ collection.url }}{% else %}/collections/all{% endif %}" class="section-link fcs__view-all">{{ s.view_all_label | default: 'View All' }}</a>
        {%- endif -%}
        <div class="fcs__nav">
          <button class="fcs__arrow" data-fcs-prev aria-label="Previous products">
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M19 7H1M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="fcs__arrow" data-fcs-next aria-label="Next products">
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7h18M13 1l6 6-6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="fcs__viewport" data-fcs-viewport>
      <div class="fcs__track" data-fcs-track>
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: count -%}
            <div class="fcs__slide">
              {%- render 'product-card', product: product -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%}Placeholder slides so the section previews fully without a collection{%- endcomment -%}
          {%- liquid
            assign p_names  = 'Oversized Wool Coat,Structured Calfskin Tote,Column Silk Gown,Tailored Blazer,Cashmere Roll-Neck,Pleated Midi Skirt' | split: ','
            assign p_prices = '$1,240,$890,$2,150,$960,$640,$520' | split: ','
          -%}
          {%- for i in (1..count) -%}
            {%- liquid
              assign pi = i | minus: 1
              assign bg_mod = i | modulo: 3 | plus: 1
            -%}
            <div class="fcs__slide">
              <div class="fcs__ph">
                <div class="fcs__ph-media fcs-bg-{{ bg_mod }}">
                  <svg width="120" height="190" viewBox="0 0 120 190" fill="none" aria-hidden="true">
                    <path d="M40 18 Q40 8 60 8 Q80 8 80 18 L86 44 L70 48 L70 178 L50 178 L50 48 L34 44 Z" stroke="rgba(200,169,110,0.32)" stroke-width="1.2" fill="rgba(200,169,110,0.05)"/>
                    <path d="M34 44 L18 54 L24 150 L50 146" stroke="rgba(200,169,110,0.22)" stroke-width="1" fill="none"/>
                    <path d="M86 44 L102 54 L96 150 L70 146" stroke="rgba(200,169,110,0.22)" stroke-width="1" fill="none"/>
                  </svg>
                  <span class="fcs__ph-tag">New In</span>
                </div>
                <div class="fcs__ph-info">
                  <p class="fcs__ph-brand">{{ shop.name }}</p>
                  <h3 class="fcs__ph-name">{{ p_names[pi] | default: 'Sample Piece' }}</h3>
                  <span class="fcs__ph-price">{{ p_prices[pi] | default: '$500' }}</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="fcs__progress" aria-hidden="true">
      <div class="fcs__progress-bar" data-fcs-progress></div>
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }}.fcs { overflow: hidden; }
  #section-{{ section.id }} .fcs__head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
    margin-bottom: 48px; flex-wrap: wrap;
  }
  #section-{{ section.id }} .fcs__controls { display: flex; align-items: center; gap: 28px; }
  #section-{{ section.id }} .fcs__nav { display: flex; gap: 10px; }
  #section-{{ section.id }} .fcs__arrow {
    width: 52px; height: 52px; border-radius: 50%;
    border: 1px solid var(--border-strong); background: transparent; color: var(--cream);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: background var(--transition), color var(--transition), border-color var(--transition), opacity var(--transition);
  }
  #section-{{ section.id }} .fcs__arrow:hover { background: var(--gold); border-color: var(--gold); color: var(--black); }
  #section-{{ section.id }} .fcs__arrow:disabled { opacity: 0.3; cursor: default; }
  #section-{{ section.id }} .fcs__arrow:disabled:hover { background: transparent; color: var(--cream); border-color: var(--border-strong); }

  #section-{{ section.id }} .fcs__viewport { overflow: hidden; margin-inline: -8px; }
  #section-{{ section.id }} .fcs__track {
    display: flex; gap: 24px; padding-inline: 8px;
    scroll-snap-type: x mandatory;
    cursor: grab; user-select: none;
  }
  #section-{{ section.id }} .fcs__track.is-dragging { cursor: grabbing; }
  #section-{{ section.id }} .fcs__slide {
    flex: 0 0 calc((100% - {{ s.per_view | minus: 1 | times: 24 }}px) / {{ s.per_view }});
    scroll-snap-align: start;
  }

  /* Progress bar */
  #section-{{ section.id }} .fcs__progress {
    margin-top: 40px; height: 2px; background: var(--border); position: relative; overflow: hidden;
  }
  #section-{{ section.id }} .fcs__progress-bar {
    position: absolute; top: 0; left: 0; height: 100%; width: 20%;
    background: var(--gold); transition: left 0.3s var(--ease-out), width 0.3s var(--ease-out);
  }

  /* Placeholder card */
  #section-{{ section.id }} .fcs__ph-media {
    position: relative; aspect-ratio: 3/4; display: flex; align-items: center; justify-content: center;
    margin-bottom: 18px; overflow: hidden;
  }
  #section-{{ section.id }} .fcs-bg-1 { background: linear-gradient(145deg, #1c1814, #2a241c); }
  #section-{{ section.id }} .fcs-bg-2 { background: linear-gradient(145deg, #141c1c, #1c2828); }
  #section-{{ section.id }} .fcs-bg-3 { background: linear-gradient(145deg, #1c1420, #28182c); }
  #section-{{ section.id }} .fcs__ph-tag {
    position: absolute; top: 16px; left: 16px;
    background: var(--gold); color: var(--black);
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 500;
    padding: 5px 11px;
  }
  #section-{{ section.id }} .fcs__ph-brand { font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  #section-{{ section.id }} .fcs__ph-name { font-family: var(--ff-display); font-size: 19px; font-weight: 400; color: var(--cream); margin-bottom: 6px; }
  #section-{{ section.id }} .fcs__ph-price { font-size: 14px; color: var(--cream); opacity: 0.85; }

  @media (max-width: 1100px) {
    #section-{{ section.id }} .fcs__slide { flex-basis: calc((100% - 24px) / 2); }
  }
  @media (max-width: 640px) {
    #section-{{ section.id }} .fcs__slide { flex-basis: 78%; }
    #section-{{ section.id }} .fcs__view-all { display: none; }
  }
</style>

<script>
  (function () {
    var ROOT_ID = 'section-{{ section.id }}';

    function initSlider(root) {
      if (!root) return;
      var viewport = root.querySelector('[data-fcs-viewport]');
      var track    = root.querySelector('[data-fcs-track]');
      var prev     = root.querySelector('[data-fcs-prev]');
      var next     = root.querySelector('[data-fcs-next]');
      var progress = root.querySelector('[data-fcs-progress]');
      if (!track || !viewport) return;

      function slideStep() {
        var slide = track.querySelector('.fcs__slide');
        if (!slide) return track.clientWidth;
        var gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap) || 24;
        return slide.getBoundingClientRect().width + gap;
      }

      function maxScroll() { return track.scrollWidth - track.clientWidth; }

      function update() {
        var max = maxScroll();
        var ratio = max > 0 ? track.scrollLeft / max : 0;
        if (progress) {
          var visible = track.clientWidth / track.scrollWidth;
          progress.style.width = Math.max(visible * 100, 8) + '%';
          progress.style.left = ratio * (100 - Math.max(visible * 100, 8)) + '%';
        }
        if (prev) prev.disabled = track.scrollLeft <= 2;
        if (next) next.disabled = track.scrollLeft >= max - 2;
      }

      if (next) next.addEventListener('click', function () {
        track.scrollBy({ left: slideStep(), behavior: 'smooth' });
      });
      if (prev) prev.addEventListener('click', function () {
        track.scrollBy({ left: -slideStep(), behavior: 'smooth' });
      });
      track.addEventListener('scroll', function () { window.requestAnimationFrame(update); }, { passive: true });

      /* Drag to scroll */
      var isDown = false, startX = 0, startScroll = 0, moved = false;
      track.addEventListener('pointerdown', function (e) {
        isDown = true; moved = false;
        startX = e.pageX; startScroll = track.scrollLeft;
        track.classList.add('is-dragging');
      });
      track.addEventListener('pointermove', function (e) {
        if (!isDown) return;
        var dx = e.pageX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startScroll - dx;
      });
      function endDrag() { isDown = false; track.classList.remove('is-dragging'); }
      track.addEventListener('pointerup', endDrag);
      track.addEventListener('pointerleave', endDrag);
      track.addEventListener('pointercancel', endDrag);
      /* Prevent click-through after a drag */
      track.addEventListener('click', function (e) {
        if (moved) { e.preventDefault(); e.stopPropagation(); }
      }, true);

      window.addEventListener('resize', update);
      update();
    }

    function boot() { initSlider(document.getElementById(ROOT_ID)); }

    if (document.readyState !== 'loading') boot();
    else document.addEventListener('DOMContentLoaded', boot);

    /* Shopify theme editor live preview */
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === '{{ section.id }}') initSlider(document.getElementById(ROOT_ID));
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "fcs-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated Edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This Season's Icons" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 16, "step": 1, "default": 8 },
    { "type": "range", "id": "per_view", "label": "Cards visible (desktop)", "min": 3, "max": 5, "step": 1, "default": 4 },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "black",    "label": "Black" },
        { "value": "charcoal", "label": "Charcoal" }
      ],
      "default": "black"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View All' link", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View All label", "default": "View All" }
  ],
  "presets": [
    { "name": "Collection Slider" }
  ]
}
{% endschema %}
