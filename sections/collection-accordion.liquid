{%- liquid
  assign s = section.settings
  assign scheme_class = 'cacc--' | append: s.scheme
-%}

<section
  id="section-{{ section.id }}"
  class="cacc-section {{ scheme_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="cacc-inner">

    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="cacc-header reveal">
        {%- if s.eyebrow != blank -%}
          <span class="cacc-eyebrow">{{ s.eyebrow }}</span>
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="cacc-heading">{{ s.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="cacc-body">
      <!-- Left: numbered accordion list -->
      <div class="cacc-list" role="list">
        {%- assign idx = 0 -%}
        {%- for block in section.blocks -%}
          {%- assign idx = forloop.index -%}
          {%- assign num = idx | prepend: '0' | slice: -2, 2 -%}
          {%- if block.type == 'item' -%}
            <div
              class="cacc-item reveal{% if forloop.first %} cacc-item--active{% endif %}"
              data-index="{{ forloop.index0 }}"
              data-image="{{ block.settings.image | image_url: width: 900 }}"
              data-label="{{ block.settings.label | escape }}"
              {{ block.shopify_attributes }}
            >
              <div class="cacc-item__inner">
                <span class="cacc-item__num">{{ num }}</span>
                <div class="cacc-item__meta">
                  <span class="cacc-item__name">{{ block.settings.label }}</span>
                  {%- if block.settings.sub != blank -%}
                    <span class="cacc-item__sub">{{ block.settings.sub }}</span>
                  {%- endif -%}
                </div>
                <div class="cacc-item__right">
                  {%- if block.settings.count != blank -%}
                    <span class="cacc-item__count">{{ block.settings.count }}</span>
                  {%- endif -%}
                  <span class="cacc-item__arrow" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="cacc-item__cover" aria-label="{{ block.settings.label }}"></a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Right: sticky preview panel -->
      <div class="cacc-preview" aria-hidden="true">
        <div class="cacc-preview__track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'item' -%}
              <div
                class="cacc-preview__slide{% if forloop.first %} cacc-preview__slide--active{% endif %}"
                data-preview="{{ forloop.index0 }}"
              >
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 900 | image_tag:
                    loading: 'lazy',
                    class: 'cacc-preview__img',
                    alt: block.settings.label
                  }}
                {%- else -%}
                  <div class="cacc-preview__placeholder">
                    <span>{{ block.settings.label | upcase }}</span>
                  </div>
                {%- endif -%}
                <div class="cacc-preview__label">
                  <span>{{ block.settings.label }}</span>
                  {%- if block.settings.count != blank -%}
                    <span class="cacc-preview__label-count">{{ block.settings.count }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if s.cta_label != blank and s.cta_url != blank -%}
          <a href="{{ s.cta_url }}" class="cacc-preview__cta">
            {{ s.cta_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Scheme variables ─────────────────────────────── */
  #section-{{ section.id }}.cacc--light {
    --cbg: var(--ivory, #FAF8F3);
    --cfg: var(--black, #0A0A0A);
    --cacc: #9B7B3F;
    --cmut: rgba(10,10,10,0.4);
    --cbdr: rgba(10,10,10,0.12);
    --cnum: rgba(10,10,10,0.15);
  }
  #section-{{ section.id }}.cacc--dark {
    --cbg: var(--black, #0A0A0A);
    --cfg: var(--cream, #F5F0E8);
    --cacc: var(--gold, #C8A96E);
    --cmut: rgba(245,240,232,0.45);
    --cbdr: rgba(245,240,232,0.1);
    --cnum: rgba(245,240,232,0.15);
  }
  #section-{{ section.id }}.cacc--warm {
    --cbg: #F0EBE0;
    --cfg: #2C1F14;
    --cacc: #8B5E3C;
    --cmut: rgba(44,31,20,0.45);
    --cbdr: rgba(44,31,20,0.13);
    --cnum: rgba(44,31,20,0.15);
  }
  #section-{{ section.id }}.cacc--theme {
    --cbg: var(--background, #0A0A0A);
    --cfg: var(--foreground, #F5F0E8);
    --cacc: var(--gold, #C8A96E);
    --cmut: var(--muted, rgba(245,240,232,0.45));
    --cbdr: var(--border, rgba(245,240,232,0.1));
    --cnum: rgba(245,240,232,0.15);
  }

  /* ── Base ─────────────────────────────────────────── */
  #section-{{ section.id }} {
    background: var(--cbg);
    color: var(--cfg);
    padding: clamp(64px, 8vw, 120px) var(--side-padding, 5vw);
  }
  .cacc-inner { max-width: var(--container-width, 1400px); margin: 0 auto; }

  /* ── Header ───────────────────────────────────────── */
  .cacc-header { margin-bottom: 56px; }
  .cacc-eyebrow {
    display: block;
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--cacc);
    margin-bottom: 14px;
  }
  .cacc-heading {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(36px, 4vw, 60px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--cfg);
    margin: 0;
  }

  /* ── Body layout ──────────────────────────────────── */
  .cacc-body {
    display: grid;
    grid-template-columns: 1fr min(42%, 520px);
    gap: 0 80px;
    align-items: start;
  }

  /* ── Accordion list ───────────────────────────────── */
  .cacc-list { display: flex; flex-direction: column; }

  .cacc-item {
    position: relative;
    border-top: 1px solid var(--cbdr);
    cursor: pointer;
    transition: background .2s;
  }
  .cacc-item:last-child { border-bottom: 1px solid var(--cbdr); }

  .cacc-item__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    transition: padding .25s;
  }
  .cacc-item--active .cacc-item__inner { padding: 36px 0; }

  .cacc-item__num {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: .1em;
    color: var(--cnum);
    min-width: 28px;
    transition: color .25s;
  }
  .cacc-item--active .cacc-item__num { color: var(--cacc); }

  .cacc-item__meta { flex: 1; display: flex; flex-direction: column; gap: 4px; }

  .cacc-item__name {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(22px, 2.8vw, 38px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--cfg);
    transition: color .2s, font-size .25s;
  }
  .cacc-item--active .cacc-item__name {
    font-size: clamp(26px, 3.2vw, 46px);
    font-style: italic;
  }

  .cacc-item__sub {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 12px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cmut);
    display: none;
  }
  .cacc-item--active .cacc-item__sub { display: block; }

  .cacc-item__right {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
  }
  .cacc-item__count {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cmut);
  }
  .cacc-item__arrow {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity .25s, transform .25s;
    color: var(--cacc);
  }
  .cacc-item--active .cacc-item__arrow { opacity: 1; transform: translateX(0); }

  .cacc-item__cover {
    position: absolute; inset: 0;
    z-index: 1;
  }

  /* ── Preview panel ────────────────────────────────── */
  .cacc-preview {
    position: sticky;
    top: clamp(80px, 10vh, 120px);
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 3px;
  }

  .cacc-preview__track { position: relative; width: 100%; height: 100%; }

  .cacc-preview__slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity .55s cubic-bezier(.4,0,.2,1);
  }
  .cacc-preview__slide--active { opacity: 1; }

  .cacc-preview__img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .6s cubic-bezier(.4,0,.2,1);
  }
  .cacc-preview__slide--active .cacc-preview__img { transform: scale(1.03); }

  .cacc-preview__placeholder {
    width: 100%; height: 100%;
    background: var(--cbdr);
    display: flex; align-items: center; justify-content: center;
  }
  .cacc-preview__placeholder span {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(18px, 2vw, 28px);
    font-weight: 300;
    letter-spacing: .2em;
    color: var(--cmut);
  }

  .cacc-preview__label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px 28px;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    color: #fff;
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 12px;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .cacc-preview__label-count { opacity: .7; }

  .cacc-preview__cta {
    position: absolute;
    top: 20px; right: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--cbg);
    color: var(--cfg);
    padding: 10px 18px;
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background .2s, color .2s;
    z-index: 2;
  }
  .cacc-preview__cta:hover { background: var(--cacc); color: #fff; }

  /* ── Reveal ───────────────────────────────────────── */
  .cacc-section .reveal { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
  .cacc-section .reveal.is-visible { opacity: 1; transform: none; }

  @media (max-width: 900px) {
    .cacc-body { grid-template-columns: 1fr; }
    .cacc-preview { display: none; }
  }
</style>

<script>
(function () {
  var SEC = '{{ section.id }}';

  function init(root) {
    var items    = root.querySelectorAll('.cacc-item');
    var slides   = root.querySelectorAll('.cacc-preview__slide');
    var active   = 0;

    function activate(idx) {
      if (idx === active) return;
      items[active]  && items[active].classList.remove('cacc-item--active');
      slides[active] && slides[active].classList.remove('cacc-preview__slide--active');
      active = idx;
      items[active]  && items[active].classList.add('cacc-item--active');
      slides[active] && slides[active].classList.add('cacc-preview__slide--active');
    }

    items.forEach(function (item, i) {
      item.addEventListener('mouseenter', function () { activate(i); });
      item.addEventListener('focusin',    function () { activate(i); });
    });

    /* reveal */
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    root.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
  }

  function getRoot() { return document.getElementById('section-' + SEC); }

  document.addEventListener('DOMContentLoaded', function () { var r = getRoot(); if (r) init(r); });

  document.addEventListener('shopify:section:load',   function (e) { if (e.detail.sectionId === SEC) { var r = getRoot(); if (r) { init(r); r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); }); } } });
  document.addEventListener('shopify:section:select', function (e) { if (e.detail.sectionId === SEC) { var r = getRoot(); if (r) r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); }); } });
})();
</script>

{% schema %}
{
  "name": "Collection Accordion",
  "tag": "section",
  "class": "section-collection-accordion",
  "settings": [
    {
      "type": "select",
      "id": "scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Collection name",
          "default": "Women's Ready-to-Wear"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Subtitle / tagline",
          "default": "Sculptural silhouettes"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Piece count",
          "default": "142 pieces"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Preview image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Collection URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Accordion",
      "blocks": [
        { "type": "item", "settings": { "label": "Women's Ready-to-Wear", "sub": "Sculptural silhouettes", "count": "142 pieces" } },
        { "type": "item", "settings": { "label": "Men's Tailoring",       "sub": "Precision craftsmanship", "count": "98 pieces" } },
        { "type": "item", "settings": { "label": "Bags & Accessories",    "sub": "The considered detail",   "count": "215 pieces" } },
        { "type": "item", "settings": { "label": "Outerwear",             "sub": "Built for every season",  "count": "64 pieces" } }
      ]
    }
  ]
}
{% endschema %}
