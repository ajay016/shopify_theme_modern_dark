{%- liquid
  assign s = section.settings
  assign fallback = 'https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?auto=format&fit=crop&w=2000&q=85'
-%}

<section
  id="section-{{ section.id }}"
  class="cmpb-section cmpb--{{ s.align }}"
  data-section-id="{{ section.id }}"
  style="--cmpb-minh: {{ s.min_height }}vh;"
>
  <div class="cmpb-media">
    {%- if s.image != blank -%}
      {{ s.image | image_url: width: 2400 | image_tag:
        loading: 'lazy', class: 'cmpb-img', sizes: '100vw',
        widths: '1000,1600,2000,2400', alt: s.heading | escape }}
    {%- else -%}
      <img class="cmpb-img" src="{{ fallback }}" alt="{{ s.heading | escape }}" loading="lazy" />
    {%- endif -%}
    <span class="cmpb-scrim" style="opacity: {{ s.overlay | divided_by: 100.0 }};"></span>
  </div>

  <div class="cmpb-content">
    <div class="cmpb-content__inner reveal">
      {%- if s.eyebrow != blank -%}<span class="cmpb-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="cmpb-heading">
          {%- assign hp = s.heading | split: '|' -%}
          {%- for part in hp -%}
            {%- if forloop.index == 2 -%}<em>{{ part | strip }}</em>{%- else -%}<span>{{ part | strip }}</span>{%- endif -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}
      {%- if s.description != blank -%}<p class="cmpb-desc">{{ s.description }}</p>{%- endif -%}
      {%- if s.btn_label != blank -%}
        <a href="{{ s.btn_link | default: '#' }}" class="cmpb-btn">{{ s.btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }} {
    position: relative; min-height: var(--cmpb-minh, 70vh);
    display: flex; overflow: hidden;
  }
  .cmpb-media { position:absolute; inset:0; }
  .cmpb-img { width:100%; height:100%; object-fit:cover; display:block; }
  .cmpb-scrim { position:absolute; inset:0; background: linear-gradient(180deg, rgba(10,10,10,.2), rgba(10,10,10,.5)); }

  .cmpb-content { position:relative; z-index:2; display:flex; width:100%; padding: clamp(48px,8vw,120px) var(--side-padding,5vw); }
  #section-{{ section.id }}.cmpb--center .cmpb-content { align-items:center; justify-content:center; text-align:center; }
  #section-{{ section.id }}.cmpb--left   .cmpb-content { align-items:center; justify-content:flex-start; }
  #section-{{ section.id }}.cmpb--bottom .cmpb-content { align-items:flex-end; justify-content:flex-start; }
  .cmpb-content__inner { max-width: 640px; }
  #section-{{ section.id }}.cmpb--center .cmpb-content__inner { max-width: 760px; }

  .cmpb-eyebrow { display:inline-block; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.24em; text-transform:uppercase; color:rgba(255,255,255,.85); margin-bottom:20px; }
  .cmpb-heading { font-family:var(--ff-display,'Cormorant Garamond',serif); font-size:clamp(40px,6vw,92px); font-weight:300; line-height:1.05; color:#fff; margin:0; }
  .cmpb-heading em { font-style:italic; color:var(--gold,#C8A96E); }
  .cmpb-heading span, .cmpb-heading em { display:block; }
  .cmpb-desc { font-family:var(--ff-body,'Outfit',sans-serif); font-size:clamp(14px,1.2vw,17px); line-height:1.7; color:rgba(255,255,255,.85); margin:24px 0 0; max-width:480px; }
  #section-{{ section.id }}.cmpb--center .cmpb-desc { margin-inline:auto; }
  .cmpb-btn { display:inline-block; margin-top:34px; font-family:var(--ff-body,'Outfit',sans-serif); font-size:12px; font-weight:500; letter-spacing:.14em; text-transform:uppercase; background:#fff; color:#0A0A0A; padding:16px 38px; border-radius:2px; text-decoration:none; transition: transform .25s, background .25s, color .25s; }
  .cmpb-btn:hover { transform: translateY(-2px); background: var(--gold,#C8A96E); }

  .cmpb-section .reveal { opacity:0; transform:translateY(28px); transition: opacity .8s ease, transform .8s ease; }
  .cmpb-section .reveal.is-visible { opacity:1; transform:none; }
</style>

<script>
(function(){
  var SEC='{{ section.id }}';
  function init(root){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:.2});
    root.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
  }
  function getRoot(){return document.getElementById('section-'+SEC);}
  document.addEventListener('DOMContentLoaded',function(){var r=getRoot();if(r)init(r);});
  document.addEventListener('shopify:section:load',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r){init(r);r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});}});
  document.addEventListener('shopify:section:select',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r)r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});});
})();
</script>

{% schema %}
{
  "name": "Campaign Banner",
  "tag": "section",
  "class": "section-campaign-banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "min_height", "label": "Minimum height", "min": 40, "max": 100, "step": 5, "unit": "vh", "default": 72 },
    { "type": "range", "id": "overlay", "label": "Image overlay", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 40 },
    {
      "type": "select", "id": "align", "label": "Content position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left",   "label": "Left" },
        { "value": "bottom", "label": "Bottom-left" }
      ],
      "default": "center"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Limited Release" },
    { "type": "text", "id": "heading", "label": "Heading (use | to italicise second part)", "default": "The Atelier | Capsule" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Twelve pieces. Made to order. Available for a limited window only." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop the Capsule" },
    { "type": "url", "id": "btn_link", "label": "Button link" }
  ],
  "presets": [ { "name": "Campaign Banner" } ]
}
{% endschema %}
