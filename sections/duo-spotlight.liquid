{%- liquid
  assign s = section.settings
  assign fbL = 'https://images.unsplash.com/photo-1509631179647-0177331693ae?auto=format&fit=crop&w=1100&q=85'
  assign fbR = 'https://images.unsplash.com/photo-1488161628813-04466f872be2?auto=format&fit=crop&w=1100&q=85'
  assign altL = s.label_left | escape
  assign altR = s.label_right | escape
-%}

<section
  id="section-{{ section.id }}"
  class="duo-section duo--{{ s.scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="duo-grid">
    <a href="{{ s.url_left | default: '#' }}" class="duo-panel">
      <div class="duo-panel__media">
        {%- if s.image_left != blank -%}
          {{ s.image_left | image_url: width: 1100 | image_tag:
            loading: 'lazy', class: 'duo-panel__img', sizes: '(max-width:820px) 100vw, 50vw',
            widths: '600,900,1100', alt: altL }}
        {%- else -%}
          <img class="duo-panel__img" src="{{ fbL }}" alt="{{ altL }}" loading="lazy" />
        {%- endif -%}
      </div>
      <span class="duo-panel__scrim" aria-hidden="true"></span>
      <span class="duo-panel__label">
        {{ s.label_left }}
        <svg width="20" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true"><path d="M1 5h19M16 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>

    <a href="{{ s.url_right | default: '#' }}" class="duo-panel">
      <div class="duo-panel__media">
        {%- if s.image_right != blank -%}
          {{ s.image_right | image_url: width: 1100 | image_tag:
            loading: 'lazy', class: 'duo-panel__img', sizes: '(max-width:820px) 100vw, 50vw',
            widths: '600,900,1100', alt: altR }}
        {%- else -%}
          <img class="duo-panel__img" src="{{ fbR }}" alt="{{ altR }}" loading="lazy" />
        {%- endif -%}
      </div>
      <span class="duo-panel__scrim" aria-hidden="true"></span>
      <span class="duo-panel__label">
        {{ s.label_right }}
        <svg width="20" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true"><path d="M1 5h19M16 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  </div>

  <div class="duo-card reveal">
    {%- if s.eyebrow != blank -%}<span class="duo-card__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="duo-card__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.text != blank -%}<p class="duo-card__text">{{ s.text }}</p>{%- endif -%}
    {%- if s.btn_label != blank -%}
      <a href="{{ s.btn_url | default: '#' }}" class="duo-card__btn">{{ s.btn_label }}</a>
    {%- endif -%}
  </div>
</section>

<style>
  #section-{{ section.id }}.duo--light { --dbg:#F4EFE6; --dcard:#F4EFE6; --dfg:#1C1814; --dacc:#A4552F; --dmut:rgba(28,24,20,.55); }
  #section-{{ section.id }}.duo--dark  { --dbg:#14100C; --dcard:#14100C; --dfg:#F2EDE4; --dacc:#D9986B; --dmut:rgba(242,237,228,.6); }
  #section-{{ section.id }}.duo--warm  { --dbg:#E7DCCB; --dcard:#E7DCCB; --dfg:#2A2118; --dacc:#8E4F2A; --dmut:rgba(42,33,24,.55); }
  #section-{{ section.id }}.duo--theme {
    --dbg:var(--background,#14100C); --dcard:var(--background,#14100C);
    --dfg:var(--foreground,#F2EDE4); --dacc:var(--gold,#C8A96E);
    --dmut:var(--muted,rgba(242,237,228,.6));
  }

  #section-{{ section.id }} { position: relative; background: var(--dbg); }
  .duo-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .duo-panel {
    position: relative; display: block; overflow: hidden;
    height: clamp(480px, 82vh, 840px);
    background: #2a221a;
  }
  .duo-panel__media { position: absolute; inset: 0; }
  .duo-panel__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .8s ease;
  }
  .duo-panel:hover .duo-panel__img { transform: scale(1.05); }
  .duo-panel__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(20,16,12,0) 55%, rgba(20,16,12,.55) 100%);
    pointer-events: none;
  }
  .duo-panel__label {
    position: absolute; left: clamp(24px, 4vw, 56px); bottom: clamp(24px, 4vw, 48px);
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--ff-display,'Cormorant Garamond',serif);
    font-size: clamp(26px, 2.6vw, 40px); font-weight: 300; font-style: italic;
    color: #fff; z-index: 2;
    transition: gap .3s ease;
  }
  .duo-panel:hover .duo-panel__label { gap: 20px; }

  .duo-card {
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3; width: min(86vw, 380px);
    background: var(--dcard);
    text-align: center;
    padding: clamp(32px, 4vw, 52px) clamp(26px, 3vw, 44px);
    box-shadow: 0 30px 80px rgba(20,16,12,.28);
    border-radius: 3px;
  }
  .duo-card__eyebrow {
    display: block;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 10px; font-weight: 500; letter-spacing: .26em; text-transform: uppercase;
    color: var(--dacc); margin-bottom: 16px;
  }
  .duo-card__heading {
    font-family: var(--ff-display,'Cormorant Garamond',serif);
    font-size: clamp(26px, 2.6vw, 38px); font-weight: 300; line-height: 1.12;
    color: var(--dfg); margin: 0;
  }
  .duo-card__text {
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 13px; line-height: 1.7; color: var(--dmut);
    margin: 16px 0 0;
  }
  .duo-card__btn {
    display: inline-block; margin-top: 24px;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 10px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase;
    color: var(--dfg); text-decoration: none;
    border-bottom: 1px solid var(--dacc); padding-bottom: 7px;
    transition: color .25s;
  }
  .duo-card__btn:hover { color: var(--dacc); }

  @media (max-width: 820px) {
    .duo-grid { grid-template-columns: 1fr; }
    .duo-panel { height: 62vh; min-height: 380px; }
    .duo-card {
      position: relative; left: auto; top: auto; transform: none;
      margin: -60px auto 0; z-index: 3;
    }
    #section-{{ section.id }} { padding-bottom: clamp(40px, 8vw, 64px); }
  }
</style>

{% schema %}
{
  "name": "Duo Spotlight",
  "tag": "section",
  "class": "section-duo-spotlight",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme (center card)",
      "options": [
        { "value": "light", "label": "Light (sand)" },
        { "value": "dark",  "label": "Dark (espresso)" },
        { "value": "warm",  "label": "Warm (deep sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    { "type": "header", "content": "Left panel" },
    { "type": "image_picker", "id": "image_left", "label": "Image" },
    { "type": "text", "id": "label_left", "label": "Label", "default": "For Her" },
    { "type": "url",  "id": "url_left",   "label": "Link" },
    { "type": "header", "content": "Right panel" },
    { "type": "image_picker", "id": "image_right", "label": "Image" },
    { "type": "text", "id": "label_right", "label": "Label", "default": "For Him" },
    { "type": "url",  "id": "url_right",   "label": "Link" },
    { "type": "header", "content": "Center card" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Two Worlds" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One Considered Wardrobe" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Womenswear and menswear, cut from the same cloth — literally. Explore both sides of the atelier." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop Everything" },
    { "type": "url",  "id": "btn_url",   "label": "Button link" }
  ],
  "presets": [ { "name": "Duo Spotlight" } ]
}
{% endschema %}
