<div class="auth-page" id="section-{{ section.id }}">
  <div class="container">
    <div class="auth-card">
      <h1 class="auth-card__title">{{ 'customer.login.title' | t }}</h1>

      {%- form 'customer_login', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-error">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="form-field">
          <label for="customer-email">{{ 'customer.login.email' | t }}</label>
          <input type="email" id="customer-email" name="customer[email]" autocomplete="email" autocorrect="off" autocapitalize="off" required>
        </div>
        <div class="form-field">
          <label for="customer-password">{{ 'customer.login.password' | t }}</label>
          <input type="password" id="customer-password" name="customer[password]" autocomplete="current-password" required>
        </div>
        <div class="auth-form__actions">
          <button type="submit" class="btn-primary auth-form__submit">{{ 'customer.login.sign_in' | t }}</button>
          <a href="{{ routes.account_recover_url }}" class="auth-form__link">{{ 'customer.login.forgot_password' | t }}</a>
        </div>
      {%- endform -%}

      <div class="auth-card__alt">
        <p>{{ 'customer.login.create_account_prompt' | t }}</p>
        <a href="{{ routes.account_register_url }}" class="btn-ghost">{{ 'customer.register.submit' | t }}</a>
      </div>
    </div>
  </div>
</div>

<style>
  .auth-page { padding: var(--section-spacing) 0; display: flex; align-items: center; min-height: 60vh; }
  .auth-card { max-width: 480px; margin: 0 auto; width: 100%; border: 1px solid var(--border); padding: 56px; }
  .auth-card__title { font-family: var(--ff-display); font-size: 28px; font-weight: 300; margin-bottom: 40px; text-align: center; }
  .auth-form { display: flex; flex-direction: column; gap: 20px; }
  .auth-form__actions { display: flex; flex-direction: column; gap: 16px; align-items: center; margin-top: 8px; }
  .auth-form__submit { width: 100%; font-size: 11px; letter-spacing: 0.25em; padding: 16px; }
  .auth-form__link { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--muted); transition: all 0.2s; }
  .auth-form__link:hover { color: var(--gold); border-bottom-color: var(--gold); }
  .auth-error { background: rgba(122, 32, 32, 0.3); border: 1px solid var(--sale-bg); padding: 12px 16px; font-size: 13px; color: var(--sale-text); }
  .auth-card__alt { margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--border); text-align: center; display: flex; flex-direction: column; gap: 16px; align-items: center; }
  .auth-card__alt p { font-size: 13px; opacity: 0.6; }
  @media (max-width: 640px) { .auth-card { padding: 32px 24px; } }
</style>

{% schema %}
{
  "name": "Login",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Login" }]
}
{% endschema %}
