<div class="contact-page" id="section-{{ section.id }}">
  <div class="container">
    <div class="contact-inner contact-inner--{{ section.settings.layout }}">

      <div class="contact-info">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h1 class="contact-title">{{ page.title | default: section.settings.heading }}</h1>
        {%- if section.settings.intro != blank -%}
          <p class="contact-intro">{{ section.settings.intro }}</p>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'detail' -%}
              <div class="contact-detail" {{ block.shopify_attributes }}>
                {%- if block.settings.label != blank -%}
                  <p class="contact-detail__label">{{ block.settings.label }}</p>
                {%- endif -%}
                {%- if block.settings.value != blank -%}
                  <p class="contact-detail__value">{{ block.settings.value }}</p>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      <div class="contact-form-wrap">
        {%- form 'contact', id: 'contact-form', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-success">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="16 12 12 8 8 12"/><line x1="12" y1="16" x2="12" y2="8"/></svg>
              <p>{{ 'contact.form.success' | t }}</p>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <p class="contact-error">{{ 'contact.form.error' | t }}</p>
            {%- endif -%}
            <div class="contact-form__row">
              <div class="form-field">
                <label for="contact-name">{{ 'contact.form.name' | t }}</label>
                <input type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>
              </div>
              <div class="form-field">
                <label for="contact-email">{{ 'contact.form.email' | t }}</label>
                <input type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
              </div>
            </div>
            {%- if section.settings.show_phone -%}
              <div class="form-field">
                <label for="contact-phone">{{ 'contact.form.phone' | t }}</label>
                <input type="tel" id="contact-phone" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
              </div>
            {%- endif -%}
            <div class="form-field">
              <label for="contact-subject">{{ 'contact.form.subject' | t | default: 'Subject' }}</label>
              <input type="text" id="contact-subject" name="contact[subject]">
            </div>
            <div class="form-field">
              <label for="contact-message">{{ 'contact.form.message' | t }}</label>
              <textarea id="contact-message" name="contact[body]" rows="{{ section.settings.textarea_rows }}" required>{{ form.body }}</textarea>
            </div>
            <button type="submit" class="btn-primary contact-form__submit">{{ 'contact.form.send' | t }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </div>
</div>

<style>
  .contact-page { padding: var(--section-spacing) 0; }
  .contact-inner { display: grid; gap: 64px; align-items: flex-start; }
  .contact-inner--split { grid-template-columns: 1fr 1.4fr; }
  .contact-inner--centered { grid-template-columns: 1fr; max-width: 680px; margin: 0 auto; }
  .contact-title { font-family: var(--ff-display); font-size: clamp(28px, 3vw, 48px); font-weight: 300; margin: 16px 0 24px; }
  .contact-intro { font-size: 14px; line-height: 1.8; opacity: 0.6; margin-bottom: 40px; }
  .contact-detail { margin-bottom: 28px; }
  .contact-detail__label { font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  .contact-detail__value { font-size: 14px; line-height: 1.6; opacity: 0.8; }
  .contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .contact-form__submit { margin-top: 8px; font-size: 11px; letter-spacing: 0.25em; padding: 16px 36px; }
  .contact-success { display: flex; align-items: center; gap: 16px; padding: 32px; border: 1px solid var(--border); }
  .contact-success p { font-size: 14px; color: var(--cream); }
  .contact-error { color: var(--sale-text); font-size: 13px; margin-bottom: 20px; }
  @media (max-width: 900px) {
    .contact-inner--split { grid-template-columns: 1fr; }
    .contact-form__row { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Contact",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",         "default": "Get in Touch" },
    { "type": "text",     "id": "heading",  "label": "Heading Fallback", "default": "Contact Us" },
    { "type": "textarea", "id": "intro",    "label": "Intro Text" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "split",    "label": "Split (info + form)" },
        { "value": "centered", "label": "Centered form only" }
      ],
      "default": "split"
    },
    { "type": "checkbox", "id": "show_phone",    "label": "Show Phone Field",   "default": false },
    { "type": "range",    "id": "textarea_rows", "label": "Message Field Rows", "min": 4, "max": 12, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Contact Detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "value", "label": "Value", "default": "hello@maisonnoir.com" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact",
      "blocks": [
        { "type": "detail", "settings": { "label": "Email", "value": "hello@maisonnoir.com" } },
        { "type": "detail", "settings": { "label": "Phone", "value": "+1 (555) 000-0000" } },
        { "type": "detail", "settings": { "label": "Address", "value": "123 Fashion Ave, New York, NY 10001" } }
      ]
    }
  ]
}
{% endschema %}
