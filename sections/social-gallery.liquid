{%- liquid
  assign s = section.settings
  assign fb1 = 'https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=700&q=80'
  assign fb2 = 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=700&q=80'
  assign fb3 = 'https://images.unsplash.com/photo-1492707892479-7bc8d5a4ee93?auto=format&fit=crop&w=700&q=80'
  assign fb4 = 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=700&q=80'
  assign fb5 = 'https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=700&q=80'
  assign fb6 = 'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=700&q=80'
-%}

<section
  id="section-{{ section.id }}"
  class="sgl-section sgl--{{ s.scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="sgl-head reveal">
    {%- if s.eyebrow != blank -%}<span class="sgl-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="sgl-heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.btn_label != blank -%}
      <a href="{{ s.btn_url | default: '#' }}" class="sgl-follow" target="_blank" rel="noopener">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="currentColor" stroke-width="1.4"/><circle cx="12" cy="12" r="4.4" stroke="currentColor" stroke-width="1.4"/><circle cx="17.6" cy="6.5" r="1.2" fill="currentColor"/></svg>
        {{ s.btn_label }}
      </a>
    {%- endif -%}
  </div>

  <div class="sgl-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        case forloop.index
          when 1
            assign fb = fb1
          when 2
            assign fb = fb2
          when 3
            assign fb = fb3
          when 4
            assign fb = fb4
          when 5
            assign fb = fb5
          else
            assign fb = fb6
        endcase
      -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="sgl-tile reveal"
        target="_blank" rel="noopener"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 700 | image_tag:
            loading: 'lazy', class: 'sgl-tile__img', sizes: '(max-width:700px) 50vw, 17vw',
            widths: '350,700', alt: '' }}
        {%- else -%}
          <img class="sgl-tile__img" src="{{ fb }}" alt="" loading="lazy" />
        {%- endif -%}
        <span class="sgl-tile__overlay" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7.5-4.9-10-9.5C.4 8 2 4.5 5.5 4 7.7 3.7 9.6 4.8 12 7.3 14.4 4.8 16.3 3.7 18.5 4 22 4.5 23.6 8 22 11.5 19.5 16.1 12 21 12 21z" fill="#fff"/></svg>
        </span>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  #section-{{ section.id }}.sgl--light { --gbg:#F4EFE6; --gfg:#1C1814; --gacc:var(--gold,#A4552F); --gmut:rgba(28,24,20,.55); --gbdr:rgba(28,24,20,.16); }
  #section-{{ section.id }}.sgl--dark  { --gbg:#14100C; --gfg:#F2EDE4; --gacc:var(--gold,#D9986B); --gmut:rgba(242,237,228,.6); --gbdr:rgba(242,237,228,.2); }
  #section-{{ section.id }}.sgl--warm  { --gbg:#E7DCCB; --gfg:#2A2118; --gacc:var(--gold,#8E4F2A); --gmut:rgba(42,33,24,.55); --gbdr:rgba(42,33,24,.2); }
  #section-{{ section.id }}.sgl--theme {
    --gbg:var(--background,#14100C); --gfg:var(--foreground,#F2EDE4);
    --gacc:var(--gold,#C8A96E); --gmut:var(--muted,rgba(242,237,228,.6));
    --gbdr:var(--border-strong,rgba(242,237,228,.2));
  }

  #section-{{ section.id }} {
    background: var(--gbg);
    padding: var(--section-spacing, 80px) 0 0;
  }
  .sgl-head {
    text-align: center; padding: 0 var(--side-padding, 5vw);
    margin-bottom: clamp(32px, 5vw, 52px);
  }
  .sgl-eyebrow {
    display: inline-block;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 11px; font-weight: 500; letter-spacing: .26em; text-transform: uppercase;
    color: var(--gacc); margin-bottom: 14px;
  }
  .sgl-heading {
    font-family: var(--ff-display,'Cormorant Garamond',serif);
    font-size: calc(clamp(30px, 4vw, 54px) * var(--heading-scale, 1)); font-weight: 300; line-height: 1.05;
    color: var(--gfg); margin: 0;
  }
  .sgl-follow {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 22px;
    font-family: var(--ff-body,'Outfit',sans-serif);
    font-size: 11px; font-weight: 500; letter-spacing: .16em; text-transform: uppercase;
    color: var(--gfg); text-decoration: none;
    border: 1px solid var(--gbdr); border-radius: 999px;
    padding: 12px 26px;
    transition: background .25s, color .25s, border-color .25s;
  }
  .sgl-follow:hover { background: var(--gfg); color: var(--gbg); border-color: var(--gfg); }

  .sgl-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
  }
  .sgl-tile {
    position: relative; display: block; overflow: hidden;
    aspect-ratio: 1 / 1; background: #cbbfa9;
  }
  .sgl-tile__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .6s ease;
  }
  .sgl-tile:hover .sgl-tile__img { transform: scale(1.07); }
  .sgl-tile__overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(20,16,12,.42);
    opacity: 0; transition: opacity .35s ease;
  }
  .sgl-tile:hover .sgl-tile__overlay { opacity: 1; }

  @media (max-width: 900px) { .sgl-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 540px) { .sgl-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

{% schema %}
{
  "name": "Social Gallery",
  "tag": "section",
  "class": "section-social-gallery",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (sand)" },
        { "value": "dark",  "label": "Dark (espresso)" },
        { "value": "warm",  "label": "Warm (deep sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@maisonnoir" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "As Worn by You" },
    { "type": "text", "id": "btn_label", "label": "Follow button label", "default": "Follow on Instagram" },
    { "type": "url",  "id": "btn_url",   "label": "Follow button link" }
  ],
  "blocks": [
    {
      "type": "tile", "name": "Photo tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Social Gallery",
      "blocks": [
        { "type": "tile" }, { "type": "tile" }, { "type": "tile" },
        { "type": "tile" }, { "type": "tile" }, { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
