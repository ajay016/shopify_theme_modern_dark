{%- liquid
  assign s = section.settings
  assign scheme_class = 'nmin--' | append: s.scheme
  assign form_id = 'nmin-form-' | append: section.id
-%}

<section
  id="section-{{ section.id }}"
  class="nmin-section {{ scheme_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="nmin-inner">

    <!-- Top rule + label -->
    <div class="nmin-top reveal">
      {%- if s.label != blank -%}
        <span class="nmin-label">{{ s.label }}</span>
      {%- endif -%}
    </div>

    <!-- Central content -->
    <div class="nmin-content reveal">
      {%- if s.heading != blank -%}
        <h2 class="nmin-heading">
          {%- assign parts = s.heading | split: '|' -%}
          {%- for part in parts -%}
            {%- if forloop.index == 2 -%}<em>{{ part | strip }}</em>
            {%- else -%}{{ part | strip }}
            {%- endif -%}
            {%- unless forloop.last %} {% endunless -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}

      {%- if s.subtext != blank -%}
        <p class="nmin-sub">{{ s.subtext }}</p>
      {%- endif -%}
    </div>

    <!-- Form -->
    <div class="nmin-form-wrap reveal">
      {%- form 'customer', id: form_id, class: 'nmin-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter" />
        <div class="nmin-field">
          <input
            type="email"
            name="contact[email]"
            id="nmin-email-{{ section.id }}"
            class="nmin-input"
            placeholder="{{ s.placeholder | default: 'Enter your email' }}"
            required
            autocomplete="email"
          />
          <button type="submit" class="nmin-btn" aria-label="{{ s.btn_label | default: 'Subscribe' }}">
            <span class="nmin-btn__label">{{ s.btn_label | default: 'Subscribe' }}</span>
            <span class="nmin-btn__arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="nmin-success">{{ s.success_msg | default: 'Thank you for subscribing.' }}</p>
        {%- elsif form.errors -%}
          <p class="nmin-error">{{ form.errors.translated_fields.first | capitalize }} {{ form.errors.messages.first }}</p>
        {%- endif -%}
      {%- endform -%}

      {%- if s.disclaimer != blank -%}
        <p class="nmin-disclaimer">{{ s.disclaimer }}</p>
      {%- endif -%}
    </div>

    <!-- Bottom rule + extras -->
    {%- if s.show_footer -%}
      <div class="nmin-footer reveal">
        <span class="nmin-footer__brand">{{ s.footer_text }}</span>
        {%- if s.footer_links != blank -%}
          <div class="nmin-footer__links">
            {%- assign flinks = s.footer_links | split: ',' -%}
            {%- for flink in flinks -%}
              <span>{{ flink | strip }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ── Scheme variables ─────────────────────────────── */
  #section-{{ section.id }}.nmin--light {
    --nbg: var(--ivory, #FAF8F3);
    --nfg: var(--black, #0A0A0A);
    --nacc: #9B7B3F;
    --nmut: rgba(10,10,10,0.38);
    --nbdr: rgba(10,10,10,0.14);
    --ninput-bg: transparent;
    --nbtn-bg: var(--black, #0A0A0A);
    --nbtn-fg: var(--ivory, #FAF8F3);
  }
  #section-{{ section.id }}.nmin--dark {
    --nbg: var(--black, #0A0A0A);
    --nfg: var(--cream, #F5F0E8);
    --nacc: var(--gold, #C8A96E);
    --nmut: rgba(245,240,232,0.4);
    --nbdr: rgba(245,240,232,0.12);
    --ninput-bg: transparent;
    --nbtn-bg: var(--gold, #C8A96E);
    --nbtn-fg: var(--black, #0A0A0A);
  }
  #section-{{ section.id }}.nmin--warm {
    --nbg: #EDE5D8;
    --nfg: #2C1F14;
    --nacc: #8B5E3C;
    --nmut: rgba(44,31,20,0.4);
    --nbdr: rgba(44,31,20,0.15);
    --ninput-bg: transparent;
    --nbtn-bg: #2C1F14;
    --nbtn-fg: #EDE5D8;
  }
  #section-{{ section.id }}.nmin--theme {
    --nbg: var(--background, #0A0A0A);
    --nfg: var(--foreground, #F5F0E8);
    --nacc: var(--gold, #C8A96E);
    --nmut: var(--muted, rgba(245,240,232,0.4));
    --nbdr: var(--border, rgba(245,240,232,0.1));
    --ninput-bg: transparent;
    --nbtn-bg: var(--gold, #C8A96E);
    --nbtn-fg: var(--black, #0A0A0A);
  }

  /* ── Base ─────────────────────────────────────────── */
  #section-{{ section.id }} {
    background: var(--nbg);
    color: var(--nfg);
    padding: clamp(80px, 10vw, 140px) var(--side-padding, 5vw);
  }
  .nmin-inner {
    max-width: min(720px, calc(var(--container-width, 1400px) * .55));
    margin: 0 auto;
    text-align: center;
  }

  /* ── Top rule ─────────────────────────────────────── */
  .nmin-top {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 52px;
  }
  .nmin-top::before,
  .nmin-top::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--nbdr);
  }
  .nmin-label {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--nmut);
    white-space: nowrap;
  }

  /* ── Content ──────────────────────────────────────── */
  .nmin-content { margin-bottom: 44px; }

  .nmin-heading {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(42px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -.01em;
    color: var(--nfg);
    margin: 0 0 20px;
  }
  .nmin-heading em {
    font-style: italic;
    color: var(--nacc);
  }

  .nmin-sub {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: clamp(13px, 1.2vw, 16px);
    line-height: 1.7;
    color: var(--nmut);
    margin: 0;
    max-width: 480px;
    margin-inline: auto;
  }

  /* ── Form ─────────────────────────────────────────── */
  .nmin-form-wrap { margin-bottom: 24px; }

  .nmin-form { display: flex; flex-direction: column; align-items: center; gap: 0; }

  .nmin-field {
    display: flex;
    align-items: stretch;
    border-bottom: 1.5px solid var(--nfg);
    width: 100%;
    max-width: 480px;
    margin-bottom: 16px;
  }

  .nmin-input {
    flex: 1;
    background: var(--ninput-bg);
    border: none;
    outline: none;
    color: var(--nfg);
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 14px;
    letter-spacing: .04em;
    padding: 14px 0;
    min-width: 0;
  }
  .nmin-input::placeholder { color: var(--nmut); }

  .nmin-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--nfg);
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .16em;
    text-transform: uppercase;
    padding: 14px 0 14px 20px;
    transition: color .2s;
  }
  .nmin-btn:hover { color: var(--nacc); }
  .nmin-btn__arrow { display: flex; align-items: center; transition: transform .25s; }
  .nmin-btn:hover .nmin-btn__arrow { transform: translateX(4px); }

  .nmin-success {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 12px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--nacc);
    margin: 0;
  }
  .nmin-error {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 12px;
    color: #c0392b;
    margin: 0;
  }

  .nmin-disclaimer {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 10px;
    letter-spacing: .06em;
    color: var(--nmut);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Footer ───────────────────────────────────────── */
  .nmin-footer {
    margin-top: 52px;
    padding-top: 24px;
    border-top: 1px solid var(--nbdr);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .nmin-footer__brand {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: 13px;
    letter-spacing: .12em;
    color: var(--nmut);
    font-style: italic;
  }
  .nmin-footer__links {
    display: flex;
    gap: 24px;
  }
  .nmin-footer__links span {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--nmut);
  }

  /* ── Reveal ───────────────────────────────────────── */
  .nmin-section .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
  .nmin-section .reveal.is-visible { opacity: 1; transform: none; }
  .nmin-section .reveal:nth-child(2) { transition-delay: .1s; }
  .nmin-section .reveal:nth-child(3) { transition-delay: .2s; }
  .nmin-section .reveal:nth-child(4) { transition-delay: .3s; }
</style>

<script>
(function () {
  var SEC = '{{ section.id }}';

  function init(root) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15 });
    root.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
  }

  function getRoot() { return document.getElementById('section-' + SEC); }

  document.addEventListener('DOMContentLoaded', function () { var r = getRoot(); if (r) init(r); });

  document.addEventListener('shopify:section:load',   function (e) { if (e.detail.sectionId !== SEC) return; var r = getRoot(); if (r) { init(r); r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); }); } });
  document.addEventListener('shopify:section:select', function (e) { if (e.detail.sectionId !== SEC) return; var r = getRoot(); if (r) r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); }); });
})();
</script>

{% schema %}
{
  "name": "Newsletter Minimal",
  "tag": "section",
  "class": "section-newsletter-minimal",
  "settings": [
    {
      "type": "select",
      "id": "scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Rule label",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (use | to italicise second word group)",
      "default": "Join the | Inner Circle"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be the first to know about new collections, exclusive events, and private sales."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Success message",
      "default": "Thank you for subscribing."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "By subscribing you agree to our Privacy Policy. Unsubscribe at any time."
    },
    {
      "type": "header",
      "content": "Footer strip"
    },
    {
      "type": "checkbox",
      "id": "show_footer",
      "label": "Show footer strip",
      "default": true
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer brand text",
      "default": "Maison Noir — Est. 2009"
    },
    {
      "type": "text",
      "id": "footer_links",
      "label": "Footer links (comma-separated)",
      "default": "Privacy Policy, Shipping, Returns"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Minimal",
      "settings": {
        "label": "Stay Connected",
        "heading": "Join the | Inner Circle",
        "subtext": "Be the first to know about new collections, exclusive events, and private sales.",
        "btn_label": "Subscribe",
        "show_footer": true
      }
    }
  ]
}
{% endschema %}
