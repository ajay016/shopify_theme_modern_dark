{%- liquid
  assign s = section.settings
  assign scheme_class = 'ptbl--' | append: s.scheme
  assign collection = collections[s.collection]
  assign product_limit = s.products_to_show | default: 8
-%}

<section
  id="section-{{ section.id }}"
  class="ptbl-section {{ scheme_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="ptbl-inner">

    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="ptbl-header reveal">
        {%- if s.eyebrow != blank -%}
          <span class="ptbl-eyebrow">{{ s.eyebrow }}</span>
        {%- endif -%}
        <div class="ptbl-header__row">
          {%- if s.heading != blank -%}
            <h2 class="ptbl-heading">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.view_all_label != blank -%}
            <a href="{{ collection.url | default: '/collections/all' }}" class="ptbl-view-all">
              {{ s.view_all_label }}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Column headers -->
    <div class="ptbl-cols reveal">
      <span class="ptbl-col ptbl-col--num">#</span>
      <span class="ptbl-col ptbl-col--name">{{ s.col_name | default: 'Product' }}</span>
      <span class="ptbl-col ptbl-col--cat">{{ s.col_cat | default: 'Category' }}</span>
      <span class="ptbl-col ptbl-col--price">{{ s.col_price | default: 'Price' }}</span>
      <span class="ptbl-col ptbl-col--action"></span>
    </div>

    <!-- Table rows -->
    <div class="ptbl-rows">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: product_limit -%}
          {%- assign row_num = forloop.index | prepend: '0' | slice: -2, 2 -%}
          <div
            class="ptbl-row reveal"
            data-image="{{ product.featured_image | image_url: width: 600 }}"
            data-alt="{{ product.featured_image.alt | default: product.title | escape }}"
          >
            <span class="ptbl-row__num">{{ row_num }}</span>

            <div class="ptbl-row__name">
              <a href="{{ product.url }}" class="ptbl-row__title">{{ product.title }}</a>
              {%- if product.vendor != blank -%}
                <span class="ptbl-row__vendor">{{ product.vendor }}</span>
              {%- endif -%}
            </div>

            <span class="ptbl-row__cat">
              {%- if product.type != blank -%}
                {{ product.type }}
              {%- elsif product.tags.first != blank -%}
                {{ product.tags.first }}
              {%- endif -%}
            </span>

            <div class="ptbl-row__price">
              {%- if product.compare_at_price > product.price -%}
                <s class="ptbl-row__was">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
              <span class="ptbl-row__now {%- if product.compare_at_price > product.price %} is-sale{%- endif -%}">{{ product.price | money }}</span>
            </div>

            <a href="{{ product.url }}" class="ptbl-row__cta" aria-label="View {{ product.title }}">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          {%- assign row_num = i | prepend: '0' | slice: -2, 2 -%}
          {%- assign names = 'The Atelier Coat,Sculptural Blazer,Cashmere Turtleneck,Wide-Leg Trousers,Silk Midi Dress,Tailored Waistcoat' | split: ',' -%}
          {%- assign cats = "Outerwear,Tailoring,Knitwear,Trousers,Dresses,Tailoring" | split: ',' -%}
          {%- assign prices = '$1,290,$ 890,$ 640,$ 580,$ 740,$ 420' | split: ',' -%}
          <div class="ptbl-row reveal" data-image="" data-alt="">
            <span class="ptbl-row__num">{{ row_num }}</span>
            <div class="ptbl-row__name">
              <span class="ptbl-row__title">{{ names[forloop.index0] }}</span>
              <span class="ptbl-row__vendor">Maison Noir</span>
            </div>
            <span class="ptbl-row__cat">{{ cats[forloop.index0] }}</span>
            <div class="ptbl-row__price">
              <span class="ptbl-row__now">{{ prices[forloop.index0] }}</span>
            </div>
            <span class="ptbl-row__cta" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>

  <!-- Floating image preview (follows cursor) -->
  <div class="ptbl-float" id="ptbl-float-{{ section.id }}" aria-hidden="true">
    <img class="ptbl-float__img" src="" alt="" />
  </div>
</section>

<style>
  /* ── Scheme ─────────────────────────────────────── */
  #section-{{ section.id }}.ptbl--light {
    --pbg: var(--ivory, #FAF8F3);
    --pfg: var(--black, #0A0A0A);
    --pacc: #9B7B3F;
    --pmut: rgba(10,10,10,0.4);
    --pbdr: rgba(10,10,10,0.12);
    --psale: #8B1A1A;
  }
  #section-{{ section.id }}.ptbl--dark {
    --pbg: var(--black, #0A0A0A);
    --pfg: var(--cream, #F5F0E8);
    --pacc: var(--gold, #C8A96E);
    --pmut: rgba(245,240,232,0.4);
    --pbdr: rgba(245,240,232,0.1);
    --psale: #E8A0A0;
  }
  #section-{{ section.id }}.ptbl--warm {
    --pbg: #F0EBE0;
    --pfg: #2C1F14;
    --pacc: #8B5E3C;
    --pmut: rgba(44,31,20,0.4);
    --pbdr: rgba(44,31,20,0.13);
    --psale: #8B1A1A;
  }
  #section-{{ section.id }}.ptbl--theme {
    --pbg: var(--background, #0A0A0A);
    --pfg: var(--foreground, #F5F0E8);
    --pacc: var(--gold, #C8A96E);
    --pmut: var(--muted, rgba(245,240,232,0.4));
    --pbdr: var(--border, rgba(245,240,232,0.1));
    --psale: #E8A0A0;
  }

  /* ── Base ────────────────────────────────────────── */
  #section-{{ section.id }} {
    background: var(--pbg);
    color: var(--pfg);
    padding: clamp(64px, 8vw, 120px) var(--side-padding, 5vw);
  }
  .ptbl-inner { max-width: var(--container-width, 1400px); margin: 0 auto; }

  /* ── Header ──────────────────────────────────────── */
  .ptbl-header { margin-bottom: 48px; }
  .ptbl-eyebrow {
    display: block;
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--pacc);
    margin-bottom: 12px;
  }
  .ptbl-header__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
  }
  .ptbl-heading {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(32px, 3.5vw, 54px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--pfg);
    margin: 0;
  }
  .ptbl-view-all {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase;
    color: var(--pmut);
    text-decoration: none;
    transition: color .2s;
    white-space: nowrap;
  }
  .ptbl-view-all:hover { color: var(--pfg); }

  /* ── Column headers ──────────────────────────────── */
  .ptbl-cols {
    display: grid;
    grid-template-columns: 44px 1fr 160px 120px 40px;
    gap: 0 24px;
    padding: 0 0 14px;
    border-bottom: 1px solid var(--pbdr);
    margin-bottom: 0;
  }
  .ptbl-col {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--pmut);
  }
  .ptbl-col--price, .ptbl-col--action { text-align: right; }
  .ptbl-col--cat { display: none; }
  @media (min-width: 768px) { .ptbl-col--cat { display: block; } }

  /* ── Rows ────────────────────────────────────────── */
  .ptbl-row {
    display: grid;
    grid-template-columns: 44px 1fr 120px 40px;
    gap: 0 24px;
    align-items: center;
    padding: 22px 0;
    border-bottom: 1px solid var(--pbdr);
    cursor: pointer;
    transition: background .18s;
    position: relative;
  }
  @media (min-width: 768px) {
    .ptbl-row { grid-template-columns: 44px 1fr 160px 120px 40px; }
  }
  .ptbl-row:hover { background: rgba(from var(--pfg) r g b / 0.03); }

  .ptbl-row__num {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: 13px;
    letter-spacing: .08em;
    color: var(--pmut);
    transition: color .2s;
  }
  .ptbl-row:hover .ptbl-row__num { color: var(--pacc); }

  .ptbl-row__name {
    display: flex; flex-direction: column; gap: 3px;
  }
  .ptbl-row__title {
    font-family: var(--ff-display, 'Cormorant Garamond', serif);
    font-size: clamp(16px, 1.8vw, 24px);
    font-weight: 400;
    color: var(--pfg);
    text-decoration: none;
    transition: font-style .2s;
  }
  .ptbl-row:hover .ptbl-row__title { font-style: italic; }
  .ptbl-row__title::after { content: ''; position: absolute; inset: 0; z-index: 0; }

  .ptbl-row__vendor {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--pmut);
  }

  .ptbl-row__cat {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 12px;
    letter-spacing: .08em;
    color: var(--pmut);
    display: none;
  }
  @media (min-width: 768px) { .ptbl-row__cat { display: block; } }

  .ptbl-row__price {
    display: flex; flex-direction: column; gap: 2px; text-align: right;
  }
  .ptbl-row__was {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 11px;
    color: var(--pmut);
    text-decoration: line-through;
  }
  .ptbl-row__now {
    font-family: var(--ff-body, 'Outfit', sans-serif);
    font-size: 14px;
    font-weight: 500;
    color: var(--pfg);
  }
  .ptbl-row__now.is-sale { color: var(--psale); }

  .ptbl-row__cta {
    display: flex; align-items: center; justify-content: flex-end;
    color: var(--pmut);
    text-decoration: none;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity .2s, transform .2s, color .2s;
    position: relative; z-index: 1;
  }
  .ptbl-row:hover .ptbl-row__cta { opacity: 1; transform: translateX(0); color: var(--pacc); }

  /* ── Floating preview image ─────────────────────── */
  .ptbl-float {
    position: fixed;
    pointer-events: none;
    z-index: 200;
    width: clamp(160px, 18vw, 260px);
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 2px;
    opacity: 0;
    transform: scale(.94) translateY(10px);
    transition: opacity .3s, transform .3s;
    box-shadow: 0 20px 60px rgba(0,0,0,.25);
  }
  .ptbl-float.is-visible { opacity: 1; transform: scale(1) translateY(0); }

  .ptbl-float__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Reveal ──────────────────────────────────────── */
  .ptbl-section .reveal { opacity: 0; transform: translateY(18px); transition: opacity .55s ease, transform .55s ease; }
  .ptbl-section .reveal.is-visible { opacity: 1; transform: none; }
</style>

<script>
(function () {
  var SEC = '{{ section.id }}';

  function init(root) {
    var floatEl   = document.getElementById('ptbl-float-' + SEC);
    var floatImg  = floatEl && floatEl.querySelector('.ptbl-float__img');
    var rows      = root.querySelectorAll('.ptbl-row');
    var mx = 0, my = 0;

    if (!floatEl) return;

    document.addEventListener('mousemove', function (e) {
      mx = e.clientX; my = e.clientY;
      floatEl.style.left = (mx + 24) + 'px';
      floatEl.style.top  = (my - 40) + 'px';
    });

    rows.forEach(function (row) {
      var src = row.dataset.image;
      var alt = row.dataset.alt || '';

      row.addEventListener('mouseenter', function () {
        if (!src) return;
        floatImg.src = src;
        floatImg.alt = alt;
        floatEl.classList.add('is-visible');
      });
      row.addEventListener('mouseleave', function () {
        floatEl.classList.remove('is-visible');
      });
    });

    /* reveal */
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    root.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
  }

  function getRoot() { return document.getElementById('section-' + SEC); }

  document.addEventListener('DOMContentLoaded', function () { var r = getRoot(); if (r) init(r); });

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail.sectionId !== SEC) return;
    var r = getRoot(); if (r) { init(r); r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); }); }
  });
  document.addEventListener('shopify:section:select', function (e) {
    if (e.detail.sectionId !== SEC) return;
    var r = getRoot(); if (r) r.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('is-visible'); });
  });
})();
</script>

{% schema %}
{
  "name": "Products Table",
  "tag": "section",
  "class": "section-products-table",
  "settings": [
    {
      "type": "select",
      "id": "scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated Edit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This Season's Icons"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all products"
    },
    {
      "type": "header",
      "content": "Column labels"
    },
    {
      "type": "text",
      "id": "col_name",
      "label": "Name column",
      "default": "Product"
    },
    {
      "type": "text",
      "id": "col_cat",
      "label": "Category column",
      "default": "Category"
    },
    {
      "type": "text",
      "id": "col_price",
      "label": "Price column",
      "default": "Price"
    }
  ],
  "presets": [
    {
      "name": "Products Table",
      "settings": {
        "eyebrow": "Curated Edit",
        "heading": "This Season's Icons",
        "products_to_show": 8,
        "view_all_label": "View all products"
      }
    }
  ]
}
{% endschema %}
