<section class="section testimonials" id="section-{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-head__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__grid testimonials__grid--{{ section.settings.columns }}">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            {%- if section.settings.show_stars -%}
              <div class="testimonial-card__stars" aria-label="5 stars">
                {%- for i in (1..5) -%}<span class="star">★</span>{%- endfor -%}
              </div>
            {%- endif -%}
            <blockquote class="testimonial-card__quote">{{ block.settings.quote }}</blockquote>
            <div class="testimonial-card__author">
              {%- if block.settings.avatar -%}
                {{
                  block.settings.avatar
                  | image_url: width: 80
                  | image_tag: class: 'testimonial-card__avatar', loading: 'lazy', alt: block.settings.name
                }}
              {%- endif -%}
              <div>
                <p class="testimonial-card__name">{{ block.settings.name }}</p>
                {%- if block.settings.location != blank -%}
                  <p class="testimonial-card__location">{{ block.settings.location }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .testimonials { padding: var(--section-spacing) 0; }
  .testimonials__grid { display: grid; gap: 24px; }
  .testimonials__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .testimonials__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .testimonials__grid--4 { grid-template-columns: repeat(4, 1fr); }
  .testimonial-card {
    background: var(--charcoal); padding: 40px 36px; border: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 24px;
  }
  .testimonial-card__stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }
  .testimonial-card__quote { font-family: var(--ff-display); font-size: 16px; font-weight: 300; line-height: 1.7; font-style: italic; color: var(--cream); }
  .testimonial-card__author { display: flex; align-items: center; gap: 12px; margin-top: auto; }
  .testimonial-card__avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
  .testimonial-card__name { font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--cream); }
  .testimonial-card__location { font-size: 11px; color: var(--cream); opacity: 0.6; letter-spacing: 0.1em; margin-top: 2px; }
  @media (max-width: 900px) {
    .testimonials__grid--3, .testimonials__grid--4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .testimonials__grid--2, .testimonials__grid--3, .testimonials__grid--4 { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",     "default": "Client Stories" },
    { "type": "text",     "id": "heading",    "label": "Heading",     "default": "What They Say" },
    { "type": "checkbox", "id": "show_stars", "label": "Show Stars",  "default": true },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea",     "id": "quote",    "label": "Quote",    "default": "An exceptional experience from start to finish. The quality is simply unparalleled." },
        { "type": "text",         "id": "name",     "label": "Name",     "default": "Alexandra M." },
        { "type": "text",         "id": "location", "label": "Location", "default": "New York" },
        { "type": "image_picker", "id": "avatar",   "label": "Avatar" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
