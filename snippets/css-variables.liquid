<style>
  :root {
    /* ── Color Scheme Presets ───────────────────────────────────── */
    {%- liquid
      case settings.color_scheme
        when 'light'
          assign sc_black    = '#FFFFFF'
          assign sc_charcoal = '#F5F2EC'
          assign sc_cream    = '#1A1A1A'
          assign sc_gold     = '#9B7B3F'
          assign sc_gold_l   = '#C8A96E'
          assign sc_muted    = '#8A8480'
          assign sc_ivory    = '#0A0A0A'
          assign sc_sale     = '#8B1A1A'
          assign sc_sale_bg  = '#FFD5D5'
        when 'warm'
          assign sc_black    = '#1C1410'
          assign sc_charcoal = '#2A2018'
          assign sc_cream    = '#EDE0CC'
          assign sc_gold     = '#C8965A'
          assign sc_gold_l   = '#E4BF8C'
          assign sc_muted    = '#8A7A68'
          assign sc_ivory    = '#F5EDD8'
          assign sc_sale     = '#FFBABA'
          assign sc_sale_bg  = '#7A2020'
        when 'custom'
          assign sc_black    = settings.color_black
          assign sc_charcoal = settings.color_charcoal
          assign sc_cream    = settings.color_cream
          assign sc_gold     = settings.color_gold
          assign sc_gold_l   = settings.color_gold_light
          assign sc_muted    = settings.color_muted
          assign sc_ivory    = settings.color_ivory
          assign sc_sale     = settings.color_sale
          assign sc_sale_bg  = settings.color_sale_bg
        else
          assign sc_black    = '#0A0A0A'
          assign sc_charcoal = '#161616'
          assign sc_cream    = '#F5F0E8'
          assign sc_gold     = '#C8A96E'
          assign sc_gold_l   = '#E8D4A8'
          assign sc_muted    = '#6E6A66'
          assign sc_ivory    = '#FAF8F3'
          assign sc_sale     = '#FFBABA'
          assign sc_sale_bg  = '#7A2020'
      endcase
    -%}

    /* Brand Palette */
    --black:       {{ sc_black }};
    --charcoal:    {{ sc_charcoal }};
    --cream:       {{ sc_cream }};
    --gold:        {{ sc_gold }};
    --gold-light:  {{ sc_gold_l }};
    --muted:       {{ sc_muted }};
    --ivory:       {{ sc_ivory }};
    --sale-text:   {{ sc_sale }};
    --sale-bg:     {{ sc_sale_bg }};

    /* Derived semi-transparent values */
    --border:        {{ sc_gold | color_modify: 'alpha', 0.18 }};
    --border-strong: {{ sc_gold | color_modify: 'alpha', 0.35 }};
    --gold-dim:      {{ sc_gold | color_modify: 'alpha', 0.12 }};
    --gold-glow:     {{ sc_gold | color_modify: 'alpha', 0.08 }};
    --cream-faint:   {{ sc_cream | color_modify: 'alpha', 0.06 }};
    --black-overlay: {{ sc_black | color_modify: 'alpha', 0.75 }};

    /* Typography — fonts loaded via Google Fonts in theme.liquid */
    {%- liquid
      case settings.font_pairing
        when 'playfair_inter'
          assign ff_display = '"Playfair Display", Georgia, serif'
          assign ff_body    = 'Inter, system-ui, sans-serif'
        when 'libre_raleway'
          assign ff_display = '"Libre Baskerville", Georgia, serif'
          assign ff_body    = 'Raleway, system-ui, sans-serif'
        when 'dm_serif_dm_sans'
          assign ff_display = '"DM Serif Display", Georgia, serif'
          assign ff_body    = '"DM Sans", system-ui, sans-serif'
        else
          assign ff_display = '"Cormorant Garamond", Georgia, serif'
          assign ff_body    = 'Outfit, system-ui, sans-serif'
      endcase
    -%}
    --ff-display: {{ ff_display }};
    --ff-body:    {{ ff_body }};
    --fs-base:    {{ settings.type_body_size }}px;

    /* Layout */
    --container-width:   {{ settings.layout_container_width }};
    --section-spacing:   {{ settings.layout_section_spacing }}px;
    --side-padding:      {{ settings.layout_side_padding }}px;

    /* Transitions */
    --ease-out:  cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --ease-in:   cubic-bezier(0.55, 0.055, 0.675, 0.19);
    --transition: 0.3s var(--ease-out);

    /* Z-index layers — nav must be lower than drawers/modals */
    --z-base:    1;
    --z-raised:  10;
    --z-nav:     100;
    --z-overlay: 150;
    --z-drawer:  400;
    --z-modal:   500;
    --z-cursor:  9999;
  }
</style>
