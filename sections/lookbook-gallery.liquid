{%- liquid
  assign s = section.settings
  assign scheme_class = 'lkb--' | append: s.scheme
  assign fb = 'https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1100&q=85|https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?auto=format&fit=crop&w=1100&q=85|https://images.unsplash.com/photo-1542295669297-4d352b042bca?auto=format&fit=crop&w=900&q=85' | split: '|'
-%}

<section
  id="section-{{ section.id }}"
  class="lkb-section {{ scheme_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="lkb-inner">

    {%- if s.eyebrow != blank or s.heading != blank or s.cta_label != blank -%}
      <div class="lkb-head reveal">
        <div>
          {%- if s.eyebrow != blank -%}<span class="lkb-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="lkb-head__heading">{{ s.heading }}</h2>{%- endif -%}
        </div>
        {%- if s.cta_label != blank -%}
          <a href="{{ s.cta_url | default: '#' }}" class="lkb-head__cta">
            {{ s.cta_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lkb-grid">
      {%- for block in section.blocks -%}
        {%- assign img = fb[forloop.index0] | default: fb[0] -%}
        <a
          href="{{ block.settings.url | default: '#' }}"
          class="lkb-tile lkb-tile--{{ block.settings.size }} reveal"
          {{ block.shopify_attributes }}
        >
          <div class="lkb-tile__media">
            {%- if block.settings.image != blank -%}
              {%- assign lkb_alt = block.settings.label | escape -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                loading: 'lazy', class: 'lkb-tile__img', sizes: '(max-width:900px) 100vw, 40vw',
                widths: '500,800,1200', alt: lkb_alt }}
            {%- else -%}
              <img class="lkb-tile__img" src="{{ img }}" alt="{{ block.settings.label | escape }}" loading="lazy" />
            {%- endif -%}
          </div>
          <div class="lkb-tile__overlay">
            {%- if block.settings.tag != blank -%}<span class="lkb-tile__tag">{{ block.settings.tag }}</span>{%- endif -%}
            <div class="lkb-tile__foot">
              {%- if block.settings.label != blank -%}<span class="lkb-tile__label">{{ block.settings.label }}</span>{%- endif -%}
              {%- if block.settings.meta != blank -%}<span class="lkb-tile__meta">{{ block.settings.meta }}</span>{%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  #section-{{ section.id }}.lkb--light { --lbg:#FAF8F3; --lfg:#0A0A0A; --lacc:var(--gold,#9B7B3F); --lmut:rgba(10,10,10,.5); --lbdr:rgba(10,10,10,.12); }
  #section-{{ section.id }}.lkb--dark  { --lbg:#0A0A0A; --lfg:#F5F0E8; --lacc:var(--gold,#C8A96E); --lmut:rgba(245,240,232,.55); --lbdr:rgba(245,240,232,.1); }
  #section-{{ section.id }}.lkb--warm  { --lbg:#F0EBE0; --lfg:#2C1F14; --lacc:var(--gold,#8B5E3C); --lmut:rgba(44,31,20,.5); --lbdr:rgba(44,31,20,.13); }
  #section-{{ section.id }}.lkb--theme { --lbg:var(--background,#0A0A0A); --lfg:var(--foreground,#F5F0E8); --lacc:var(--gold,#C8A96E); --lmut:var(--muted,rgba(245,240,232,.55)); --lbdr:var(--border,rgba(245,240,232,.1)); }

  #section-{{ section.id }} { background: var(--lbg); color: var(--lfg); padding: var(--section-spacing,80px) var(--side-padding,5vw); }
  .lkb-inner { max-width: var(--container-width,1440px); margin: 0 auto; }

  .lkb-head { display:flex; align-items:flex-end; justify-content:space-between; gap:24px; margin-bottom: clamp(36px,4vw,60px); }
  .lkb-head__eyebrow { display:block; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.22em; text-transform:uppercase; color:var(--lacc); margin-bottom:12px; }
  .lkb-head__heading { font-family:var(--ff-display,'Cormorant Garamond',serif); font-size:clamp(32px,4vw,56px); font-weight:300; line-height:1.08; margin:0; }
  .lkb-head__cta { display:inline-flex; align-items:center; gap:8px; font-family:var(--ff-body,'Outfit',sans-serif); font-size:11px; font-weight:500; letter-spacing:.14em; text-transform:uppercase; color:var(--lmut); text-decoration:none; white-space:nowrap; transition:color .2s; }
  .lkb-head__cta:hover { color: var(--lfg); }

  /* Asymmetric editorial mosaic */
  .lkb-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: clamp(120px, 14vw, 200px);
    gap: clamp(12px, 1.4vw, 22px);
  }
  .lkb-tile { position: relative; overflow: hidden; border-radius: 3px; text-decoration: none; display: block; background: #2a2a2a; }
  .lkb-tile--tall  { grid-column: span 4; grid-row: span 3; }
  .lkb-tile--wide  { grid-column: span 8; grid-row: span 2; }
  .lkb-tile--sq    { grid-column: span 4; grid-row: span 2; }
  .lkb-tile--small { grid-column: span 4; grid-row: span 2; }

  .lkb-tile__media { position:absolute; inset:0; }
  .lkb-tile__img { width:100%; height:100%; object-fit:cover; display:block; transition: transform .8s cubic-bezier(.4,0,.2,1); }
  .lkb-tile:hover .lkb-tile__img { transform: scale(1.06); }

  .lkb-tile__overlay {
    position:absolute; inset:0; z-index:1;
    display:flex; flex-direction:column; justify-content:space-between;
    padding: 18px 20px;
    background: linear-gradient(180deg, rgba(10,10,10,.18) 0%, rgba(10,10,10,0) 30%, rgba(10,10,10,.6) 100%);
    opacity: .9; transition: opacity .3s;
  }
  .lkb-tile:hover .lkb-tile__overlay { opacity: 1; }
  .lkb-tile__tag { align-self:flex-start; font-family:var(--ff-body,'Outfit',sans-serif); font-size:9px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#0A0A0A; background:rgba(255,255,255,.92); padding:6px 11px; border-radius:2px; }
  .lkb-tile__foot { display:flex; flex-direction:column; gap:3px; transform: translateY(6px); opacity:.92; transition: transform .35s, opacity .35s; }
  .lkb-tile:hover .lkb-tile__foot { transform: none; opacity:1; }
  .lkb-tile__label { font-family:var(--ff-display,'Cormorant Garamond',serif); font-size:clamp(18px,2vw,26px); font-weight:400; color:#fff; }
  .lkb-tile__meta { font-family:var(--ff-body,'Outfit',sans-serif); font-size:10px; letter-spacing:.14em; text-transform:uppercase; color:rgba(255,255,255,.8); }

  .lkb-section .reveal.reveal-armed { opacity:0; transform:translateY(26px); transition: opacity .65s ease, transform .65s ease; }
  .lkb-section .reveal.is-visible { opacity:1; transform:none; }
  .lkb-grid .reveal:nth-child(2){transition-delay:.06s;}
  .lkb-grid .reveal:nth-child(3){transition-delay:.12s;}
  .lkb-grid .reveal:nth-child(4){transition-delay:.18s;}
  .lkb-grid .reveal:nth-child(5){transition-delay:.24s;}

  @media (max-width: 820px) {
    .lkb-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 44vw; }
    .lkb-tile--tall, .lkb-tile--wide, .lkb-tile--sq, .lkb-tile--small { grid-column: span 1; grid-row: span 1; }
    .lkb-tile--tall { grid-column: span 2; grid-row: span 1; }
  }
</style>

<script>
(function(){
  var SEC='{{ section.id }}';
  function init(root){
    var els=root.querySelectorAll('.reveal');
    els.forEach(function(el){el.classList.add('reveal-armed');});
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:.1});
    els.forEach(function(el){io.observe(el);});
    setTimeout(function(){els.forEach(function(el){el.classList.add('is-visible');});},700);
  }
  function getRoot(){return document.getElementById('section-'+SEC);}
  document.addEventListener('DOMContentLoaded',function(){var r=getRoot();if(r)init(r);});
  document.addEventListener('shopify:section:load',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r){init(r);r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});}});
  document.addEventListener('shopify:section:select',function(e){if(e.detail.sectionId!==SEC)return;var r=getRoot();if(r)r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});});
})();
</script>

{% schema %}
{
  "name": "Lookbook Gallery",
  "tag": "section",
  "class": "section-lookbook-gallery",
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (ivory)" },
        { "value": "dark",  "label": "Dark (black)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Lookbook" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Autumn Editorial" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View full lookbook" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Image tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select", "id": "size", "label": "Tile size",
          "options": [
            { "value": "tall",  "label": "Tall (feature)" },
            { "value": "wide",  "label": "Wide" },
            { "value": "sq",    "label": "Square" },
            { "value": "small", "label": "Small" }
          ],
          "default": "sq"
        },
        { "type": "text", "id": "tag", "label": "Tag pill" },
        { "type": "text", "id": "label", "label": "Label", "default": "Women's AW25" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "42 pieces" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Gallery",
      "blocks": [
        { "type": "tile", "settings": { "size": "tall",  "tag": "Featured", "label": "The Tailoring Edit", "meta": "Explore" } },
        { "type": "tile", "settings": { "size": "wide",  "label": "Outerwear", "meta": "64 pieces" } },
        { "type": "tile", "settings": { "size": "sq",    "label": "Knitwear", "meta": "38 pieces" } },
        { "type": "tile", "settings": { "size": "sq",    "label": "Accessories", "meta": "215 pieces" } }
      ]
    }
  ]
}
{% endschema %}
