{% liquid
  assign sidebar_position = section.settings.sidebar_position
  assign filter_style     = section.settings.filter_style
  assign columns          = section.settings.grid_columns | plus: 0
  assign view_default     = section.settings.view_default
  assign pagination_style = section.settings.pagination_style
  assign title_style      = section.settings.title_style
  assign products_per_page = section.settings.products_per_page
%}

{%- paginate collection.products by products_per_page -%}

<div class="collection-page" id="section-{{ section.id }}" data-sidebar="{{ sidebar_position }}" data-filter-style="{{ filter_style }}">

  {%- comment -%} Collection Title Area {%- endcomment -%}
  <div class="collection-title collection-title--{{ title_style }}">
    {%- case title_style -%}
      {%- when 'style-1' -%}
        <div class="container">
          <h1 class="collection-title__text">{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <div class="collection-title__desc rte">{{ collection.description }}</div>
          {%- endif -%}
        </div>
      {%- when 'style-2' -%}
        <div class="collection-title__banner" {% if collection.image %}style="background-image:url({{ collection.image | image_url: width: 1600 }})"{% endif %}>
          <div class="container">
            <h1 class="collection-title__text">{{ collection.title }}</h1>
          </div>
        </div>
      {%- when 'style-3' -%}
        <div class="container">
          <nav class="breadcrumb" aria-label="breadcrumb">
            <a href="/">{{ 'general.home' | t }}</a>
            <span>{{ 'general.breadcrumb_separator' | t }}</span>
            <span>{{ collection.title }}</span>
          </nav>
          <h1 class="collection-title__text collection-title__text--large">{{ collection.title }}</h1>
        </div>
      {%- when 'style-4' -%}
        <div class="collection-title__centered">
          <div class="container">
            <p class="eyebrow">{{ 'collections.general.collection' | t }}</p>
            <h1 class="collection-title__text">{{ collection.title }}</h1>
          </div>
        </div>
      {%- when 'style-5' -%}
        <div class="collection-title__split">
          <div class="container">
            <h1 class="collection-title__text">{{ collection.title }}</h1>
            <p class="collection-title__count">{{ collection.products_count }} {{ 'collections.general.items' | t }}</p>
          </div>
        </div>
    {%- endcase -%}
  </div>

  {%- comment -%} Filter bar (drawer / dropdown styles) {%- endcomment -%}
  {%- if filter_style == 'drawer' or filter_style == 'dropdown' -%}
    <div class="collection-toolbar container">
      {%- if filter_style == 'drawer' -%}
        <button class="toolbar-btn" data-open-filter-drawer>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="14" y2="18"/></svg>
          {{ 'collections.filtering.filter_button' | t }}
          {%- assign active_count = 0 -%}
          {%- for f in collection.filters -%}{%- assign active_count = active_count | plus: f.active_values.size -%}{%- endfor -%}
          {%- if active_count > 0 -%}<span class="filter-count">{{ active_count }}</span>{%- endif -%}
        </button>
      {%- elsif filter_style == 'dropdown' -%}
        <div class="dropdown-filters">
          {%- for filter in collection.filters -%}
            <details class="dropdown-filter" data-filter-group>
              <summary>{{ filter.label }}</summary>
              <div class="dropdown-filter__panel">
                {%- for value in filter.values -%}
                  <label class="filter-check">
                    <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      data-filter-url="{{ value.url_to_add }}"
                      data-filter-remove="{{ value.url_to_remove }}"
                    >
                    <span>{{ value.label }}</span>
                    <span class="filter-count-pill">{{ value.count }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </details>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="toolbar-right">
        {%- render 'collection-sort' -%}
        {%- if sidebar_position == 'none' -%}
          {%- render 'collection-view-toggle', columns: columns -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="collection-layout container {% if sidebar_position != 'none' %}collection-layout--has-sidebar collection-layout--sidebar-{{ sidebar_position }}{% endif %}">

    {%- comment -%} Left Sidebar {%- endcomment -%}
    {%- if sidebar_position == 'left' or sidebar_position == 'right' -%}
      <aside class="collection-sidebar" aria-label="Filters">
        {%- if filter_style != 'drawer' and filter_style != 'dropdown' -%}
          <div class="sidebar-header">
            <h2 class="sidebar-header__title">{{ 'collections.filtering.filters' | t }}</h2>
            {%- assign has_active = false -%}
            {%- for f in collection.filters -%}
              {%- if f.active_values.size > 0 -%}{%- assign has_active = true -%}{%- endif -%}
            {%- endfor -%}
            {%- if has_active -%}
              <a href="{{ collection.url }}" class="sidebar-clear">{{ 'collections.filtering.clear_all' | t }}</a>
            {%- endif -%}
          </div>

          {%- for filter in collection.filters -%}
            <div class="filter-group" data-filter-group>
              <button class="filter-group__toggle" aria-expanded="true">
                {{ filter.label }}
                {%- render 'icon-chevron-down' -%}
              </button>
              <div class="filter-group__body">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    <ul class="filter-list">
                      {%- for value in filter.values -%}
                        <li>
                          <label class="filter-check">
                            <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              data-filter-url="{{ value.url_to_add }}"
                              data-filter-remove="{{ value.url_to_remove }}"
                            >
                            <span>{{ value.label }}</span>
                            <span class="filter-count-pill">{{ value.count }}</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- when 'price_range' -%}
                    <div class="price-range-filter">
                      <div class="price-range-slider" data-price-range
                        data-min="{{ filter.range_min | money_without_currency }}"
                        data-max="{{ filter.range_max | money_without_currency }}"
                        data-current-min="{{ filter.min_value.value | default: filter.range_min | money_without_currency }}"
                        data-current-max="{{ filter.max_value.value | default: filter.range_max | money_without_currency }}"
                      ></div>
                      <div class="price-range-inputs">
                        <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | remove: ',' }}" placeholder="{{ filter.range_min | money }}">
                        <span>–</span>
                        <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | remove: ',' }}" placeholder="{{ filter.range_max | money }}">
                      </div>
                    </div>
                {%- endcase -%}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="sidebar-sort">
            {%- render 'collection-sort' -%}
            {%- render 'collection-view-toggle', columns: columns -%}
          </div>
        {%- endif -%}
      </aside>
    {%- endif -%}

    {%- comment -%} Main Products Area {%- endcomment -%}
    <div class="collection-main" id="collection-products">
      {%- if sidebar_position == 'none' and filter_style != 'drawer' and filter_style != 'dropdown' -%}
        <div class="collection-toolbar collection-toolbar--inline">
          {%- render 'collection-sort' -%}
          {%- render 'collection-view-toggle', columns: columns -%}
        </div>
      {%- endif -%}

      {%- comment -%} Active filter chips {%- endcomment -%}
      {%- assign has_active_filters = false -%}
      {%- for f in collection.filters -%}
        {%- if f.active_values.size > 0 or f.min_value.value or f.max_value.value -%}
          {%- assign has_active_filters = true -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_active_filters -%}
        <div class="active-filters">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <a href="{{ value.url_to_remove }}" class="filter-chip filter-chip--active">
                {{ value.label }} ×
              </a>
            {%- endfor -%}
            {%- if filter.min_value.value or filter.max_value.value -%}
              <a href="{{ filter.url_to_remove }}" class="filter-chip filter-chip--active">
                {{ filter.min_value.value | default: filter.range_min | money }} – {{ filter.max_value.value | default: filter.range_max | money }} ×
              </a>
            {%- endif -%}
          {%- endfor -%}
          <a href="{{ collection.url }}" class="filter-chip filter-chip--clear">{{ 'collections.filtering.clear_all' | t }}</a>
        </div>
      {%- endif -%}

      {%- if collection.products.size == 0 -%}
        <div class="collection-empty">
          <p>{{ 'collections.general.no_matches' | t }}</p>
          {%- if has_active_filters -%}
            <a href="{{ collection.url }}" class="btn-ghost">{{ 'collections.filtering.clear_all' | t }}</a>
          {%- endif -%}
        </div>
      {%- else -%}
        <div
          class="product-grid product-grid--{{ columns }}"
          id="product-grid"
          data-view="{{ view_default }}"
        >
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          {%- if pagination_style == 'load_more' -%}
            <div class="pagination-load-more">
              {%- if paginate.next -%}
                <button class="btn-ghost" data-load-more data-next-url="{{ paginate.next.url }}">
                  {{ 'collections.general.load_more' | t }}
                  <span class="load-more-count">({{ paginate.next.title }})</span>
                </button>
              {%- endif -%}
            </div>
          {%- elsif pagination_style == 'infinite' -%}
            <div class="pagination-infinite" data-infinite-scroll {% if paginate.next %}data-next-url="{{ paginate.next.url }}"{% endif %}>
              <span class="pagination-spinner"></span>
            </div>
          {%- else -%}
            <nav class="pagination" aria-label="{{ 'accessibility.pagination' | t }}">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="pagination__item pagination__item--prev">← {{ 'general.pagination.previous' | t }}</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination__item pagination__item--gap">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="pagination__item pagination__item--next">{{ 'general.pagination.next' | t }} →</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Filter Drawer (for drawer mode) {%- endcomment -%}
  {%- if filter_style == 'drawer' -%}
    <div class="filter-drawer" id="filter-drawer" role="dialog" aria-modal="true" aria-label="{{ 'collections.filtering.filters' | t }}">
      <div class="filter-drawer__header">
        <h2>{{ 'collections.filtering.filters' | t }}</h2>
        <button class="filter-drawer__close" data-close-filter-drawer aria-label="{{ 'accessibility.close' | t }}">{%- render 'icon-close' -%}</button>
      </div>
      <div class="filter-drawer__body">
        {%- for filter in collection.filters -%}
          <div class="filter-group" data-filter-group>
            <button class="filter-group__toggle" aria-expanded="true">
              {{ filter.label }} {%- render 'icon-chevron-down' -%}
            </button>
            <div class="filter-group__body">
              {%- case filter.type -%}
                {%- when 'list' -%}
                  <ul class="filter-list">
                    {%- for value in filter.values -%}
                      <li>
                        <label class="filter-check">
                          <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                            {% if value.active %}checked{% endif %}
                            data-filter-url="{{ value.url_to_add }}"
                            data-filter-remove="{{ value.url_to_remove }}"
                          >
                          <span>{{ value.label }}</span>
                          <span class="filter-count-pill">{{ value.count }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- when 'price_range' -%}
                  <div class="price-range-inputs">
                    <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | remove: ',' }}" placeholder="{{ filter.range_min | money }}">
                    <span>–</span>
                    <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | remove: ',' }}" placeholder="{{ filter.range_max | money }}">
                  </div>
              {%- endcase -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
      <div class="filter-drawer__footer">
        <a href="{{ collection.url }}" class="btn-ghost">{{ 'collections.filtering.clear_all' | t }}</a>
        <button class="btn-primary" data-close-filter-drawer>{{ 'collections.filtering.apply' | t }}</button>
      </div>
    </div>
    <div class="filter-drawer__overlay" data-close-filter-drawer></div>
  {%- endif -%}
</div>

{%- endpaginate -%}

<style>
  .collection-page { padding-bottom: var(--section-spacing); }
  .collection-title { margin-bottom: 40px; }
  .collection-title--style-1 { padding-top: 56px; }
  .collection-title--style-2 .collection-title__banner {
    min-height: 280px; background: var(--charcoal) center/cover no-repeat;
    display: flex; align-items: flex-end; padding-bottom: 40px;
    background-blend-mode: overlay;
  }
  .collection-title--style-4 .collection-title__centered { text-align: center; padding-top: 56px; }
  .collection-title--style-5 .collection-title__split { padding-top: 32px; }
  .collection-title--style-5 .container { display: flex; align-items: baseline; justify-content: space-between; }
  .collection-title__text { font-family: var(--ff-display); font-size: clamp(28px, 4vw, 56px); font-weight: 300; letter-spacing: 0.02em; }
  .collection-title--style-2 .collection-title__text { color: var(--cream); }
  .collection-title__text--large { font-size: clamp(40px, 6vw, 80px); }
  .collection-title__count { font-size: 12px; letter-spacing: 0.2em; color: var(--muted); text-transform: uppercase; }
  .collection-title__desc { margin-top: 16px; font-size: 13px; opacity: 0.6; max-width: 560px; line-height: 1.7; }

  .collection-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 24px; padding-bottom: 24px;
    border-bottom: 1px solid var(--border); margin-bottom: 32px;
  }
  .collection-toolbar--inline { border-top: 0; margin-top: 0; }
  .toolbar-right { display: flex; align-items: center; gap: 16px; }
  .toolbar-btn {
    display: flex; align-items: center; gap: 8px;
    background: transparent; border: 1px solid var(--border);
    color: var(--cream); font-family: var(--ff-body); font-size: 11px;
    letter-spacing: 0.2em; text-transform: uppercase; padding: 10px 20px; cursor: pointer;
    transition: border-color 0.3s;
  }
  .toolbar-btn:hover { border-color: var(--gold); }
  .filter-count { background: var(--gold); color: var(--black); width: 18px; height: 18px; border-radius: 50%; font-size: 9px; display: flex; align-items: center; justify-content: center; }

  .collection-layout { display: flex; gap: 48px; align-items: flex-start; }
  .collection-layout--has-sidebar.collection-layout--sidebar-left { flex-direction: row; }
  .collection-layout--has-sidebar.collection-layout--sidebar-right { flex-direction: row-reverse; }
  .collection-sidebar { width: 260px; flex-shrink: 0; position: sticky; top: 100px; }
  .collection-main { flex: 1; min-width: 0; }

  .sidebar-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .sidebar-header__title { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; }
  .sidebar-clear { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--muted); }

  .filter-group { border-bottom: 1px solid var(--border); }
  .filter-group__toggle {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    background: transparent; border: none; color: var(--cream);
    font-family: var(--ff-body); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 16px 0; cursor: pointer;
  }
  .filter-group__toggle svg { transition: transform 0.3s; }
  .filter-group__toggle[aria-expanded="false"] svg { transform: rotate(-90deg); }
  .filter-group__body { padding-bottom: 16px; }
  .filter-list { list-style: none; }
  .filter-check { display: flex; align-items: center; gap: 10px; padding: 6px 0; cursor: pointer; font-size: 13px; color: var(--cream); }
  .filter-check input[type="checkbox"] { appearance: none; width: 14px; height: 14px; border: 1px solid var(--border); border-radius: 1px; flex-shrink: 0; transition: all 0.2s; }
  .filter-check input[type="checkbox"]:checked { background: var(--gold); border-color: var(--gold); }
  .filter-count-pill { margin-left: auto; font-size: 10px; color: var(--muted); }

  .active-filters { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .filter-chip { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; padding: 6px 12px; border: 1px solid var(--border); color: var(--cream); transition: all 0.2s; }
  .filter-chip--active { border-color: var(--gold); color: var(--gold); }
  .filter-chip--active:hover { background: var(--gold); color: var(--black); }
  .filter-chip--clear { color: var(--muted); }

  .collection-empty { text-align: center; padding: 80px 20px; opacity: 0.6; }
  .collection-empty .btn-ghost { margin-top: 24px; }

  .dropdown-filters { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .dropdown-filter { position: relative; }
  .dropdown-filter summary {
    list-style: none; cursor: pointer; padding: 10px 20px; border: 1px solid var(--border);
    font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--cream);
    transition: border-color 0.3s; display: flex; align-items: center; gap: 8px;
  }
  .dropdown-filter summary:hover { border-color: var(--gold); }
  .dropdown-filter__panel {
    position: absolute; top: 100%; left: 0; min-width: 200px; z-index: var(--z-raised);
    background: var(--charcoal); border: 1px solid var(--border); padding: 16px;
    max-height: 280px; overflow-y: auto;
  }

  .filter-drawer {
    position: fixed; top: 0; right: -400px; width: 380px; height: 100vh;
    background: var(--charcoal); z-index: var(--z-drawer);
    display: flex; flex-direction: column;
    transition: right 0.4s var(--ease-out);
  }
  .filter-drawer.is-open { right: 0; }
  .filter-drawer__header { display: flex; align-items: center; justify-content: space-between; padding: 24px 28px; border-bottom: 1px solid var(--border); }
  .filter-drawer__header h2 { font-size: 12px; letter-spacing: 0.25em; text-transform: uppercase; }
  .filter-drawer__close { background: transparent; border: none; color: var(--cream); cursor: pointer; padding: 4px; }
  .filter-drawer__body { flex: 1; overflow-y: auto; padding: 0 28px; }
  .filter-drawer__footer { padding: 24px 28px; border-top: 1px solid var(--border); display: flex; gap: 12px; }
  .filter-drawer__overlay { position: fixed; inset: 0; background: var(--black-overlay); z-index: calc(var(--z-drawer) - 1); display: none; }
  .filter-drawer.is-open ~ .filter-drawer__overlay { display: block; }

  .pagination { display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 48px; }
  .pagination__item { padding: 10px 16px; border: 1px solid var(--border); font-size: 12px; letter-spacing: 0.1em; color: var(--cream); transition: all 0.2s; }
  .pagination__item--current { border-color: var(--gold); color: var(--gold); }
  .pagination__item:hover:not(.pagination__item--current):not(.pagination__item--gap) { border-color: var(--gold); }
  .pagination__item--gap { border-color: transparent; }
  .pagination-load-more { text-align: center; margin-top: 48px; }
  .pagination-spinner { display: block; width: 24px; height: 24px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 32px auto; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .price-range-inputs { display: flex; align-items: center; gap: 8px; }
  .price-range-inputs input { width: 80px; background: transparent; border: 1px solid var(--border); color: var(--cream); font-family: var(--ff-body); font-size: 12px; padding: 8px 10px; outline: none; }
  .price-range-inputs input:focus { border-color: var(--gold); }
  .price-range-inputs span { color: var(--muted); }

  @media (max-width: 1024px) {
    .collection-sidebar { width: 220px; }
  }
  @media (max-width: 900px) {
    .collection-layout--has-sidebar { flex-direction: column; }
    .collection-sidebar { width: 100%; position: static; }
  }
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "div",
  "settings": [
    {
      "type": "select", "id": "title_style", "label": "Collection Title Style",
      "options": [
        { "value": "style-1", "label": "Style 1 — Simple Text" },
        { "value": "style-2", "label": "Style 2 — Banner Image" },
        { "value": "style-3", "label": "Style 3 — With Breadcrumb" },
        { "value": "style-4", "label": "Style 4 — Centered + Eyebrow" },
        { "value": "style-5", "label": "Style 5 — Left + Item Count" }
      ],
      "default": "style-1"
    },
    {
      "type": "select", "id": "sidebar_position", "label": "Sidebar Position",
      "options": [
        { "value": "left",  "label": "Left Sidebar" },
        { "value": "right", "label": "Right Sidebar" },
        { "value": "none",  "label": "No Sidebar" }
      ],
      "default": "left"
    },
    {
      "type": "select", "id": "filter_style", "label": "Filter Style",
      "options": [
        { "value": "sidebar",  "label": "Sidebar (static)" },
        { "value": "drawer",   "label": "Drawer (slide-in)" },
        { "value": "dropdown", "label": "Dropdown Bar" },
        { "value": "toggle",   "label": "Toggle Groups" }
      ],
      "default": "sidebar"
    },
    {
      "type": "select", "id": "grid_columns", "label": "Default Grid Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "3"
    },
    {
      "type": "select", "id": "view_default", "label": "Default View",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ],
      "default": "grid"
