{%- liquid
  assign s = section.settings
  assign fallbacks = 'https://images.unsplash.com/photo-1539109136881-3be0616acf4b?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1525507119028-ed4c629a60a3?auto=format&fit=crop&w=900&q=85|https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=900&q=85' | split: '|'
-%}

<section
  id="section-{{ section.id }}"
  class="cix-section cix--{{ s.scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="cix-inner">
    <div class="cix-head reveal">
      <div>
        {%- if s.eyebrow != blank -%}<span class="cix-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="cix-heading">{{ s.heading }}</h2>{%- endif -%}
      </div>
      {%- if s.intro != blank -%}<p class="cix-intro">{{ s.intro }}</p>{%- endif -%}
    </div>

    <div class="cix-grid">
      {%- for block in section.blocks -%}
        {%- assign fb = fallbacks[forloop.index0] | default: fallbacks[0] -%}
        {%- assign img = block.settings.image -%}
        <a
          href="{{ block.settings.link | default: '/collections/all' }}"
          class="cix-tile reveal{% if forloop.first %} cix-tile--feature{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="cix-tile__media">
            {%- if img != blank -%}
              {{ img | image_url: width: 900 | image_tag: loading: 'lazy', class: 'cix-tile__img', sizes: '(max-width:800px) 90vw, 45vw', widths: '400,600,900', alt: block.settings.title }}
            {%- else -%}
              <img class="cix-tile__img" src="{{ fb }}" alt="{{ block.settings.title | escape }}" loading="lazy" />
            {%- endif -%}
          </div>
          <span class="cix-tile__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <div class="cix-tile__body">
            {%- if block.settings.kicker != blank -%}<span class="cix-tile__kicker">{{ block.settings.kicker }}</span>{%- endif -%}
            <span class="cix-tile__title">{{ block.settings.title }}</span>
            <span class="cix-tile__cta">{{ block.settings.cta | default: 'Explore' }} <span aria-hidden="true">&#8594;</span></span>
          </div>
        </a>
      {%- else -%}
        {%- assign demo_titles = 'Outerwear,Tailoring,Knitwear,Accessories' | split: ',' -%}
        {%- assign demo_kick = 'The Structure,The Cut,The Comfort,The Detail' | split: ',' -%}
        {%- for i in (0..3) -%}
          <a href="/collections/all" class="cix-tile reveal{% if forloop.first %} cix-tile--feature{% endif %}">
            <div class="cix-tile__media">
              <img class="cix-tile__img" src="{{ fallbacks[i] }}" alt="{{ demo_titles[i] }}" loading="lazy" />
            </div>
            <span class="cix-tile__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <div class="cix-tile__body">
              <span class="cix-tile__kicker">{{ demo_kick[i] }}</span>
              <span class="cix-tile__title">{{ demo_titles[i] }}</span>
              <span class="cix-tile__cta">Explore <span aria-hidden="true">&#8594;</span></span>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }}.cix--light { --bg:#ECE9E2; --fg:#18181A; --acc:var(--gold,#9A7B43); --mut:rgba(24,24,26,.55); --bdr:rgba(24,24,26,.14); }
  #section-{{ section.id }}.cix--dark  { --bg:#161618; --fg:#ECE9E2; --acc:var(--gold,#C8A96E); --mut:rgba(236,233,226,.52); --bdr:rgba(236,233,226,.14); }
  #section-{{ section.id }}.cix--warm  { --bg:#E7DCCB; --fg:#241D15; --acc:var(--gold,#8E4F2A); --mut:rgba(36,29,21,.55); --bdr:rgba(36,29,21,.18); }
  #section-{{ section.id }}.cix--theme { --bg:var(--background,#161618); --fg:var(--foreground,#ECE9E2); --acc:var(--gold,#C8A96E); --mut:var(--muted,rgba(236,233,226,.52)); --bdr:var(--border,rgba(236,233,226,.14)); }

  #section-{{ section.id }} { background: var(--bg); color: var(--fg); padding: var(--section-spacing,80px) var(--side-padding,5vw); }
  #section-{{ section.id }} .cix-inner { max-width: var(--container-width,1440px); margin: 0 auto; }

  #section-{{ section.id }} .cix-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 28px; margin-bottom: clamp(34px,4vw,54px); flex-wrap: wrap; }
  #section-{{ section.id }} .cix-eyebrow { display: block; font-family: var(--ff-body,'Outfit',sans-serif); font-size: 11px; font-weight: 500; letter-spacing: .26em; text-transform: uppercase; color: var(--acc); margin-bottom: 14px; }
  #section-{{ section.id }} .cix-heading { font-family: var(--ff-display,'Cormorant Garamond',serif); font-size: calc(clamp(32px,4.4vw,62px) * var(--heading-scale,1)); font-weight: 300; line-height: 1.02; text-transform: uppercase; margin: 0; }
  #section-{{ section.id }} .cix-intro { font-family: var(--ff-body,'Outfit',sans-serif); font-size: clamp(13px,1vw,15px); line-height: 1.7; color: var(--mut); max-width: 340px; }

  #section-{{ section.id }} .cix-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: clamp(10px,1.2vw,18px); }
  #section-{{ section.id }} .cix-tile {
    position: relative; grid-column: span 2; aspect-ratio: 3/4; overflow: hidden;
    display: block; text-decoration: none; color: var(--fg); background: var(--bdr);
  }
  #section-{{ section.id }} .cix-tile--feature { grid-column: span 3; grid-row: span 2; aspect-ratio: auto; }
  #section-{{ section.id }} .cix-tile__media { position: absolute; inset: 0; overflow: hidden; }
  #section-{{ section.id }} .cix-tile__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .7s cubic-bezier(.2,0,.2,1); filter: saturate(.92); }
  #section-{{ section.id }} .cix-tile:hover .cix-tile__img { transform: scale(1.05); }
  #section-{{ section.id }} .cix-tile::after { content:''; position:absolute; inset:0; background: linear-gradient(to top, rgba(12,12,13,.78) 0%, rgba(12,12,13,.06) 52%, transparent 100%); z-index:1; }

  #section-{{ section.id }} .cix-tile__num {
    position: absolute; top: 14px; left: 16px; z-index: 2;
    font-family: var(--ff-display,'Cormorant Garamond',serif); font-size: clamp(26px,2.6vw,44px);
    line-height: 1; color: rgba(255,255,255,.92);
  }
  #section-{{ section.id }} .cix-tile__body { position: absolute; left: 18px; right: 18px; bottom: 18px; z-index: 2; }
  #section-{{ section.id }} .cix-tile__kicker { display: block; font-family: var(--ff-body,'Outfit',sans-serif); font-size: 10px; font-weight: 500; letter-spacing: .2em; text-transform: uppercase; color: var(--acc); margin-bottom: 8px; }
  #section-{{ section.id }} .cix-tile__title { display: block; font-family: var(--ff-display,'Cormorant Garamond',serif); font-size: clamp(22px,2.2vw,40px); font-weight: 400; line-height: 1.05; color: #fff; }
  #section-{{ section.id }} .cix-tile--feature .cix-tile__title { font-size: clamp(30px,3.4vw,58px); }
  #section-{{ section.id }} .cix-tile__cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; font-family: var(--ff-body,'Outfit',sans-serif); font-size: 11px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.85); opacity: 0; transform: translateY(6px); transition: opacity .3s, transform .3s; }
  #section-{{ section.id }} .cix-tile:hover .cix-tile__cta { opacity: 1; transform: none; }

  #section-{{ section.id }} .reveal.reveal-armed { opacity: 0; transform: translateY(26px); transition: opacity .7s ease, transform .7s ease; }
  #section-{{ section.id }} .reveal.is-visible { opacity: 1; transform: none; }
  #section-{{ section.id }} .cix-tile:nth-child(2){transition-delay:.06s;}
  #section-{{ section.id }} .cix-tile:nth-child(3){transition-delay:.12s;}
  #section-{{ section.id }} .cix-tile:nth-child(4){transition-delay:.18s;}

  @media (max-width: 800px) {
    #section-{{ section.id }} .cix-grid { grid-template-columns: repeat(2, 1fr); }
    #section-{{ section.id }} .cix-tile,
    #section-{{ section.id }} .cix-tile--feature { grid-column: span 1; grid-row: auto; aspect-ratio: 3/4; }
  }
</style>

<script>
(function(){
  var SEC='{{ section.id }}';
  function arm(root){
    var els=root.querySelectorAll('.reveal');
    els.forEach(function(el){el.classList.add('reveal-armed');});
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target);}});},{threshold:.12});
    els.forEach(function(el){io.observe(el);});
    setTimeout(function(){els.forEach(function(el){el.classList.add('is-visible');});},800);
  }
  function root(){return document.getElementById('section-'+SEC);}
  document.addEventListener('DOMContentLoaded',function(){var r=root();if(r)arm(r);});
  document.addEventListener('shopify:section:load',function(e){if(e.detail.sectionId!==SEC)return;var r=root();if(r){arm(r);r.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});}});
})();
</script>

{% schema %}
{
  "name": "Category Index",
  "tag": "section",
  "class": "section-category-index",
  "max_blocks": 7,
  "settings": [
    {
      "type": "select", "id": "scheme", "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (bone)" },
        { "value": "dark",  "label": "Dark (graphite)" },
        { "value": "warm",  "label": "Warm (sand)" },
        { "value": "theme", "label": "Follow theme" }
      ],
      "default": "light"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Index" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Four pillars of the collection — engineered for movement, made for the modern wardrobe." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "The Cut" },
        { "type": "text", "id": "title",  "label": "Title",  "default": "Tailoring" },
        { "type": "text", "id": "cta",    "label": "CTA label", "default": "Explore" },
        { "type": "url",  "id": "link",   "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Index",
      "blocks": [
        { "type": "category", "settings": { "kicker": "The Structure", "title": "Outerwear" } },
        { "type": "category", "settings": { "kicker": "The Cut", "title": "Tailoring" } },
        { "type": "category", "settings": { "kicker": "The Comfort", "title": "Knitwear" } },
        { "type": "category", "settings": { "kicker": "The Detail", "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
